---
import { contacts } from '@shared/constants/contacts'

const whatsappText = encodeURIComponent('Здравствуйте! Жду коммерческое предложение на радиаторы и конвекторы Velar.')
const whatsappHref = `https://wa.me/${contacts.whatsApp}?text=${whatsappText}`
---

<section class='mx-auto mb-10 mt-2 max-w-3xl rounded-2xl border border-neutral-200 bg-white px-5 py-8 text-center shadow-sm md:mb-14 md:mt-4 md:px-10 md:py-10'>
	<div class='mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-50 text-emerald-700'>
		<svg
			class='h-6 w-6'
			aria-hidden='true'
			viewBox='0 0 24 24'
			fill='none'
			stroke='currentColor'
			stroke-width='1.8'
			stroke-linecap='round'
			stroke-linejoin='round'
		>
			<path d='M21.8 11.1v.8a9.8 9.8 0 1 1-5.8-9' />
			<path d='m9 11 3 3L22 4' />
		</svg>
	</div>

	<h1 class='m-0 text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl'>Запрос принят</h1>

	<p class='mx-auto mt-5 max-w-2xl text-base font-normal leading-7 text-neutral-700'>
		Спасибо! Мы получили вашу заявку и подготовим расчет в ближайшие рабочие часы.
		Если потребуется уточнить параметры радиаторов, менеджер свяжется с вами по выбранному способу связи.
	</p>

	<p class='mx-auto mt-4 max-w-2xl text-base font-normal leading-7 text-neutral-700'>
		Если вы выбрали связь через мессенджер, напишите нам короткое сообщение в WhatsApp или Telegram.
		Так диалог закрепится за вашим аккаунтом, и мы сможем быстрее отправить расчет.
	</p>

	<div class='mt-7 grid gap-3 sm:grid-cols-2'>
		<a
			href={whatsappHref}
			class='inline-flex h-11 items-center justify-center gap-2 rounded-md bg-[#1f9d55] px-4 text-sm font-medium text-white no-underline transition hover:bg-[#188548] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#1f9d55]'
		>
			<svg class='h-5 w-5' aria-hidden='true' fill='currentColor' viewBox='0 0 32 32'>
				<path d='M26.6 5.4A14.8 14.8 0 0 0 1.2 15.9c0 2.7.7 5.3 2 7.5L1.1 31l7.9-2.1a14.8 14.8 0 0 0 7.1 1.8A14.8 14.8 0 0 0 26.6 5.4ZM16.1 28.2c-2.3 0-4.5-.6-6.3-1.7l-.5-.3-4.7 1.2 1.3-4.6-.3-.5a12.3 12.3 0 1 1 10.5 5.9Zm6.7-9.2c-.4-.2-2.2-1.1-2.5-1.2-.3-.1-.6-.2-.8.2-.3.4-1 1.2-1.2 1.5-.2.2-.4.3-.8.1-1.1-.5-2.1-1.1-3-1.9-.8-.7-1.5-1.6-2-2.5-.2-.4 0-.6.2-.8l.6-.6c.1-.2.3-.4.4-.6.1-.2.1-.4 0-.6-.1-.2-.8-2-1.1-2.8-.3-.7-.6-.6-.8-.6h-.7c-.4 0-.7.2-1 .5-.8.8-1.3 1.8-1.3 3 0 1.5.7 2.9 1.5 3.9 1.6 2.4 3.7 4.3 6.3 5.6.5.2 1.2.5 2 .7.4.1.9.2 1.5.2.3 0 .6 0 .9-.1 1.1-.2 2-.9 2.5-1.8.2-.4.3-.8.3-1.2 0-.2 0-.4-.1-.5-.1-.2-.3-.3-.7-.5Z' />
			</svg>
			Написать в WhatsApp
		</a>

		<a
			href={contacts.telegram}
			class='inline-flex h-11 items-center justify-center gap-2 rounded-md bg-[#2a8fbd] px-4 text-sm font-medium text-white no-underline transition hover:bg-[#247ca5] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2a8fbd]'
		>
			<svg class='h-5 w-5' aria-hidden='true' fill='currentColor' viewBox='0 0 24 24'>
				<path d='M21.9 4.3 18.7 19.6c-.2 1.2-1.7 1.7-2.7 1l-4.1-3.1-2 2a.8.8 0 0 1-1.4-.4l-1.5-5.3-4-1.6c-1.2-.5-1.2-2.2 0-2.7L19.9 3c1.1-.4 2.2.3 2 1.3ZM8.3 13.4l.9 3.4.3-2.1 7.8-7.1-9 5.8Z' />
			</svg>
			Написать в Telegram
		</a>
	</div>

	<div class='mt-5 grid gap-3 sm:grid-cols-2'>
		<a
			href='/design'
			class='inline-flex h-10 items-center justify-center rounded-md border border-neutral-300 px-4 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-950 hover:bg-neutral-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400'
		>
			Вернуться в каталог
		</a>

		<a
			href='/'
			class='inline-flex h-10 items-center justify-center rounded-md border border-neutral-300 px-4 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-950 hover:bg-neutral-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400'
		>
			На главную
		</a>
	</div>
</section>
