---
import { columnsCardTextClass, columnsCardTitleClass, columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

const items = [
	{
		title: '2-трубчатые',
		badge: '2 трубки - минимальная глубина',
		image: '/images/columns/2columns.jpg',
		description:
			'Самый неглубокий вариант. Подходит для небольших помещений, узких проходов, подоконных зон и случаев, когда радиатор не должен сильно выступать от стены.',
		tech: 'Глубина секции: 70 мм',
		cta: { label: 'Смотреть 2-трубчатые модели', tube: '2' },
	},
	{
		title: '3-трубчатые',
		badge: '3 трубки - универсальный выбор',
		image: '/images/columns/3columns.jpg',
		description:
			'Универсальный вариант для квартир и частных домов. Хороший баланс глубины, теплоотдачи и внешнего вида.',
		tech: 'Глубина секции: 100 мм',
		cta: { label: 'Смотреть 3-трубчатые модели', tube: '3' },
	},
	{
		title: '4-трубчатые',
		badge: '4 трубки - больше мощности',
		image: '/images/columns/4columns.jpg',
		description:
			'Более мощное решение для помещений с повышенными теплопотерями, высокими потолками, большими окнами или увеличенной площадью.',
		tech: 'Глубина секции: 140 мм',
		cta: { label: 'Смотреть 4-трубчатые модели', tube: '4' },
	},
	{
		title: '5-трубчатые',
		badge: '5 трубок - по запросу / спецзадачи',
		image: '/images/models/columns/main4b.jpg',
		description:
			'5-трубчатые модели - перспективное решение для задач, где нужна максимальная теплоотдача. Если вам нужен такой формат, отправьте параметры помещения - менеджер проверит доступность и подберет альтернативу среди текущих моделей.',
		tech: 'Новинка 2026 года',
		note: 'Технические данные появятся позже.',
		cta: { label: 'Получить консультацию', href: '/request' },
	},
]
---

<section id='columns-tube-differences' class='bg-white py-12 md:py-14 xl:py-16'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={`max-w-4xl ${columnsSectionTitleClass}`}>
			2-, 3-, 4- и 5-трубчатые радиаторы - что выбрать
		</h2>
		<p class={`mt-3 max-w-4xl ${columnsSectionSubtitleClass}`}>
			Количество труб в секции влияет на глубину, теплоотдачу и визуальную массивность радиатора. Чем больше труб, тем мощнее и глубже секция. Для небольших помещений и зон под окном часто достаточно 2-3 трубок, для комнат с повышенными теплопотерями и больших помещений лучше смотреть 3-4 трубки.
		</p>
		<div class='mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4'>
			{items.map(item => (
				<article class='group flex h-full flex-col rounded-lg border border-neutral-200 bg-white p-4 transition hover:border-neutral-300 md:p-5'>
					<div class='h-[178px] overflow-hidden rounded-md bg-white md:h-[196px] xl:h-[184px]'>
						<img
							src={item.image}
							alt={`${item.title} радиаторы Velar`}
							title={`${item.title} радиаторы Velar`}
							loading='lazy'
							class='h-full w-full object-cover object-[50%_18%] transition duration-300 group-hover:scale-[1.03]'
						/>
					</div>
					<span class='mt-4 inline-flex w-fit items-center rounded-full bg-red-50 px-2.5 py-1 text-[11px] font-medium leading-tight text-red-700 md:text-xs'>
						{item.badge}
					</span>
					<h3 class={`mt-3 ${columnsCardTitleClass}`}>{item.title}</h3>
					<p class={`mt-2 flex-1 ${columnsCardTextClass}`}>{item.description}</p>
					<div class='mt-4 border-t border-neutral-100 pt-3 text-sm font-semibold leading-5 text-neutral-950 md:text-sm'>{item.tech}</div>
					{item.note && <div class='mt-1 text-xs leading-5 text-neutral-500'>{item.note}</div>}
					{item.cta.href ? (
						<a
							href={item.cta.href}
							class='mt-4 inline-flex h-9 items-center justify-center rounded-lg border border-neutral-300 bg-white px-3.5 text-xs font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'
						>
							{item.cta.label}
						</a>
					) : (
						<button
							type='button'
							data-tube-filter={item.cta.tube}
							class='mt-4 inline-flex h-9 cursor-pointer items-center justify-center rounded-lg border border-neutral-300 bg-white px-3.5 text-xs font-semibold text-neutral-950 transition hover:border-red-300 hover:bg-red-50 hover:text-red-700'
						>
							{item.cta.label}
						</button>
					)}
				</article>
			))}
		</div>
	</div>
</section>

<script is:inline>
	document.addEventListener('click', event => {
		const target = event.target
		if (!(target instanceof HTMLElement)) return
		const button = target.closest('[data-tube-filter]')
		if (!(button instanceof HTMLElement)) return

		const value = button.getAttribute('data-tube-filter')
		if (!value) return

		window.dispatchEvent(
			new CustomEvent('columns:setFilter', { detail: { field: 'tubes', value } }),
		)

		const modelList = document.getElementById('model_list')
		if (modelList) modelList.scrollIntoView({ behavior: 'smooth', block: 'start' })
	})
</script>
