---
const items = [
	{
		title: '2-трубчатые',
		image: '/images/columns/2columns.jpg',
		description: 'Компактные и легкие. Подходят для небольших помещений, подоконных зон и спокойных интерьеров.',
		href: '/columns/2057',
	},
	{
		title: '3-трубчатые',
		image: '/images/columns/3columns.jpg',
		description: 'Оптимальный баланс размера и теплоотдачи. Универсальное решение для квартиры и дома.',
		href: '/columns/3057',
	},
	{
		title: '4-трубчатые',
		image: '/images/columns/4columns.jpg',
		description: 'Повышенная теплоотдача для стандартных и больших помещений с заметными теплопотерями.',
		href: '/columns/4057',
	},
	{
		title: '5-трубчатые',
		image: '/images/models/columns/main4b.jpg',
		description: 'Максимальная глубина и мощность для просторных помещений, общественных и коммерческих зон.',
		href: '/request',
	},
]
---

<section id='columns-tube-differences' class='bg-white py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class='max-w-4xl text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl'>
			Чем отличаются 2-, 3-, 4- и 5-трубчатые радиаторы
		</h2>
		<div class='mt-7 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4'>
			{items.map(item => (
				<article class='group rounded-[20px] border border-neutral-200 bg-white p-4 transition hover:border-neutral-300 hover:bg-neutral-50'>
					<div class='flex h-[210px] items-center justify-center rounded-2xl bg-neutral-50 p-4'>
						<img
							src={item.image}
							alt={`${item.title} радиаторы Velar`}
							title={`${item.title} радиаторы Velar`}
							loading='lazy'
							class='h-full w-auto max-w-full object-contain object-center'
						/>
					</div>
					<h3 class='mt-4 text-lg font-semibold text-neutral-950'>{item.title}</h3>
					<p class='mt-2 text-sm leading-6 text-neutral-700'>{item.description}</p>
					<a href={item.href} class='mt-4 inline-flex text-sm font-semibold text-red-700 hover:underline'>Подробнее →</a>
				</article>
			))}
		</div>
	</div>
</section>
