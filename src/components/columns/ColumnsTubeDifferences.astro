---
import { Picture } from '@astrojs/image/components'

const items = [
	{
		title: '2-трубчатые',
		image: '/images/columns/2columns.jpg',
		depth: 'Компактная глубина',
		power: 'Ниже мощность секции',
		when: 'Под окна и для небольших помещений',
		description: 'Более аккуратные по толщине и удобны там, где важна компактность.',
	},
	{
		title: '3-трубчатые',
		image: '/images/columns/3columns.jpg',
		depth: 'Средняя глубина',
		power: 'Баланс мощности и габарита',
		when: 'Универсальный вариант для квартиры и дома',
		description: 'Чаще всего оптимальны для замены старых батарей без перегруза по глубине.',
	},
	{
		title: '4-трубчатые',
		image: '/images/columns/4columns.jpg',
		depth: 'Увеличенная глубина',
		power: 'Максимальная мощность секции',
		when: 'Для помещений с повышенной теплопотерей',
		description: 'Лучший выбор, когда приоритет — максимальная теплоотдача.',
	},
]
---

<section id='columns-tube-differences' class='bg-white py-12 md:py-16'>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>Чем отличаются 2-, 3- и 4-трубчатые радиаторы</h2>
		<div class='mt-6 grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4'>
			{
				items.map(item => (
					<article class='rounded-lg border border-neutral-200 bg-white p-4'>
						<div class='overflow-hidden rounded-[3px] bg-neutral-50'>
							<Picture
								src={item.image}
								alt={`${item.title} радиаторы Velar`}
								title={`${item.title} радиаторы Velar`}
								loading='lazy'
								aspectRatio='4:3'
								widths={[320, 480, 720]}
								width={720}
								sizes='(max-width: 768px) 100vw, 33vw'
								class='h-full max-h-[140px] w-full object-contain'
							/>
						</div>
						<h3 class='mt-3 text-sm font-semibold text-neutral-900'>{item.title}</h3>
						<p class='mt-2 text-xs text-neutral-700'>{item.description}</p>
						<ul class='mt-3 space-y-1.5 text-xs text-neutral-700'>
							<li>• {item.depth}</li>
							<li>• {item.power}</li>
							<li>• {item.when}</li>
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>
