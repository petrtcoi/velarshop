---
import { columnsCardTextClass, columnsCardTitleClass, columnsSectionTitleClass } from './columnsTypography'

const items = [
	{
		title: '2-трубчатые',
		image: '/images/columns/2columns.jpg',
		description:
			'Самый плоский вариант для небольших помещений и подоконных зон. Подходит там, где важна минимальная глубина радиатора.',
		tech: 'Глубина секции: 70 мм',
	},
	{
		title: '3-трубчатые',
		image: '/images/columns/3columns.jpg',
		description: 'Универсальный формат для квартир и частных домов. Баланс между глубиной, теплоотдачей и внешним видом.',
		tech: 'Глубина секции: 100 мм',
	},
	{
		title: '4-трубчатые',
		image: '/images/columns/4columns.jpg',
		description:
			'Более мощная версия для помещений с повышенными теплопотерями, высокими потолками или большой площадью.',
		tech: 'Глубина секции: 140 мм',
	},
	{
		title: '5-трубчатые',
		image: '/images/models/columns/main4b.jpg',
		description:
			'Самые мощные радиаторы в линейке. Новинка 2026 года для просторных помещений и коммерческих объектов.',
		tech: 'Новинка 2026 года',
		note: 'Технические данные появятся позже.',
	},
]
---

<section id='columns-tube-differences' class='bg-white py-12 md:py-14 xl:py-16'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={`max-w-4xl ${columnsSectionTitleClass}`}>
			Чем отличаются 2-, 3-, 4- и 5-трубчатые радиаторы
		</h2>
		<div class='mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4'>
			{items.map(item => (
				<article class='group flex h-full flex-col rounded-lg border border-neutral-200 bg-white p-4 transition hover:border-neutral-300 md:p-5'>
					<div class='h-[178px] overflow-hidden rounded-md bg-white md:h-[196px] xl:h-[184px]'>
						<img
							src={item.image}
							alt={`${item.title} радиаторы Velar`}
							title={`${item.title} радиаторы Velar`}
							loading='lazy'
							class='h-full w-full object-cover object-[50%_18%] transition duration-300 group-hover:scale-[1.03]'
						/>
					</div>
					<h3 class={`mt-4 ${columnsCardTitleClass}`}>{item.title}</h3>
					<p class={`mt-2 flex-1 line-clamp-3 ${columnsCardTextClass}`}>{item.description}</p>
					<div class='mt-4 border-t border-neutral-100 pt-3 text-sm font-semibold leading-5 text-neutral-950 md:text-sm'>{item.tech}</div>
					{item.note && <div class='mt-1 text-xs leading-5 text-neutral-500'>{item.note}</div>}
				</article>
			))}
		</div>
	</div>
</section>
