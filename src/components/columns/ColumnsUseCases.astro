---
import { columnsCardTextClass, columnsSectionTitleClass } from './columnsTypography'

const useCases = [
	['Квартиры и дома', 'Универсальный подбор по высоте, мощности и подключению.'],
	['Лофты и студии', 'Высокие вертикальные модели хорошо работают как интерьерный акцент.'],
	['Офисы и коммерческие помещения', 'Подходят для переговорных, холлов и рабочих зон.'],
	['Школы и детские сады', 'Можно подобрать понятную геометрию и надежное подключение.'],
	['Рестораны и отели', 'Цвет RAL помогает встроить радиатор в проектный интерьер.'],
	['Медицинские учреждения', 'Простая форма облегчает визуальный контроль и уход.'],
]
---

<section id='columns-use-cases' class='bg-white py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={columnsSectionTitleClass}>Где подходят трубчатые радиаторы</h2>
		<div class='mt-7 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3'>
			{useCases.map(([title, description]) => (
				<article class='rounded-2xl border border-neutral-200 bg-white p-5 transition hover:border-neutral-300 hover:bg-neutral-50'>
					<h3 class='text-base font-semibold leading-tight text-neutral-950'>{title}</h3>
					<p class={`mt-2 ${columnsCardTextClass}`}>{description}</p>
				</article>
			))}
		</div>
	</div>
</section>
