---
import { Picture } from '@astrojs/image/components'
import ColumnsFilters from './ColumnsFilters'
import type { ColumnsModelCard } from './columnsData'

type Props = {
	models: ColumnsModelCard[]
}

const { models } = Astro.props as Props

function depthByTubes(tubes: number): number {
	if (tubes === 2) return 78
	if (tubes === 3) return 110
	if (tubes === 4) return 142
	if (tubes === 5) return 174
	return 110
}
---

<section id='columns-catalog' class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<div id='model_list'></div>
		<div class='mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between'>
			<div>
				<h2 class='text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl'>Модели трубчатых радиаторов</h2>
				<p class='mt-3 max-w-2xl text-sm leading-6 text-neutral-700 md:text-base'>
					Фильтруйте линейку по количеству труб и высоте. На desktop список остается таблицей, на мобильных превращается в компактные строки.
				</p>
			</div>
			<p class='text-sm text-neutral-600'>
				Показано <span id='columns-catalog-count' class='font-medium text-neutral-900'>20 из {models.length}</span>
			</p>
		</div>

		<ColumnsFilters client:load />

		<div aria-label='Список моделей трубчатых радиаторов Velar' class='mt-5 overflow-hidden rounded-[20px] border border-neutral-200 bg-white'>
			<div class='hidden border-b border-neutral-100 bg-neutral-50 px-5 py-3 text-xs font-medium uppercase tracking-wide text-neutral-500 md:grid md:grid-cols-[minmax(0,1.45fr)_70px_100px_100px_130px_140px_110px_90px] md:gap-4'>
				<div>Модель</div>
				<div>Труб</div>
				<div>Высота, мм</div>
				<div>Глубина, мм</div>
				<div>Теплоотдача, Вт</div>
				<div>Подключение</div>
				<div>Цена от</div>
				<div>Подробнее</div>
			</div>
			{
				models.map((model, index) => (
					<article
						class='border-b border-neutral-100 bg-white px-4 py-4 transition-colors last:border-b-0 hover:bg-neutral-50 md:px-5'
						data-columns-card='1'
						data-height={String(model.height)}
						data-tubes={String(model.tubeCount)}
						data-purpose={model.purposeTags.join(',')}
						data-price={String(model.minPrice)}
						data-index={String(index)}
						style={index >= 20 ? 'display:none' : undefined}
					>
						<div class='grid grid-cols-[52px_minmax(0,1fr)] gap-3 md:hidden'>
							<Picture
								src={model.image}
								alt={`${model.prefix} Velar ${model.name}`}
								title={`${model.prefix} Velar ${model.name}`}
								loading='lazy'
								aspectRatio='1:1'
								widths={[120, 180]}
								width={120}
								sizes='52px'
								class='h-12 w-12 rounded-lg bg-neutral-50 object-contain p-1'
							/>
							<div class='min-w-0'>
								<div class='flex items-start justify-between gap-3'>
									<a href={model.href} class='text-sm font-semibold text-neutral-950 hover:text-red-700 hover:underline'>
										Velar {model.name}
									</a>
									<span class='shrink-0 text-sm font-semibold text-neutral-950'>от {model.minPrice.toLocaleString('ru-RU')} ₽</span>
								</div>
								<p class='mt-1 text-xs leading-5 text-neutral-600'>
									{model.tubeCount} труб · {model.height} мм · {depthByTubes(model.tubeCount)} мм · нижнее/боковое
								</p>
								<a href={model.href} class='mt-1 inline-flex text-xs font-medium text-red-700 hover:underline'>Подробнее →</a>
							</div>
						</div>

						<div class='hidden min-h-[58px] items-center md:grid md:grid-cols-[minmax(0,1.45fr)_70px_100px_100px_130px_140px_110px_90px] md:gap-4'>
							<div class='flex min-w-0 items-center gap-3'>
								<Picture
									src={model.image}
									alt={`${model.prefix} Velar ${model.name}`}
									title={`${model.prefix} Velar ${model.name}`}
									loading='lazy'
									aspectRatio='1:1'
									widths={[120, 180]}
									width={120}
									sizes='44px'
									class='h-11 w-11 rounded-lg bg-neutral-50 object-contain p-1'
								/>
								<div class='min-w-0'>
									<a href={model.href} class='text-sm font-semibold text-neutral-950 hover:text-red-700 hover:underline'>
										Velar {model.name}
									</a>
									<p class='mt-0.5 truncate text-xs text-neutral-500'>{model.height <= 700 ? 'низкая модель под окно' : 'высокая или универсальная модель'}</p>
								</div>
							</div>
							<div class='text-sm text-neutral-800'>{model.tubeCount}</div>
							<div class='text-sm text-neutral-800'>{model.height}</div>
							<div class='text-sm text-neutral-800'>{depthByTubes(model.tubeCount)}</div>
							<div class='text-sm text-neutral-800'>{model.powerSection} Вт/секц.</div>
							<div class='text-sm text-neutral-800'>нижнее/боковое</div>
							<div class='text-sm font-semibold text-neutral-950'>{model.minPrice.toLocaleString('ru-RU')} ₽</div>
							<a href={model.href} class='text-sm font-medium text-red-700 hover:underline'>Открыть</a>
						</div>
					</article>
				))
			}
		</div>

		<div class='mt-5 flex justify-center'>
			<button
				id='columns-show-more'
				type='button'
				class='inline-flex h-11 cursor-pointer items-center justify-center rounded-xl border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'
				style={models.length > 20 ? 'cursor:pointer' : 'display:none;cursor:pointer'}
			>
				Показать ещё
			</button>
		</div>
	</div>
</section>
