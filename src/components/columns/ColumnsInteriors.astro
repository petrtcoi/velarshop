---
const interiorImages = [
	'/images/columns/1.jpg',
	'/images/columns/2.jpg',
	'/images/columns/3.jpg',
	'/images/columns/4.jpg',
	'/images/columns/5.jpg',
	'/images/columns/6.jpg',
]
---

<section id='columns-interiors' class='bg-white py-12 md:py-16'>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>Трубчатые радиаторы Velar в интерьере</h2>
		<p class='mt-3 max-w-3xl text-sm leading-6 text-neutral-700'>
			Трубчатые модели подходят для квартир, домов и дизайнерских интерьеров. Радиатор можно сделать нейтральным элементом
			или акцентом за счёт цвета RAL.
		</p>
		<div class='mt-6 grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4'>
			{
				interiorImages.map((image, index) => (
					<div class='overflow-hidden rounded-lg bg-neutral-100'>
						<img
							src={image}
							alt={`Трубчатый радиатор Velar в интерьере ${index + 1}`}
							title={`Трубчатый радиатор Velar в интерьере ${index + 1}`}
							loading='lazy'
							class='block h-auto w-full'
						/>
					</div>
				))
			}
		</div>
	</div>
</section>
