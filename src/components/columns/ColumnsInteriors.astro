---
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

const interiors = [
	{
		title: 'Классические интерьеры',
		description: 'Для светлых комнат, молдингов, спокойной мебели и классической отделки.',
		image: '/images/columns/interiors/classic.webp',
		position: '50% 50%',
	},
	{
		title: 'Современные квартиры',
		description: 'Лаконичный белый радиатор под окно или на свободную стену без визуальной перегрузки.',
		image: '/images/columns/interiors/modern.webp',
		position: '58% 50%',
	},
	{
		title: 'Лофт и индустриальные пространства',
		description: 'Трубчатый радиатор хорошо сочетается с кирпичом, бетоном, деревом и темной мебелью.',
		image: '/images/columns/interiors/loft.webp',
		position: '56% 50%',
	},
	{
		title: 'Офисы и общественные пространства',
		description: 'Для офисов, шоурумов, холлов и проектов, где радиатор должен выглядеть аккуратно и надежно.',
		image: '/images/columns/interiors/office-ral.webp',
		position: '62% 50%',
	},
]
---

<section id='columns-interiors' class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={columnsSectionTitleClass}>Трубчатые радиаторы Velar в интерьере</h2>
		<p class={`mt-3 max-w-4xl ${columnsSectionSubtitleClass}`}>
			Трубчатый радиатор можно сделать почти незаметным в цвет стены или использовать как вертикальный акцент. Для спокойных интерьеров чаще выбирают белый, графитовый или цвет стены, для лофта и общественных пространств - черный, темный серый и контрастные RAL-цвета.
		</p>
		<div class='-mx-4 mt-7 flex gap-4 overflow-x-auto px-4 pb-2 md:mx-0 md:grid md:grid-cols-2 md:overflow-visible md:px-0 xl:grid-cols-4'>
			{interiors.map(item => (
				<article class='min-w-[270px] overflow-hidden rounded-[20px] border border-neutral-200 bg-white transition hover:border-neutral-300 md:min-w-0'>
					<img
						src={item.image}
						alt={item.title}
						title={item.title}
						width='900'
						height='675'
						loading='lazy'
						decoding='async'
						style={`object-position: ${item.position};`}
						class='h-[220px] w-full object-cover'
					/>
					<div class='p-4'>
						<h3 class='text-base font-semibold leading-tight text-neutral-950 md:text-lg'>{item.title}</h3>
						<p class='mt-2 text-sm leading-[1.5] text-neutral-600'>{item.description}</p>
					</div>
				</article>
			))}
		</div>

		<div class='mt-8 flex flex-col gap-3 rounded-2xl border border-neutral-200 bg-white p-5 md:flex-row md:items-center md:justify-between'>
			<p class='max-w-2xl text-sm leading-6 text-neutral-700 md:text-base'>
				Хотите подобрать цвет под интерьер? Отправьте фото стены или RAL-номер - подскажем, какие модели и оттенки подойдут.
			</p>
			<a href='/request' class='inline-flex h-11 shrink-0 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
				Получить расчет в цвет RAL
			</a>
		</div>
	</div>
</section>
