---
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type FilterState = {
	height?: 'all' | 'low' | 'middle' | 'high'
	tubes?: 'all' | '2' | '3' | '4'
}

type SelectorAction =
	| { label: string; href: string }
	| { label: string; filters?: FilterState; modelIds?: string[]; scrollTo?: string }

type TaskCard = {
	title: string
	description: string
	models: string[]
	primary: SelectorAction
	note?: { label: string; href: string }
}

type Chip = {
	label: string
	action: SelectorAction
}

type Props = {
	variant?: 'compact' | 'expanded'
}

const { variant = 'expanded' } = Astro.props as Props

const compactChips: Chip[] = [
	{ label: 'Под окно', action: { filters: { height: 'low' }, modelIds: ['2030', '3030', '4030', '2057', '3057', '4057'], scrollTo: 'columns-models' } },
	{ label: 'Замена батареи', action: { filters: { height: 'middle' }, modelIds: ['2057', '3057', '4057'], scrollTo: 'columns-models' } },
	{ label: 'Высокие 1800 мм', action: { filters: { height: 'high' }, modelIds: ['2180', '3180', '4180'], scrollTo: 'columns-models' } },
	{ label: 'Для квартиры', action: { modelIds: ['2057', '3057', '3030'], scrollTo: 'columns-models' } },
	{ label: 'Для частного дома', action: { modelIds: ['3057', '4057', '3180', '4180'], scrollTo: 'columns-models' } },
	{ label: '2 трубки', action: { filters: { tubes: '2' }, modelIds: ['2030', '2057', '2180'], scrollTo: 'columns-models' } },
	{ label: '3 трубки', action: { filters: { tubes: '3' }, modelIds: ['3030', '3057', '3180'], scrollTo: 'columns-models' } },
	{ label: '4 трубки', action: { filters: { tubes: '4' }, modelIds: ['4030', '4057', '4180'], scrollTo: 'columns-models' } },
	{ label: 'В цвет RAL', action: { href: '#columns-calculator' } },
]

const cards: TaskCard[] = [
	{
		title: 'Минимальная высота 300 мм',
		description: 'Самые низкие модели в линейке для ниш и низких подоконников. Под окно также часто подходят 3057 и другие модели, если позволяет высота установки.',
		models: ['2030', '3030', '4030'],
		primary: { label: 'Смотреть варианты', filters: { height: 'low' }, modelIds: ['2030', '3030', '4030'], scrollTo: 'columns-models' },
	},
	{
		title: 'Для замены старой батареи',
		description: 'Межосевое расстояние 500 мм подходит для замены стандартных алюминиевых или чугунных батарей без сложной переделки.',
		models: ['2057', '3057', '4057'],
		primary: { label: 'Смотреть варианты', filters: { height: 'middle' }, modelIds: ['2057', '3057', '4057'], scrollTo: 'columns-models' },
	},
	{
		title: 'Высокий трубчатый радиатор',
		description: 'Для узкой стены, прихожей и лофта, высота 1500-2000 мм.',
		models: ['2180', '3180', '4180'],
		primary: { label: 'Смотреть варианты', filters: { height: 'high' }, modelIds: ['2180', '3180', '4180'], scrollTo: 'columns-models' },
		note: { label: 'Вертикальные радиаторы 1800 мм', href: '/collections/verticalnye-radiatory-1800-mm' },
	},
	{
		title: 'Для квартиры',
		description: '2-3 трубки с боковым или нижним подключением.',
		models: ['2057', '3057', '3030'],
		primary: { label: 'Смотреть варианты', modelIds: ['2057', '3057', '3030'], scrollTo: 'columns-models' },
		note: { label: 'Радиаторы для квартиры', href: '/info/tube-radiators' },
	},
	{
		title: 'Для частного дома',
		description: '3-4 трубки, для больших комнат - высокие модели.',
		models: ['3057', '4057', '3180', '4180'],
		primary: { label: 'Смотреть варианты', modelIds: ['3057', '4057', '3180', '4180'], scrollTo: 'columns-models' },
	},
	{
		title: 'В цвет RAL',
		description: 'Нейтральный под цвет стены или акцентный элемент интерьера.',
		models: [],
		primary: { label: 'Подобрать по цвету', href: '#columns-calculator' },
		note: { label: 'Цвет интерьера и радиатор', href: '/info/tsvet-interera-i-radiator' },
	},
]
---

<section id={variant === 'compact' ? 'columns-task-selector-compact' : 'columns-task-selector'} class={variant === 'compact' ? 'bg-white py-8 md:py-10' : 'bg-white py-10 md:py-12'}>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		{variant === 'compact' ? (
			<>
				<h2 class={columnsSectionTitleClass}>Быстро выбрать по задаче</h2>
				<div class='mt-5 flex flex-wrap gap-2.5'>
					{compactChips.map(chip =>
						'href' in chip.action ? (
							<a
								href={chip.action.href}
								class='inline-flex min-h-10 items-center rounded-full border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-900 transition hover:border-red-300 hover:bg-red-50 hover:text-red-700'
							>
								{chip.label}
							</a>
						) : (
							<button
								type='button'
								data-columns-filters={JSON.stringify(chip.action.filters ?? {})}
								data-columns-model-ids={(chip.action.modelIds ?? []).join(',')}
								data-columns-scroll-to={chip.action.scrollTo ?? 'columns-models'}
								class='inline-flex min-h-10 cursor-pointer items-center rounded-full border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-900 transition hover:border-red-300 hover:bg-red-50 hover:text-red-700'
							>
								{chip.label}
							</button>
						),
					)}
				</div>
			</>
		) : (
			<>
				<h2 class={columnsSectionTitleClass}>Выбор трубчатого радиатора по задаче</h2>
				<p class={`mt-3 max-w-3xl ${columnsSectionSubtitleClass}`}>
					Выберите ситуацию и откройте подходящие модели без длинного поиска по всему каталогу.
				</p>

				<div class='mt-7 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3'>
					{cards.map(card => (
						<article class='flex h-full flex-col rounded-2xl border border-neutral-200 bg-white p-5 transition hover:border-neutral-300'>
							<h3 class='text-base font-semibold leading-tight text-neutral-950 md:text-lg'>{card.title}</h3>
							<p class='mt-2 flex-1 text-sm leading-[1.5] text-neutral-600'>{card.description}</p>
							{card.models.length > 0 && (
								<div class='mt-4 flex flex-wrap gap-2'>
									{card.models.map(id => (
										<a
											href={`/columns/${id}`}
											class='inline-flex h-8 min-w-[52px] items-center justify-center rounded-full border border-neutral-200 bg-white px-3 text-xs font-medium text-neutral-800 transition-colors hover:border-red-200 hover:bg-red-50 hover:text-red-700'
										>
											{id}
										</a>
									))}
								</div>
							)}
							<div class='mt-4 flex flex-wrap items-center gap-x-4 gap-y-2'>
								{'href' in card.primary ? (
									<a href={card.primary.href} class='inline-flex items-center gap-1 text-sm font-semibold text-red-700 transition hover:text-red-800'>
										{card.primary.label}
										<span aria-hidden='true'>→</span>
									</a>
								) : (
									<button
										type='button'
										data-columns-filters={JSON.stringify(card.primary.filters ?? {})}
										data-columns-model-ids={(card.primary.modelIds ?? []).join(',')}
										data-columns-scroll-to={card.primary.scrollTo ?? 'columns-models'}
										class='inline-flex cursor-pointer items-center gap-1 text-sm font-semibold text-red-700 transition hover:text-red-800'
									>
										{card.primary.label}
										<span aria-hidden='true'>→</span>
									</button>
								)}
								{card.note && (
									<a href={card.note.href} class='text-xs font-medium text-neutral-500 underline decoration-neutral-300 underline-offset-2 transition hover:text-neutral-700'>
										{card.note.label}
									</a>
								)}
							</div>
						</article>
					))}
				</div>
			</>
		)}
	</div>
</section>

<script is:inline>
	document.addEventListener('click', function (event) {
		var target = event.target
		if (!(target instanceof HTMLElement)) return
		var button = target.closest('[data-columns-filters]')
		if (!(button instanceof HTMLElement)) return

		var rawFilters = button.getAttribute('data-columns-filters') || '{}'
		var filters = {}
		try {
			filters = JSON.parse(rawFilters)
		} catch (_error) {
			filters = {}
		}
		var modelIds = (button.getAttribute('data-columns-model-ids') || '')
			.split(',')
			.map(function (value) {
				return value.trim()
			})
			.filter(Boolean)
		var scrollTo = button.getAttribute('data-columns-scroll-to') || 'columns-models'

		window.dispatchEvent(
			new CustomEvent('columns:setFilter', {
				detail: { filters: filters, modelIds: modelIds },
			}),
		)

		var modelList = document.getElementById(scrollTo)
		if (modelList) modelList.scrollIntoView({ behavior: 'smooth', block: 'start' })
	})
</script>
