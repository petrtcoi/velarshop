---
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type ArticleLink = {
	href: string
	title: string
}

type Props = {
	articles: ArticleLink[]
}

const { articles } = Astro.props as Props
---

<section id='columns-useful-articles' class='bg-white py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<div class='max-w-3xl'>
			<h2 class={columnsSectionTitleClass}>Полезные материалы о трубчатых радиаторах</h2>
			<p class={`mt-3 ${columnsSectionSubtitleClass}`}>
				Разобрали выбор, монтаж, сравнение и сценарии применения трубчатых радиаторов Velar.
			</p>
		</div>
		<ul class='mt-7 max-w-3xl divide-y divide-neutral-200 border-y border-neutral-200'>
			{articles.map(item => (
				<li>
					<a href={item.href} class='group flex gap-3 py-3.5 text-sm leading-6 text-neutral-700 transition-colors hover:text-red-700 md:text-base'>
						<span class='mt-px text-neutral-400 transition-colors group-hover:text-red-700' aria-hidden='true'>→</span>
						<span>{item.title}</span>
					</a>
				</li>
			))}
		</ul>
	</div>
</section>
