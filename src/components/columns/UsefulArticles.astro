---
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type ArticleLink = {
	href: string
	title: string
}

type ArticleGroup = {
	title: string
	items: ArticleLink[]
}

type Props = {
	groups: ArticleGroup[]
}

const { groups } = Astro.props as Props
---

<section id='columns-useful-articles' class='bg-white py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<div class='max-w-3xl'>
			<h2 class={columnsSectionTitleClass}>Полезные материалы о трубчатых радиаторах</h2>
			<p class={`mt-3 ${columnsSectionSubtitleClass}`}>
				Собрали материалы, которые помогают выбрать трубчатый радиатор, рассчитать секции, сравнить его с другими типами отопления и подготовить данные для заказа.
			</p>
		</div>
		<div class='mt-7 grid gap-4 md:grid-cols-2'>
			{groups.map(group => (
				<div class='rounded-2xl border border-neutral-200 bg-white p-5 md:p-6'>
					<h3 class='text-sm font-semibold uppercase tracking-wide text-neutral-500'>{group.title}</h3>
					<ul class='mt-3 divide-y divide-neutral-100'>
						{group.items.map(item => (
							<li>
								<a href={item.href} class='group flex gap-3 py-2.5 text-sm leading-6 text-neutral-700 transition-colors hover:text-red-700'>
									<span class='mt-px text-neutral-400 transition-colors group-hover:text-red-700' aria-hidden='true'>→</span>
									<span>{item.title}</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</div>
</section>
