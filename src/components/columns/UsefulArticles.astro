---
type ArticleLink = {
	href: string
	title: string
	description: string
}

type Props = {
	articles: ArticleLink[]
}

const { articles } = Astro.props as Props
---

<section id='columns-useful-articles' class='bg-white py-12 md:py-20'>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>Полезные материалы о трубчатых радиаторах</h2>
		<div class='mt-6 grid grid-cols-1 gap-3 md:grid-cols-2 md:gap-4 xl:grid-cols-3'>
			{
				articles.map(article => (
					<a
						href={article.href}
						class='group rounded-lg border border-neutral-200 bg-white p-4 transition-colors hover:border-neutral-300'
					>
						<div class='text-sm md:text-base font-semibold text-neutral-900'>{article.title}</div>
						<div class='mt-2 text-sm leading-6 text-neutral-600'>{article.description}</div>
						<div class='mt-3 text-sm font-medium text-red-700'>Читать →</div>
					</a>
				))
			}
		</div>
	</div>
</section>
