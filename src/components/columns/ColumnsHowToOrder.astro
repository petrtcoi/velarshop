---
import { columnsHowToSteps } from './columnsData'
import { columnsCardTextClass, columnsSectionTitleClass } from './columnsTypography'
---

<section id='columns-how-order' class='bg-white py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<div class='flex flex-col gap-4 md:flex-row md:items-end md:justify-between'>
			<h2 class={`max-w-3xl ${columnsSectionTitleClass}`}>Как заказать трубчатый радиатор</h2>
			<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
				Получить расчет
			</a>
		</div>
		<ol class='mt-7 grid gap-3 md:grid-cols-2 xl:grid-cols-3'>
			{columnsHowToSteps.map((step, index) => (
				<li class='rounded-[20px] border border-neutral-200 bg-white p-5'>
					<div class='text-sm font-semibold text-red-700'>{String(index + 1).padStart(2, '0')}</div>
					<h3 class='mt-5 text-base font-semibold leading-tight text-neutral-950'>{step.title}</h3>
					<p class={`mt-2 ${columnsCardTextClass}`}>{step.text}</p>
				</li>
			))}
		</ol>
	</div>
</section>
