---
const points = [
	'Производство под заказ',
	'Разные высоты и количество секций',
	'Покраска в цвета RAL',
	'Помощь с подбором',
	'Доставка по России',
	'Гарантия до 10 лет',
	'Работа с физлицами и юрлицами',
]
---

<section id='columns-why-velar' class='bg-white py-12 md:py-20'>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>Почему выбирают Velar для трубчатых радиаторов</h2>
		<div class='mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4'>
			{
				points.map(point => (
					<div class='rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm md:text-base text-neutral-800'>
						{point}
					</div>
				))
			}
		</div>
	</div>
</section>
