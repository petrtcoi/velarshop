---
type Props = {
	minPrice: number
}

const { minPrice } = Astro.props as Props
---

<section id='columns-hero' class='mt-3 border-b border-neutral-200 py-6 md:py-7'>
	<div class='grid gap-6 md:grid-cols-[minmax(0,1fr)_340px] md:items-stretch'>
		<div class='flex flex-col'>
			<div>
			<h1 class='text-2xl font-semibold tracking-tight text-neutral-950 md:text-3xl'>Трубчатые радиаторы Velar</h1>

			<p class='mt-2 max-w-2xl text-sm leading-6 text-neutral-700'>
				Стальные трубчатые радиаторы для квартир, домов и дизайнерских интерьеров. Подберём модель по высоте, мощности, подключению и цвету RAL.
			</p>

			<div class='mt-4 flex flex-wrap items-center gap-2'>
				<a
					href='/request'
					class='inline-flex h-9 items-center justify-center rounded-[3px] bg-red-700 px-4 text-sm font-medium text-white transition-colors hover:bg-red-800'
				>
					Получить расчет
				</a>

				<a
					href='#model_list'
					class='inline-flex h-9 items-center justify-center rounded-[3px] border border-neutral-300 bg-white px-4 text-sm font-medium text-neutral-900 transition-colors hover:border-neutral-400 hover:bg-neutral-50'
				>
					Смотреть модели
				</a>
			</div>

				<div class='mt-3 flex flex-wrap items-center gap-2 text-sm'>
					<span class='text-neutral-600'>Популярные модели:</span>
					<a href='/columns/2180' class='inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700'>2180</a>
					<a href='/columns/3030' class='inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700'>3030</a>
					<a href='/columns/3057' class='inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700'>3057</a>
					<a href='/columns/3180' class='inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700'>3180</a>
				</div>
			</div>

			<div class='mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-neutral-600 md:mt-auto'>
				<span class='inline-flex items-center gap-1.5'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' class='h-3.5 w-3.5 text-red-700' aria-hidden='true'>
						<path d='M12 3v18' />
						<path d='M17 7H9.5a2.5 2.5 0 1 0 0 5h5a2.5 2.5 0 1 1 0 5H6' />
					</svg>
					от {Math.max(minPrice, 5800).toLocaleString('ru-RU')} ₽
				</span>

				<span class='inline-flex items-center gap-1.5'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' class='h-3.5 w-3.5 text-red-700' aria-hidden='true'>
						<path d='M3 19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5a.5.5 0 0 0-.77-.42l-4.46 2.84A.5.5 0 0 1 15 10.5v-2a.5.5 0 0 0-.77-.42L9.77 10.92A.5.5 0 0 1 9 10.5V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2Z' />
						<path d='M8 16h.01' />
						<path d='M12 16h.01' />
						<path d='M16 16h.01' />
					</svg>
					под заказ
				</span>

				<span class='inline-flex items-center gap-1.5'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' class='h-3.5 w-3.5 text-red-700' aria-hidden='true'>
						<circle cx='13.5' cy='6.5' r='2.5' />
						<circle cx='17.5' cy='17.5' r='2.5' />
						<circle cx='6.5' cy='12.5' r='2.5' />
						<path d='m8.9 11.3 3.2-3.6' />
						<path d='m15 8.5 1.2 6.4' />
						<path d='m8.7 13.6 6.3 2.5' />
					</svg>
					цвета RAL
				</span>

				<span class='inline-flex items-center gap-1.5'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' class='h-3.5 w-3.5 text-red-700' aria-hidden='true'>
						<path d='M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2' />
						<path d='M15 18h-6' />
						<path d='M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14' />
						<circle cx='17' cy='18' r='2' />
						<circle cx='7' cy='18' r='2' />
					</svg>
					доставка по России
				</span>
			</div>
		</div>

		<aside class='hidden rounded-lg border border-neutral-200 bg-neutral-50 p-5 md:block'>
			<p class='text-sm font-semibold text-neutral-950'>Подберём радиатор под задачу</p>
			<p class='mt-2 text-sm leading-6 text-neutral-700'>
				Поможем выбрать высоту, количество трубок, секций, подключение и цвет RAL.
			</p>

			<ul class='mt-4 space-y-2 text-sm text-neutral-700'>
				<li class='flex gap-2'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='mt-0.5 h-4 w-4 shrink-0 text-red-700' aria-hidden='true'>
						<path d='M20 6 9 17l-5-5' />
					</svg>
					<span>под окно или в нишу</span>
				</li>
				<li class='flex gap-2'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='mt-0.5 h-4 w-4 shrink-0 text-red-700' aria-hidden='true'>
						<path d='M20 6 9 17l-5-5' />
					</svg>
					<span>для квартиры или дома</span>
				</li>
				<li class='flex gap-2'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='mt-0.5 h-4 w-4 shrink-0 text-red-700' aria-hidden='true'>
						<path d='M20 6 9 17l-5-5' />
					</svg>
					<span>по мощности помещения</span>
				</li>
				<li class='flex gap-2'>
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='mt-0.5 h-4 w-4 shrink-0 text-red-700' aria-hidden='true'>
						<path d='M20 6 9 17l-5-5' />
					</svg>
					<span>с учётом цвета и сроков</span>
				</li>
			</ul>

			<a href='/request' class='mt-4 inline-flex text-sm font-medium text-red-700 hover:underline'>
				Получить консультацию →
			</a>
		</aside>
	</div>
</section>
