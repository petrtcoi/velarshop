---
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from '../../pages/api/hero-configurator/[model].json'

const modelOptions = buildQuickConfiguratorModels({ type: 'columns' })
const defaultModelId = '3057'
let initialDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultModelId },
	} as any)
	if (response.ok) initialDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload columns configurator model:', error)
}

const statItems = [
	{ value: 'до 3000 мм', label: 'по высоте' },
	{ value: 'до 50 секций', label: 'в одном радиаторе' },
	{ value: 'до 16 атм', label: 'рабочее давление' },
	{ value: 'RAL', label: 'цвета на выбор' },
]
	---

<section id='columns-hero' class='border-b border-neutral-200 bg-white'>
		<div class='mx-auto max-w-[1240px] px-4 py-8 md:px-6 md:py-12 xl:px-8 xl:py-14'>
			<div class='grid items-center gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(220px,320px)] lg:gap-10 xl:grid-cols-[minmax(0,1fr)_minmax(220px,320px)_minmax(360px,420px)]'>
				<div class='min-w-0'>
					<h1 class='max-w-[620px] text-[36px] font-semibold leading-[0.95] tracking-tight text-neutral-950 md:text-6xl xl:text-[68px]'>
						Трубчатые радиаторы Velar
					</h1>
				<p class='mt-5 max-w-[560px] text-base leading-7 text-neutral-700 md:text-lg'>
					Стальные трубчатые радиаторы для квартир, домов и дизайнерских интерьеров. Подберем модель по высоте, мощности, подключению и цвету RAL.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row'>
					<a href='/request' class='inline-flex h-12 items-center justify-center rounded-xl bg-red-700 px-6 text-sm font-semibold text-white transition hover:bg-red-800'>
						Получить расчет
					</a>
					<a href='#model_list' class='inline-flex h-12 items-center justify-center rounded-xl border border-neutral-300 bg-white px-6 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Смотреть модели
					</a>
					</div>
					<div class='mt-7 grid grid-cols-2 gap-3 sm:grid-cols-4'>
						{statItems.map(item => (
							<div class='rounded-full border border-neutral-200 bg-white px-4 py-2.5 text-sm leading-tight text-neutral-800'>
								<span class='font-semibold text-neutral-950'>{item.value}</span>
								<span class='ml-1 text-neutral-500'>{item.label}</span>
							</div>
						))}
					</div>
				</div>

					<div class='order-2 hidden justify-center md:flex lg:order-none'>
						<img
							src='/images/models/columns/hero-black-column-radiator.png'
							alt='Черный вертикальный трубчатый радиатор Velar'
							title='Черный вертикальный трубчатый радиатор Velar'
							loading='eager'
							class='h-auto max-h-[430px] w-full max-w-[240px] bg-transparent object-contain shadow-none md:max-h-[520px] md:max-w-[300px] xl:max-h-[560px]'
						/>
					</div>

			<aside class='order-3 lg:col-span-2 xl:col-span-1'>
				<HeroQuickConfigurator
					client:load
					models={modelOptions}
					defaultModelId={defaultModelId}
						initialDetails={initialDetails}
						variant='category'
						title='Быстрый подбор'
						modelResolutionMode='family-by-height'
						category='tubular'
					/>
				</aside>
		</div>
	</div>
</section>
