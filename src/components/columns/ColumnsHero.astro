---
import ColumnsQuickConfigurator from "./ColumnsQuickConfigurator";
import type { ColumnsModelCard } from "./columnsData";

type Props = {
  minPrice: number;
  models: ColumnsModelCard[];
};

const { minPrice, models } = Astro.props as Props;
---

<section
  id="columns-hero"
  class="mt-3 border-b border-neutral-200 py-6 md:py-7"
>
  <div
    class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_480px] lg:items-stretch xl:grid-cols-[minmax(0,1fr)_520px]"
  >
    <div class="flex min-h-full flex-col">
      <div>
        <h1
          class="text-2xl font-semibold tracking-tight text-neutral-950 md:text-3xl"
        >
          Трубчатые радиаторы Velar
        </h1>

        <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-700">
          Стальные трубчатые радиаторы Velar — решение для квартир, частных домов и дизайнерских интерьеров, где важны не только тепло, но и внешний вид. Доступны разные высоты, количество трубок в секции, варианты подключения и окраска в цвета RAL. Мы поможем подобрать модель по мощности помещения, месту установки и нужной конфигурации.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-8">
          <a
            href="/request"
            class="inline-flex h-10 items-center justify-center rounded-[3px] border border-red-700 bg-white px-5 text-sm font-medium text-red-700 transition-colors hover:bg-red-50"
          >
            Получить расчет
          </a>

          <a
            href="#model_list"
            class="inline-flex items-center text-sm font-medium text-neutral-700 transition-colors hover:text-red-700 hover:underline"
          >
            Все модели →
          </a>
        </div>

        <!-- Bestsellers -->
        <div class="mt-8 flex md:flex-row flex-wrap justify-start items-center gap-2 text-sm">
          <div class="text-neutral-600">Популярные модели:</div>
          <div class="flex flex-wrap justify-start items-center gap-2 text-sm">
          <a
            href="/columns/2180"
            class="inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700"
            >2180</a
          >
          <a
            href="/columns/3030"
            class="inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700"
            >3030</a
          >
          <a
            href="/columns/3057"
            class="inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700"
            >3057</a
          >
          <a
            href="/columns/3180"
            class="inline-flex h-7 cursor-pointer items-center rounded-[3px] border border-neutral-200 bg-white px-2.5 text-xs font-medium text-neutral-900 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-700"
            >3180</a
          >
          </div>
        </div>
      </div>

      <!-- Features -->
      <div
        class="mt-6 grid max-w-xl grid-cols-2 gap-3  text-neutral-700 lg:mt-auto"
      >
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-banknote-icon lucide-banknote"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
          <span class="text-sm md:text-md font-thin"
            >Цена от {minPrice.toLocaleString("ru-RU")} ₽</span
          >
        </div>
        <div class="flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
               stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-12 w-12 text-neutral-900"
            aria-hidden="true"
          >
            <path
              d="M3 19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5a.5.5 0 0 0-.77-.42l-4.46 2.84A.5.5 0 0 1 15 10.5v-2a.5.5 0 0 0-.77-.42L9.77 10.92A.5.5 0 0 1 9 10.5V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2Z"
            ></path>
            <path d="M8 16h.01"></path>
            <path d="M12 16h.01"></path>
            <path d="M16 16h.01"></path>
          </svg>
          <span class="text-sm md:text-md font-thin">Под заказ и в наличии</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette-icon lucide-palette"><path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"/><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/></svg>
          <span class="text-sm md:text-md font-thin">Покраска в цвета RAL</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck-icon lucide-truck"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          <span class="text-sm md:text-md font-thin">Доставка по России</span>
        </div>
      </div>
    </div>

    <aside>
      <ColumnsQuickConfigurator models={models} client:load />
    </aside>
  </div>
</section>
