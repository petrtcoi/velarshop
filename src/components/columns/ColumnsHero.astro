---
import ColumnsQuickConfigurator from "./ColumnsQuickConfigurator";
import type { ColumnsModelCard } from "./columnsData";

type Props = {
  minPrice: number;
  models: ColumnsModelCard[];
};

const { minPrice: _minPrice, models } = Astro.props as Props;
---

<section
  id="columns-hero"
  class="mt-3 border-b border-neutral-200 py-6 md:py-7"
>
  <div
    class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_480px] lg:items-stretch xl:grid-cols-[minmax(0,1fr)_520px]"
  >
    <div class="flex min-h-full flex-col">
      <div>
        <h1
          class="text-2xl font-semibold tracking-tight text-neutral-950 md:text-3xl"
        >
          Трубчатые радиаторы Velar
        </h1>

        <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-700">
          Стальные трубчатые радиаторы Velar для квартир, домов и дизайнерских
          интерьеров. Подберем модель по высоте, мощности, подключению и цвету
          RAL.
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-4">
          <a
            href="/request"
            class="inline-flex h-10 items-center justify-center rounded-[3px] border border-red-700 bg-white px-5 text-sm font-medium text-red-700 transition-colors hover:bg-red-50"
          >
            Получить расчет
          </a>

          <a
            href="#model_list"
            class="inline-flex items-center text-sm font-medium text-neutral-700 transition-colors hover:text-red-700 hover:underline"
          >
            Смотреть модели →
          </a>
        </div>

        <div class="mt-5">
          <p
            class="text-xs font-medium uppercase tracking-wide text-neutral-600"
          >
            Популярные модели
          </p>
          <div class="mt-2 grid gap-2 sm:grid-cols-2">
            <a
              href="/columns/2180"
              class="group rounded-[3px] border border-neutral-200 bg-white p-3 transition-colors hover:border-neutral-300 hover:bg-neutral-50"
            >
              <p class="text-sm font-semibold text-neutral-900">Velar 2180</p>
              <p class="mt-1 text-xs text-neutral-600">
                вертикальный радиатор 1800 мм
              </p>
              <span
                class="mt-2 inline-flex text-xs font-medium text-neutral-700 transition-colors group-hover:text-red-700"
              >
                Перейти →
              </span>
            </a>

            <a
              href="/columns/3030"
              class="group rounded-[3px] border border-neutral-200 bg-white p-3 transition-colors hover:border-neutral-300 hover:bg-neutral-50"
            >
              <p class="text-sm font-semibold text-neutral-900">Velar 3030</p>
              <p class="mt-1 text-xs text-neutral-600">
                низкий радиатор под окно
              </p>
              <span
                class="mt-2 inline-flex text-xs font-medium text-neutral-700 transition-colors group-hover:text-red-700"
              >
                Перейти →
              </span>
            </a>

            <a
              href="/columns/3057"
              class="group rounded-[3px] border border-neutral-200 bg-white p-3 transition-colors hover:border-neutral-300 hover:bg-neutral-50"
            >
              <p class="text-sm font-semibold text-neutral-900">Velar 3057</p>
              <p class="mt-1 text-xs text-neutral-600">
                универсальная модель 570 мм
              </p>
              <span
                class="mt-2 inline-flex text-xs font-medium text-neutral-700 transition-colors group-hover:text-red-700"
              >
                Перейти →
              </span>
            </a>

            <a
              href="/columns/3180"
              class="group rounded-[3px] border border-neutral-200 bg-white p-3 transition-colors hover:border-neutral-300 hover:bg-neutral-50"
            >
              <p class="text-sm font-semibold text-neutral-900">Velar 3180</p>
              <p class="mt-1 text-xs text-neutral-600">
                высокий 3-трубчатый радиатор
              </p>
              <span
                class="mt-2 inline-flex text-xs font-medium text-neutral-700 transition-colors group-hover:text-red-700"
              >
                Перейти →
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="mt-4 border-t border-neutral-200 pt-3 md:mt-auto">
        <div class="hidden md:grid md:grid-cols-4">
          <div class="flex items-center gap-2 py-1 text-neutral-950">
            <span
              class="inline-flex h-6 w-6 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 16h.01"></path><path d="M16 16h.01"></path><path
                  d="M3 19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5a.5.5 0 0 0-.77-.42l-4.46 2.84a.5.5 0 0 1-.77-.42v-2a.5.5 0 0 0-.77-.42L9.77 10.92A.5.5 0 0 1 9 10.5V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"
                ></path><path d="M8 16h.01"></path></svg
              >
            </span>
            <span class="text-sm leading-5">Производство под заказ</span>
          </div>
          <div
            class="flex items-center gap-2 border-l border-neutral-300 pl-4 py-1 text-neutral-950"
          >
            <span
              class="inline-flex h-6 w-6 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"
                ></path><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"
                ></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"
                ></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"
                ></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"
                ></circle></svg
              >
            </span>
            <span class="text-sm leading-5">Цвета RAL</span>
          </div>
          <div
            class="flex items-center gap-2 border-l border-neutral-300 pl-4 py-1 text-neutral-950"
          >
            <span
              class="inline-flex h-6 w-6 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                ></path></svg
              >
            </span>
            <span class="text-sm leading-5">Гарантия до 10 лет</span>
          </div>
          <div
            class="flex items-center gap-2 border-l border-neutral-300 pl-4 py-1 text-neutral-950"
          >
            <span
              class="inline-flex h-6 w-6 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"
                ></path><path d="M15 18H9"></path><path
                  d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"
                ></path><circle cx="17" cy="18" r="2"></circle><circle
                  cx="7"
                  cy="18"
                  r="2"></circle></svg
              >
            </span>
            <span class="text-sm leading-5">Доставка по России</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2 text-neutral-950 md:hidden">
          <div class="flex items-center gap-2 py-1">
            <span
              class="inline-flex h-5 w-5 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 16h.01"></path><path d="M16 16h.01"></path><path
                  d="M3 19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5a.5.5 0 0 0-.77-.42l-4.46 2.84a.5.5 0 0 1-.77-.42v-2a.5.5 0 0 0-.77-.42L9.77 10.92A.5.5 0 0 1 9 10.5V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"
                ></path><path d="M8 16h.01"></path></svg
              >
            </span>
            <span class="text-sm leading-5">Под заказ</span>
          </div>
          <div class="flex items-center gap-2 py-1">
            <span
              class="inline-flex h-5 w-5 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"
                ></path><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"
                ></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"
                ></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"
                ></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"
                ></circle></svg
              >
            </span>
            <span class="text-sm leading-5">Цвета RAL</span>
          </div>
          <div class="flex items-center gap-2 py-1">
            <span
              class="inline-flex h-5 w-5 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                ></path></svg
              >
            </span>
            <span class="text-sm leading-5">Гарантия 10 лет</span>
          </div>
          <div class="flex items-center gap-2 py-1">
            <span
              class="inline-flex h-5 w-5 items-center justify-center"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"
                ></path><path d="M15 18H9"></path><path
                  d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"
                ></path><circle cx="17" cy="18" r="2"></circle><circle
                  cx="7"
                  cy="18"
                  r="2"></circle></svg
              >
            </span>
            <span class="text-sm leading-5">Доставка по России</span>
          </div>
        </div>
      </div>
    </div>

    <aside>
      <ColumnsQuickConfigurator models={models} client:load />
    </aside>
  </div>
</section>
