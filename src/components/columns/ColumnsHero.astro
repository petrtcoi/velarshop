---
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from '../../pages/api/hero-configurator/[model].json'

const modelOptions = buildQuickConfiguratorModels({ type: 'columns' })
const defaultModelId = '3057'
let initialDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultModelId },
	} as any)
	if (response.ok) initialDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload columns configurator model:', error)
}

const statItems = [
	{
		text: 'Высота до 2 м',
		icon: '<path d="M21.3 15.3 15 21.6 2.4 9 8.7 2.7z"></path><path d="m14.5 4.5-2 2"></path><path d="m11.5 7.5-2 2"></path><path d="m8.5 10.5-2 2"></path>',
	},
	{
		text: 'Рабочее давление до 16 атм',
		icon: '<path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path>',
	},
	{
		text: 'До 50 секций',
		icon: '<path d="m12 2 8 4-8 4-8-4 8-4Z"></path><path d="m4 10 8 4 8-4"></path><path d="m4 14 8 4 8-4"></path>',
	},
]
	---

<section id='columns-hero' class='border-b border-neutral-200 bg-white'>
	<div class='mx-auto max-w-[1240px] px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 xl:px-8 xl:py-12'>
		<div class='grid gap-7 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:gap-8 min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(220px,320px)_minmax(360px,420px)] min-[1250px]:items-center min-[1250px]:gap-10'>
			<div class='min-w-0'>
				<h1 class='max-w-[620px] text-[34px] font-medium leading-[1.04] tracking-tight text-neutral-950 md:text-[38px] xl:text-[56px]'>
					Трубчатые радиаторы Velar
				</h1>
				<p class='mt-5 max-w-[560px] text-[15px] leading-6 text-neutral-700 md:text-base md:leading-7'>
					Стальные трубчатые радиаторы для квартир, домов и дизайнерских интерьеров. Подберем модель по высоте, мощности, подключению и цвету RAL.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
						Получить расчет
					</a>
					<a href='#model_list' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Смотреть модели
					</a>
					</div>
					<div class='mt-7 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] leading-tight text-neutral-700 md:text-sm'>
						{statItems.map(item => (
							<div class='inline-flex items-center gap-2.5'>
								<span class='inline-flex h-5 w-5 shrink-0 items-center justify-center text-red-700' aria-hidden='true'>
									<svg
										xmlns='http://www.w3.org/2000/svg'
										viewBox='0 0 24 24'
										fill='none'
										stroke='currentColor'
										stroke-width='1.5'
										stroke-linecap='round'
										stroke-linejoin='round'
										class='h-5 w-5'
										set:html={item.icon}
									/>
								</span>
								<span>{item.text}</span>
							</div>
						))}
					</div>
			</div>

			<div class='hidden justify-center min-[1250px]:flex min-[1250px]:items-center'>
				<img
					src='/images/models/columns/hero-black-column-radiator.png'
					alt='Черный вертикальный трубчатый радиатор Velar'
					title='Черный вертикальный трубчатый радиатор Velar'
					loading='eager'
					class='h-auto max-h-[560px] w-full max-w-[300px] bg-transparent object-contain shadow-none'
				/>
			</div>

			<div class='grid min-w-0 gap-5 sm:grid-cols-[150px_minmax(0,1fr)] sm:items-start md:grid-cols-[180px_minmax(0,1fr)] min-[900px]:col-start-2 min-[900px]:block min-[1250px]:col-start-3'>
				<div class='hidden justify-center sm:flex min-[900px]:hidden'>
					<img
						src='/images/models/columns/hero-black-column-radiator.png'
						alt='Черный вертикальный трубчатый радиатор Velar'
						title='Черный вертикальный трубчатый радиатор Velar'
						loading='lazy'
						class='h-auto max-h-[430px] w-full max-w-[180px] bg-transparent object-contain shadow-none'
					/>
				</div>

				<aside class='min-w-0'>
					<HeroQuickConfigurator
						client:load
						models={modelOptions}
						defaultModelId={defaultModelId}
						initialDetails={initialDetails}
						variant='category'
						title='Быстрый подбор'
						modelResolutionMode='family-by-height'
						category='tubular'
					/>
				</aside>
			</div>
		</div>
	</div>
</section>
