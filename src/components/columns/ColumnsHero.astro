---
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from '../../pages/api/hero-configurator/[model].json'

const modelOptions = buildQuickConfiguratorModels({ type: 'columns' })
const defaultModelId = '3057'
let initialDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultModelId },
	} as any)
	if (response.ok) initialDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload columns configurator model:', error)
}

const statItems = [
	{
		text: 'Высота до 2 м',
		icon: '<path d="M21.3 15.3 15 21.6 2.4 9 8.7 2.7z"></path><path d="m14.5 4.5-2 2"></path><path d="m11.5 7.5-2 2"></path><path d="m8.5 10.5-2 2"></path>',
	},
	{
		text: 'Рабочее давление до 16 атм',
		icon: '<path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path>',
	},
	{
		text: 'До 50 секций',
		icon: '<path d="m12 2 8 4-8 4-8-4 8-4Z"></path><path d="m4 10 8 4 8-4"></path><path d="m4 14 8 4 8-4"></path>',
	},
	{
		text: 'Цвета RAL',
		icon: '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle><path d="M12 2a10 10 0 1 0 0 20 1.6 1.6 0 0 0 1.2-2.7 1.6 1.6 0 0 1 1.2-2.7H17a5 5 0 0 0 5-5 10 10 0 0 0-10-9.6Z"></path>',
	},
	{
		text: 'Доставка по России',
		icon: '<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle>',
	},
]
---

<section id='columns-hero' class='border-b border-neutral-200 bg-white'>
	<div class='mx-auto max-w-[1240px] px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 xl:px-8 xl:py-12'>
		<div class='grid gap-7 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:items-start min-[900px]:gap-8 min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(220px,320px)_minmax(360px,420px)] min-[1250px]:gap-10'>
			<div class='min-w-0'>
				<h1 class='max-w-[620px] text-[34px] font-medium leading-[1.04] tracking-tight text-neutral-950 md:text-[38px] xl:text-[56px]'>
					Трубчатые радиаторы Velar
				</h1>
				<p class='mt-5 max-w-[560px] text-sm leading-6 text-neutral-700 md:text-base md:leading-7'>
					Трубчатые радиаторы Velar - стальные секционные радиаторы для квартир, домов и дизайн-проектов. Подберем модель по высоте, количеству труб, секциям, подключению и цвету RAL: под окно, для замены старой батареи или как высокий радиатор на узкую стену. Выберите модель ниже или отправьте параметры помещения - менеджер рассчитает мощность, стоимость, оплату и доставку по России.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row min-[420px]:flex-wrap'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
						Получить расчет
					</a>
					<a href='#columns-models' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Смотреть модели
					</a>
					<a href='#columns-calculator' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Подобрать по параметрам
					</a>
				</div>
				<div class='mt-7 flex flex-wrap items-center gap-x-7 gap-y-3 text-[13px] leading-tight text-neutral-700 md:text-sm'>
					{statItems.map(item => (
						<div class='inline-flex items-center gap-2.5'>
							<span class='inline-flex h-5 w-5 shrink-0 items-center justify-center text-red-700' aria-hidden='true'>
								<svg
									xmlns='http://www.w3.org/2000/svg'
									viewBox='0 0 24 24'
									fill='none'
									stroke='currentColor'
									stroke-width='1.5'
									stroke-linecap='round'
									stroke-linejoin='round'
									class='h-5 w-5'
									set:html={item.icon}
								/>
							</span>
							<span>{item.text}</span>
						</div>
					))}
				</div>
			</div>

			<div class='hidden flex-col items-center justify-center min-[1250px]:flex'>
				<img
					src='/images/models/columns/hero-black-column-radiator.png'
					alt='Черный вертикальный трубчатый радиатор Velar'
					title='Черный вертикальный трубчатый радиатор Velar'
					loading='eager'
					class='h-auto max-h-[700px] w-full max-w-[380px] bg-transparent object-contain shadow-none'
				/>
				<p class='mt-3 text-center text-xs font-medium text-neutral-500'>Высота от 300 до 2000 мм</p>
			</div>

			<div class='grid min-w-0 gap-5 sm:grid-cols-[190px_minmax(0,1fr)] sm:items-start md:grid-cols-[220px_minmax(0,1fr)] min-[900px]:col-start-2 min-[900px]:block min-[1250px]:col-start-3'>
				<div class='flex flex-col items-center justify-center min-[900px]:hidden'>
					<img
						src='/images/models/columns/hero-black-column-radiator.png'
						alt='Черный вертикальный трубчатый радиатор Velar'
						title='Черный вертикальный трубчатый радиатор Velar'
						loading='lazy'
						class='h-auto max-h-[440px] w-full max-w-[210px] bg-transparent object-contain shadow-none sm:max-h-[540px] sm:max-w-[230px]'
					/>
					<p class='mt-2 text-center text-xs font-medium text-neutral-500'>Высота от 300 до 2000 мм</p>
				</div>

				<aside class='min-w-0'>
					<details id='columns-configurator-collapse' open class='columns-configurator-collapse'>
						<summary class='mb-3 flex cursor-pointer list-none items-center justify-between gap-3 rounded-[18px] border border-neutral-200 bg-white px-4 py-3 text-sm font-semibold text-neutral-950 transition hover:border-neutral-300 min-[900px]:hidden [&::-webkit-details-marker]:hidden'>
							<span>Быстрый расчет по параметрам</span>
							<span class='inline-flex h-9 items-center justify-center rounded-lg bg-red-700 px-3.5 text-xs font-semibold text-white'>Открыть подбор</span>
						</summary>
						<div>
							<HeroQuickConfigurator
								client:load
								models={modelOptions}
								defaultModelId={defaultModelId}
								initialDetails={initialDetails}
								variant='category'
								title='Быстрый подбор'
								modelResolutionMode='family-by-height'
								category='tubular'
								addToCartLabel='Добавить в запрос'
								goToCartLabel='Перейти к запросу'
								cartPillLabel='Запрос'
								cartHref='/request'
							/>
							<p class='mt-2.5 text-[12px] leading-[1.45] text-neutral-500 md:text-[13px]'>
								Добавьте вариант в запрос - менеджер проверит мощность, подключение, наличие или срок производства и рассчитает итоговую стоимость с доставкой.
							</p>
						</div>
					</details>
				</aside>
			</div>
		</div>
	</div>

	<script is:inline>
		;(function () {
			var details = document.getElementById('columns-configurator-collapse')
			if (!details) return
			var mq = window.matchMedia('(min-width: 900px)')
			var apply = function () {
				details.open = mq.matches
			}
			apply()
			mq.addEventListener('change', apply)
		})()
	</script>
</section>
