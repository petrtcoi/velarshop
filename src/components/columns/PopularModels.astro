---
import { Picture } from '@astrojs/image/components'
import type { ColumnsModelCard } from './columnsData'

type Props = {
	models: ColumnsModelCard[]
}

const { models } = Astro.props as Props

function getPopularPurpose(model: ColumnsModelCard): string {
	if (model.height <= 500) return 'Для установки под окно и в помещениях с невысокими подоконниками.'
	if (model.height >= 1200) return 'Для высоких помещений, ниш и вертикальных акцентов в интерьере.'
	return 'Универсальный вариант для квартиры и частного дома.'
}
---

<section id='popular-columns-models' class='bg-white py-12 md:py-20'>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>Популярные модели трубчатых радиаторов</h2>
		<p class='mt-3 text-sm md:text-base leading-7 text-neutral-700'>
			Чаще всего выбирают для квартир, частных домов и проектов с индивидуальными требованиями к высоте и мощности.
		</p>
		<div class='mt-6 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 md:gap-6'>
			{
				models.map(model => (
					<article class='rounded-2xl border border-neutral-200 bg-white p-4 flex flex-col'>
						<Picture
							src={model.image}
							alt={`${model.prefix} Velar ${model.name}`}
							title={`${model.prefix} Velar ${model.name}`}
							loading='lazy'
							aspectRatio='1:1'
							widths={[300, 500]}
							width={300}
							sizes='(max-width: 768px) 100vw, 25vw'
							class='w-full aspect-square rounded-xl object-contain bg-neutral-50 p-4'
						/>
						<h3 class='mt-4 text-base font-semibold text-neutral-900'>Velar {model.name}</h3>
						<p class='mt-2 text-sm leading-6 text-neutral-600'>{getPopularPurpose(model)}</p>
						<div class='mt-3 space-y-1 text-sm text-neutral-800'>
							<div><strong>Высота:</strong> {model.height} мм</div>
							<div><strong>Тип:</strong> {model.tubeCount}-трубчатый</div>
							<div><strong>Мощность секции:</strong> {model.powerSection} Вт</div>
							<div><strong>Цена от:</strong> {model.minPrice.toLocaleString('ru-RU')} руб.</div>
						</div>
						<div class='mt-auto pt-4 grid grid-cols-2 gap-2'>
							<a
								href={model.href}
								class='inline-flex h-10 items-center justify-center rounded-[3px] border border-neutral-300 bg-white px-3 text-sm font-semibold text-neutral-900 hover:border-neutral-400'
							>
								Подробнее
							</a>
							<a
								href='/request'
								class='inline-flex h-10 items-center justify-center rounded-[3px] border border-red-700 bg-red-700 px-3 text-sm font-semibold text-white hover:bg-red-800 hover:border-red-800'
							>
								Получить расчет
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
