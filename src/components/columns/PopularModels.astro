---
import Picture from '@shared/components/Picture.astro';
import type { ColumnsModelCard } from './columnsData'
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type Props = {
	models: ColumnsModelCard[]
}

const { models } = Astro.props as Props
const modelOrder = ['3030', '3057', '2180', '3180']
const orderedModels = modelOrder
	.map(id => models.find(model => model.id === id))
	.filter((model): model is ColumnsModelCard => Boolean(model))
const visibleModels = orderedModels.length === modelOrder.length ? orderedModels : models

const whenToChoose: Record<string, string> = {
	'3030': 'Когда выбрать: низкий трубчатый радиатор под окно, в нишу или под ограниченную высоту.',
	'3057': 'Когда выбрать: универсальная замена стандартной батареи в квартире или доме.',
	'2180': 'Когда выбрать: высокий и относительно неглубокий радиатор для узкой стены, прихожей, лофта или простенка.',
	'3180': 'Когда выбрать: высокий радиатор с большей теплоотдачей, чем у 2-трубчатой версии.',
}
---

<section id='columns-popular' class='bg-white py-8 md:py-10'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={columnsSectionTitleClass}>Популярные модели трубчатых радиаторов</h2>
		<p class={`mt-3 max-w-3xl ${columnsSectionSubtitleClass}`}>
			Самые частые варианты для подбора: низкие модели под окно, стандартные модели для замены батареи и высокие радиаторы для узкой стены.
		</p>
		<div class='mt-6 grid grid-cols-1 gap-4 md:grid-cols-2'>
			{
				visibleModels.map(model => (
					<article class='flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white transition hover:border-neutral-300 sm:min-h-[190px] sm:flex-row'>
						<div class='flex shrink-0 items-center justify-center bg-neutral-50 p-4 sm:w-[35%] sm:p-4'>
							<Picture
								src={model.image}
								alt={`${model.prefix} Velar ${model.name}`}
								title={`${model.prefix} Velar ${model.name}`}
								loading='lazy'
								widths={[160, 240]}
								width={160}
								sizes='(max-width: 640px) 130px, 200px'
								class='h-[124px] w-auto object-contain sm:h-[138px] md:h-[148px]'
							/>
						</div>
						<div class='flex flex-1 flex-col p-4 sm:p-5'>
							<h3 class='text-base font-semibold leading-5 text-neutral-950'>Velar {model.name}</h3>
							<p class='mt-2 text-[13px] leading-[1.4] text-neutral-600'>
								{model.tubeCount} трубки · высота {model.height} мм · {model.sectionsMin}-{model.sectionsMax} секций
							</p>
							<p class='mt-1.5 text-base font-semibold leading-5 text-neutral-950'>от {model.minPrice.toLocaleString('ru-RU')} ₽</p>
							<p class='mt-2.5 flex-1 text-[13px] leading-[1.45] text-neutral-600'>
								{whenToChoose[model.id]}
							</p>
							<div class='mt-4 flex flex-wrap items-center gap-2'>
								<a
									href={`/request?model=${encodeURIComponent(`Velar ${model.name}`)}`}
									class='inline-flex h-10 items-center justify-center rounded-lg border border-red-700 bg-transparent px-4 text-xs font-semibold text-red-700 transition hover:bg-red-50'
								>
									Добавить в запрос
								</a>
								<a
									href={model.href}
									class='inline-flex h-10 items-center justify-center px-2 text-xs font-medium text-neutral-700 transition hover:text-red-700 hover:underline'
								>
									Подробнее
								</a>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
