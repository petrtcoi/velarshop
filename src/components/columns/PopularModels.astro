---
import { Picture } from '@astrojs/image/components'
import type { ColumnsModelCard } from './columnsData'
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type Props = {
	models: ColumnsModelCard[]
}

const { models } = Astro.props as Props
---

<section id='popular-columns-models' class='bg-white py-8 md:py-10'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={columnsSectionTitleClass}>Популярные модели трубчатых радиаторов</h2>
		<p class={`mt-3 max-w-3xl ${columnsSectionSubtitleClass}`}>
			Быстрые ссылки на основные модели Velar: низкие, стандартные и высокие трубчатые радиаторы.
		</p>
		<div class='-mx-4 mt-6 flex gap-3 overflow-x-auto px-4 pb-1 md:mx-0 md:grid md:grid-cols-2 md:gap-4 md:overflow-visible md:px-0 xl:grid-cols-4'>
			{
				models.map(model => (
					<a
						href={model.href}
						class='group flex min-h-[116px] min-w-[248px] items-center gap-3 rounded-[16px] border border-neutral-200 bg-white p-3 transition hover:border-neutral-300 hover:bg-neutral-50 md:min-w-0'
					>
						<Picture
							src={model.image}
							alt={`${model.prefix} Velar ${model.name}`}
							title={`${model.prefix} Velar ${model.name}`}
							loading='lazy'
							aspectRatio='1:1'
							widths={[120, 180]}
							width={120}
							sizes='56px'
							class='h-14 w-14 shrink-0 rounded-lg bg-neutral-50 object-contain p-1.5'
						/>
						<div class='min-w-0'>
							<h3 class='text-[15px] font-semibold leading-5 text-neutral-950 md:text-base'>Velar {model.name}</h3>
							<p class='mt-1 truncate text-[13px] leading-5 text-neutral-600'>
								{model.tubeCount} трубки · высота {model.height} мм · {model.sectionsMin}-{model.sectionsMax} секций
							</p>
							<div class='mt-2 inline-flex items-center gap-1 text-[14px] font-semibold leading-5 text-neutral-950'>
								<span>от {model.minPrice.toLocaleString('ru-RU')} ₽</span>
								<span class='text-red-700 transition-transform group-hover:translate-x-0.5'>→</span>
							</div>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>
