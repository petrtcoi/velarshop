---
import { Picture } from '@astrojs/image/components'
import type { ColumnsModelCard } from './columnsData'
import { columnsSectionSubtitleClass, columnsSectionTitleClass } from './columnsTypography'

type Props = {
	models: ColumnsModelCard[]
}

const { models } = Astro.props as Props
const modelOrder = ['3030', '3057', '2180', '3180']
const orderedModels = modelOrder
	.map(id => models.find(model => model.id === id))
	.filter((model): model is ColumnsModelCard => Boolean(model))
const visibleModels = orderedModels.length === modelOrder.length ? orderedModels : models
---

<section id='popular-columns-models' class='bg-white py-8 md:py-10'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={columnsSectionTitleClass}>Популярные модели трубчатых радиаторов</h2>
		<p class={`mt-3 max-w-3xl ${columnsSectionSubtitleClass}`}>
			Быстрые ссылки на основные модели Velar: низкие, стандартные и высокие трубчатые радиаторы.
		</p>
		<div class='mt-6 grid grid-cols-2 gap-3 md:gap-4 xl:grid-cols-4'>
			{
				visibleModels.map(model => (
					<a
						href={model.href}
						class='group flex min-h-[116px] items-start gap-2.5 rounded-[16px] border border-neutral-200 bg-white p-3 transition hover:border-neutral-300 hover:bg-neutral-50 md:gap-3 md:p-3.5'
					>
						<Picture
							src={model.image}
							alt={`${model.prefix} Velar ${model.name}`}
							title={`${model.prefix} Velar ${model.name}`}
							loading='lazy'
							aspectRatio='1:1'
							widths={[120, 180]}
							width={120}
							sizes='(max-width: 768px) 48px, 56px'
							class='h-12 w-12 shrink-0 rounded-lg bg-neutral-50 object-contain p-1.5 md:h-14 md:w-14'
						/>
						<div class='min-w-0 flex-1'>
							<h3 class='text-[14px] font-semibold leading-5 text-neutral-950 md:text-[15px]'>Velar {model.name}</h3>
							<p class='mt-1 text-[12px] leading-[1.35] text-neutral-600 md:text-[13px]'>
								{model.tubeCount} трубки · высота {model.height} мм
							</p>
							<p class='text-[12px] leading-[1.35] text-neutral-600 md:text-[13px]'>{model.sectionsMin}-{model.sectionsMax} секций</p>
							<p class='mt-2 text-[14px] font-semibold leading-5 text-neutral-950'>от {model.minPrice.toLocaleString('ru-RU')} ₽</p>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>
