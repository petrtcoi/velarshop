---
import { columnsSectionTitleClass } from './columnsTypography'

const rows = [
	{
		type: 'Трубчатые',
		pros: 'Гибкий выбор размеров, аккуратный вид, подходят для современных интерьеров.',
		cons: 'Обычно дороже базовых панельных решений.',
		when: 'Если важны дизайн, вариативность и подбор под проект.',
	},
	{
		type: 'Панельные',
		pros: 'Доступная цена, быстрый монтаж, хорошая теплоотдача.',
		cons: 'Меньше вариантов по геометрии и дизайну.',
		when: 'Для типовых помещений и ограниченного бюджета.',
	},
	{
		type: 'Чугунные',
		pros: 'Высокая инерционность и устойчивость к качеству теплоносителя.',
		cons: 'Большой вес и более сложный монтаж.',
		when: 'Для классических интерьеров и систем с перепадами параметров.',
	},
	{
		type: 'Дизайн-радиаторы',
		pros: 'Максимальный выбор форм и интерьерных решений.',
		cons: 'Требуют точного подбора под задачу и проект.',
		when: 'Если радиатор должен быть частью визуальной концепции.',
	},
]
---

<section id='columns-comparison' class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class={`max-w-4xl ${columnsSectionTitleClass}`}>
			Трубчатые, панельные, чугунные и дизайн-радиаторы: что выбрать
		</h2>
		<div class='mt-7 hidden overflow-hidden rounded-2xl border border-neutral-200 bg-white md:block'>
			<table class='w-full min-w-[760px] border-collapse'>
				<thead class='bg-neutral-50'>
					<tr>
						<th class='px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-neutral-500'>Тип радиатора</th>
						<th class='px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-neutral-500'>Плюсы</th>
						<th class='px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-neutral-500'>Минусы</th>
						<th class='px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-neutral-500'>Когда выбрать</th>
					</tr>
				</thead>
				<tbody>
					{
						rows.map(row => (
							<tr class='border-t border-neutral-200'>
								<td class='px-4 py-3 text-sm font-semibold text-neutral-900'>{row.type}</td>
								<td class='px-4 py-3 text-sm leading-6 text-neutral-700'>{row.pros}</td>
								<td class='px-4 py-3 text-sm leading-6 text-neutral-700'>{row.cons}</td>
								<td class='px-4 py-3 text-sm leading-6 text-neutral-700'>{row.when}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
		<div class='mt-6 grid gap-3 md:hidden'>
			{rows.map(row => (
				<article class='rounded-[20px] border border-neutral-200 bg-white p-4'>
					<h3 class='text-base font-semibold text-neutral-950'>{row.type}</h3>
					<p class='mt-3 text-sm leading-6 text-neutral-700'><span class='font-medium text-neutral-950'>Плюсы: </span>{row.pros}</p>
					<p class='mt-2 text-sm leading-6 text-neutral-700'><span class='font-medium text-neutral-950'>Когда выбрать: </span>{row.when}</p>
				</article>
			))}
		</div>
	</div>
</section>
