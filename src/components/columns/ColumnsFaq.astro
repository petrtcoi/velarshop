---
import { columnsFaqItems } from './columnsData'
---

<section
	id='columns-faq'
	aria-label='Ответы на вопросы о трубчатых радиаторах Velar'
	class='bg-neutral-50 py-12 md:py-20'
>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>FAQ по трубчатым радиаторам</h2>
		<p class='mt-3 text-sm md:text-base leading-7 text-neutral-700'>
			Короткие ответы на вопросы, которые чаще всего возникают перед выбором и заказом.
		</p>
		<div class='mt-6 space-y-3'>
			{
				columnsFaqItems.map(item => (
					<details class='rounded-xl border border-neutral-200 bg-white p-4'>
						<summary class='cursor-pointer text-sm md:text-base font-semibold text-neutral-900'>{item.question}</summary>
						<div class='mt-3 text-sm leading-6 text-neutral-700'>
							<p>{item.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>
