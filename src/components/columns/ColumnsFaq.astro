---
import { columnsFaqItems } from './columnsData'
---

<section
	id='columns-faq'
	aria-label='Ответы на вопросы о трубчатых радиаторах Velar'
	class='bg-neutral-50 py-12 md:py-16 xl:py-20'
>
	<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
		<h2 class='text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl'>FAQ по трубчатым радиаторам</h2>
		<p class='mt-3 text-base leading-7 text-neutral-700'>
			Короткие ответы на вопросы, которые чаще всего возникают перед выбором и заказом.
		</p>
		<div class='mt-6 space-y-3'>
			{
				columnsFaqItems.map(item => (
					<details class='rounded-[20px] border border-neutral-200 bg-white p-5'>
						<summary class='cursor-pointer text-sm md:text-base font-semibold text-neutral-900'>{item.question}</summary>
						<div class='mt-3 text-sm leading-6 text-neutral-700'>
							<p>{item.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>
