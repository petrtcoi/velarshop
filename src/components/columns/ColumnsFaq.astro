---
const faqItems = [
	{
		q: 'Чем трубчатые радиаторы отличаются от панельных?',
		a: 'Трубчатые модели предлагают более гибкий выбор по высоте, глубине и количеству секций, а также лучше подходят для интерьерных задач. Панельные радиаторы чаще выигрывают по цене в типовых проектах.',
	},
	{
		q: 'Можно ли заказать трубчатый радиатор в цвет RAL?',
		a: 'Да, доступны варианты окраски по шкале RAL. Подбор цвета выполняется под интерьер или требования дизайн-проекта.',
	},
	{
		q: 'Как рассчитать мощность трубчатого радиатора?',
		a: 'Для точного расчета учитывают площадь, высоту потолков, теплопотери, тип остекления и температурный график системы отопления. Мы помогаем сделать расчет перед заказом.',
	},
	{
		q: 'Подходят ли трубчатые радиаторы для квартиры?',
		a: 'Да, они подходят для квартир, включая варианты установки под окнами и в помещениях с ограниченным пространством.',
	},
	{
		q: 'Сколько занимает производство?',
		a: 'Срок зависит от выбранной модели, количества секций, цвета и комплектации. Актуальные сроки уточняются при согласовании заказа.',
	},
	{
		q: 'Какой тип подключения выбрать?',
		a: 'Тип подключения зависит от схемы разводки и требований проекта. Мы подскажем оптимальный вариант после уточнения параметров объекта.',
	},
	{
		q: 'Можно ли сделать нестандартный размер?',
		a: 'Да, для трубчатых моделей доступны варианты под заказ по высоте, длине и числу секций.',
	},
]
---

<section
	id='columns-faq'
	aria-label='Ответы на вопросы о трубчатых радиаторах Velar'
	class='bg-neutral-50 py-12 md:py-20'
	itemscope
	itemtype='https://schema.org/FAQPage'
>
	<div class='max-w-7xl mx-auto px-5 md:px-10'>
		<h2 class='text-2xl md:text-3xl font-semibold text-neutral-900'>FAQ по трубчатым радиаторам</h2>
		<p class='mt-3 text-sm md:text-base leading-7 text-neutral-700'>
			Короткие ответы на вопросы, которые чаще всего возникают перед выбором и заказом.
		</p>
		<div class='mt-6 space-y-3'>
			{
				faqItems.map(item => (
					<details
						class='rounded-xl border border-neutral-200 bg-white p-4'
						itemscope
						itemprop='mainEntity'
						itemtype='https://schema.org/Question'
					>
						<summary class='cursor-pointer text-sm md:text-base font-semibold text-neutral-900' itemprop='name'>
							{item.q}
						</summary>
						<div
							class='mt-3 text-sm leading-6 text-neutral-700'
							itemscope
							itemprop='acceptedAnswer'
							itemtype='https://schema.org/Answer'
						>
							<p itemprop='text'>{item.a}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>
