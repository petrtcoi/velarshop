---
import { Picture } from '@astrojs/image/components'
import type { DesignSeries } from './designData'
import { formatRub } from './designData'

type Props = {
	series: DesignSeries
	orientation?: 'vertical' | 'horizontal'
	index?: number
}

const { series, orientation, index = 0 } = Astro.props as Props
const primaryModel =
	orientation === 'horizontal'
		? series.horizontalModel
		: orientation === 'vertical'
			? series.verticalModel
			: series.verticalModel ?? series.horizontalModel
const secondaryModel =
	orientation === 'vertical' ? series.horizontalModel : orientation === 'horizontal' ? series.verticalModel : undefined
---

<article class='group flex h-full flex-col overflow-hidden rounded-lg border border-neutral-200 bg-white'>
	<a href={series.href} class='block bg-neutral-50'>
		<Picture
			src={series.image}
			alt={`${series.title} дизайн-радиатор`}
			title={`${series.title} дизайн-радиатор`}
			loading={index > 5 ? 'lazy' : 'eager'}
			aspectRatio='4:3'
			widths={[360, 520, 720]}
			width={520}
			height={390}
			sizes='(max-width: 768px) 100vw, (max-width: 1180px) 33vw, 25vw'
			class='h-[220px] w-full object-contain p-5 transition duration-300 group-hover:scale-[1.02] md:h-[210px] xl:h-[240px]'
		/>
	</a>
	<div class='flex flex-1 flex-col p-5'>
		<div class='flex items-start justify-between gap-4'>
			<h3 class='text-xl font-semibold leading-tight text-neutral-950'>{series.title}</h3>
			{series.priceFrom > 0 && (
				<div class='shrink-0 text-right text-sm font-semibold text-neutral-950'>от {formatRub(series.priceFrom)}</div>
			)}
		</div>
		<p class='mt-3 text-[15px] leading-6 text-neutral-600'>{series.description}</p>
		<div class='mt-4 flex flex-wrap gap-2 text-xs font-semibold text-neutral-600'>
			<span class='rounded-full bg-neutral-100 px-3 py-1'>{series.profile}</span>
			<span class='rounded-full bg-neutral-100 px-3 py-1'>{series.orientations.includes('vertical') ? 'вертикальная' : ''}{series.orientations.length > 1 ? ' / горизонтальная' : ''}</span>
		</div>
		<div class='mt-auto flex flex-wrap gap-2 pt-5 text-sm font-semibold'>
			<a href={series.href} class='inline-flex h-9 items-center justify-center rounded-lg border border-neutral-300 px-3 text-neutral-950 transition hover:border-red-700 hover:text-red-700'>
				Подробнее о модели
			</a>
			{primaryModel && (
				<a href={primaryModel.href} class='inline-flex h-9 items-center justify-center rounded-lg bg-red-700 px-3 text-white transition hover:bg-red-800'>
					{orientation === 'horizontal' ? 'Горизонтальная' : orientation === 'vertical' ? 'Вертикальная' : primaryModel.orientation === 'vertical' ? 'Вертикальная' : 'Горизонтальная'}
				</a>
			)}
			{!orientation && series.verticalModel && series.horizontalModel && (
				<a href={series.horizontalModel.href} class='inline-flex h-9 items-center justify-center rounded-lg border border-neutral-300 px-3 text-neutral-950 transition hover:border-red-700 hover:text-red-700'>
					Горизонтальная
				</a>
			)}
			{orientation && secondaryModel && (
				<a href={secondaryModel.href} class='inline-flex h-9 items-center justify-center rounded-lg border border-neutral-300 px-3 text-neutral-950 transition hover:border-red-700 hover:text-red-700'>
					{secondaryModel.orientation === 'vertical' ? 'Есть вертикальная версия' : 'Есть горизонтальная версия'}
				</a>
			)}
		</div>
	</div>
</article>
