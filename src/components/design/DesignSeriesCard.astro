---
import Picture from '@shared/components/Picture.astro';
import type { DesignSeries } from './designData'
import { formatRub } from './designData'

type Props = {
	series: DesignSeries
	orientation?: 'vertical' | 'horizontal'
	index?: number
}

const { series, index = 0 } = Astro.props as Props
const orientationLabel = series.orientations.map(item => item === 'vertical' ? 'V' : 'H').join('/')
---

<article id={`series-${series.slug}`} class='group flex h-full flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white md:flex-row'>
	<a href={series.href} class='block bg-neutral-50 md:w-[220px] md:shrink-0 lg:w-[240px]'>
		<Picture
			src={series.image}
			alt={`${series.title} дизайн-радиатор`}
			title={`${series.title} дизайн-радиатор`}
			loading={index > 5 ? 'lazy' : 'eager'}
			aspectRatio='4:3'
			widths={[360, 520, 720]}
			width={520}
			height={390}
			sizes='(max-width: 768px) 100vw, 240px'
			class='h-[120px] w-full object-contain p-3 transition duration-300 group-hover:scale-[1.02] md:h-full md:min-h-[220px] md:p-4'
		/>
	</a>
	<div class='flex flex-1 flex-col p-4 md:p-5'>
		<div class='flex items-start justify-between gap-4'>
			<h3 class='text-lg font-semibold leading-tight text-neutral-950 md:text-xl'>{series.title}</h3>
			{series.priceFrom > 0 && (
				<div class='shrink-0 text-right text-sm font-semibold text-neutral-950'>от {formatRub(series.priceFrom)}</div>
			)}
		</div>
		<div class='mt-2 text-sm leading-6 text-neutral-600'>
			{series.profile} · {orientationLabel}
		</div>
		<p class='mt-3 text-sm leading-6 text-neutral-700'>
			<span class='font-medium text-neutral-950'>Когда выбрать:</span> {series.whenChoose}
		</p>
		<div class='mt-auto pt-4'>
			{series.models.length > 1 && (
				<div class='flex flex-wrap gap-x-3 gap-y-2 text-sm'>
					{series.verticalModel && (
						<a href={series.verticalModel.href} class='font-medium text-red-700 transition hover:underline'>
							{series.verticalModel.name}
						</a>
					)}
					{series.horizontalModel && (
						<a href={series.horizontalModel.href} class='font-medium text-red-700 transition hover:underline'>
							{series.horizontalModel.name}
						</a>
					)}
					<a href={series.href} class='font-medium text-neutral-700 transition hover:text-red-700 hover:underline'>
						Подробнее
					</a>
				</div>
			)}
			{series.models.length <= 1 && (
				<div class='flex flex-wrap gap-x-3 gap-y-2 text-sm'>
					<a href={series.href} class='font-medium text-neutral-700 transition hover:text-red-700 hover:underline'>
						Подробнее
					</a>
				</div>
			)}
		</div>
	</div>
</article>
