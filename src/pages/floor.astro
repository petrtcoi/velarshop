---
import Picture from '@shared/components/Picture.astro';
import { modelsJsonData } from '@entities/Model'
import { radiatorsJsonData } from '@entities/Radiator'
import Layout from '@shared/layouts/Layout.astro'
import { getModelSlug } from '@shared/utils/getModelSlug'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from './api/hero-configurator/[model].json'
import JsonLd from '../components/seo/JsonLd.astro'
import { getCategorySeo } from '../lib/seo/categorySeo'

const pageDescription =
	'Напольные радиаторы Velar для панорамных окон, низких подоконников, зимних садов и готовых интерьеров. Подбор Q500, P200 и P300, расчет мощности и доставка по России.'

const breadcrumbs = [
	{ title: 'Главная', url: '/' },
	{ title: 'Напольные радиаторы', url: '/floor' },
]

function toNum(value: string | undefined): number {
	if (!value) return 0
	const parsed = Number.parseFloat(value)
	return Number.isFinite(parsed) ? parsed : 0
}

function formatRub(value: number): string {
	return `${value.toLocaleString('ru-RU')} ₽`
}

const textLinkClass =
	'font-medium text-red-700 underline decoration-red-300 underline-offset-2 transition hover:decoration-transparent'

const modelCopy: Record<
	string,
	{
		title: string
		description: string
		whenToChoose: string
		cardSpecs: string
		cardWhen: string
	}
> = {
	q500: {
		title: 'Velar Q500',
		description:
			'Радиатор-скамейка высотой 500 мм для входных зон, гостиных, холлов и общественных помещений. Подходит для интерьеров, где радиатор должен быть не просто отопительным прибором, а частью мебели или архитектурной композиции.',
		whenToChoose:
			'если нужен выразительный напольный радиатор, который можно использовать как интерьерный объект вдоль стены, окна или в зоне ожидания.',
		cardSpecs: 'радиатор-скамейка',
		cardWhen: 'если радиатор должен быть частью интерьера, скамейкой или акцентом в холле, гостиной или входной зоне.',
	},
	p200: {
		title: 'Velar P200',
		description:
			'Низкий напольный радиатор высотой около 191 мм для установки перед панорамными окнами, низкими подоконниками и в помещениях, где важно не перекрывать обзор.',
		whenToChoose: 'если нужен максимально низкий и аккуратный радиатор перед остеклением.',
		cardSpecs: 'низкий напольный радиатор',
		cardWhen: 'перед панорамным окном, если важно не перекрывать обзор.',
	},
	p300: {
		title: 'Velar P300',
		description:
			'Более мощный напольный радиатор для панорамного остекления, зимних садов, просторных гостиных и помещений с повышенными теплопотерями.',
		whenToChoose:
			'если P200 может быть недостаточно по мощности или нужно отопить длинную зону остекления.',
		cardSpecs: 'напольный радиатор повышенной мощности',
		cardWhen: 'если у панорамного окна большие теплопотери или нужна большая мощность, чем у P200.',
	},
}

const floorModelOrder = ['q500', 'p200', 'p300']
const floorConfiguratorMap = new Map(buildQuickConfiguratorModels({ type: 'floor' }).map(model => [model.id, model]))
const floorConfiguratorModels = floorModelOrder
	.map(id => floorConfiguratorMap.get(id))
	.filter((model): model is NonNullable<typeof model> => Boolean(model))
const defaultFloorModelId = floorConfiguratorModels.find(model => model.id === 'p200')?.id ?? floorConfiguratorModels[0]?.id ?? 'p200'
let initialFloorDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultFloorModelId },
	} as any)
	if (response.ok) initialFloorDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload floor configurator model:', error)
}

const floorModels = floorModelOrder
	.map(id => modelsJsonData.find(model => model.id === id))
	.filter(Boolean)
	.map(model => {
		const radiators = radiatorsJsonData.filter(radiator => radiator.model_id === model!.id)
		const prices = radiators.map(radiator => toNum(radiator.price)).filter(value => value > 0)
		const minPrice = prices.length ? Math.min(...prices) : 0
		const firstRadiator = radiators[0]
		const lengths = radiators.map(radiator => toNum(radiator.length)).filter(value => value > 0)
		const minLength = lengths.length ? Math.min(...lengths) : 0
		const maxLength = lengths.length ? Math.max(...lengths) : 0

		return {
			id: model!.id,
			title: modelCopy[model!.id]?.title ?? `Velar ${model!.name}`,
			href: getModelSlug(model!),
			image: `/images/models/${model!.slug}/main.jpg`,
			priceFrom: minPrice,
			height: firstRadiator?.height ? `${firstRadiator.height} мм` : 'уточняется',
			width: firstRadiator?.width ? `${firstRadiator.width} мм` : 'уточняется',
			lengthRange: minLength && maxLength ? `${minLength}-${maxLength} мм` : 'уточняется',
			description: modelCopy[model!.id]?.description ?? model!.short_comment,
			whenToChoose: modelCopy[model!.id]?.whenToChoose ?? model!.short_comment,
			cardSpecs: modelCopy[model!.id]?.cardSpecs ?? model!.short_comment,
			cardWhen: modelCopy[model!.id]?.cardWhen ?? model!.short_comment,
		}
	})

const modelById = Object.fromEntries(floorModels.map(model => [model.id, model]))
const q500Href = modelById.q500?.href ?? '/model/q500'
const p200Href = modelById.p200?.href ?? '/model/p200'
const p300Href = modelById.p300?.href ?? '/model/p300'

const heroFacts = ['Q500, P200, P300', 'длина до 2500 мм', 'цвета RAL', 'доставка по России']

const usefulLinks = [
	['/info/floor-design-radiators', 'Напольные дизайн-радиаторы: особенности, преимущества и недостатки'],
	['/info/radiatory-dlya-panoramnykh-okon-tipy-osobennosti', 'Радиаторы для панорамных окон: типы и особенности'],
	['/info/teplovaya-zavesa-u-panoramnyh-okon', 'Тепловая завеса у панорамных окон'],
	['/info/vnutripolnyy-konvektor-scenarii', 'Когда вместо напольного радиатора выбрать внутрипольный конвектор'],
	['/info/chto-postavit-pered-panoramnym-oknom', 'Что поставить перед панорамным окном'],
] as const

const convectorArticleLink = usefulLinks.find(([, title]) => title === 'Когда вместо напольного радиатора выбрать внутрипольный конвектор')

const quickChips = [
	{ label: 'Перед панорамным окном', href: '#model-p200' },
	{ label: 'Низкий радиатор', href: '#model-p200' },
	{ label: 'Больше мощности', href: '#model-p300' },
	{ label: 'Радиатор-скамейка', href: '#model-q500' },
	{ label: 'Как выбрать модель', href: '#floor-model-choice' },
	{ label: 'Подобрать по параметрам', href: '#floor-calculator' },
	{ label: 'Для готового ремонта', href: '#floor-vs-convector' },
	{ label: 'Сравнить с конвектором', href: '#floor-vs-convector' },
	{ label: 'Для коммерческого помещения', href: '#model-q500' },
]

const chooseRows = [
	{
		task: 'Низкий радиатор перед панорамным окном',
		choice: [{ href: p200Href, label: 'P200' }],
		reason: 'Минимальная высота, не перекрывает обзор, подходит для остекления в пол.',
	},
	{
		task: 'Больше мощности вдоль окна',
		choice: [{ href: p300Href, label: 'P300' }],
		reason: 'Выше и мощнее P200, лучше для просторных помещений, зимних садов и больших теплопотерь.',
	},
	{
		task: 'Радиатор как часть интерьера',
		choice: [{ href: q500Href, label: 'Q500' }],
		reason: 'Формат радиатора-скамейки, подходит для холлов, входных зон, гостиных и коммерческих помещений.',
	},
	{
		task: 'Длинная зона остекления',
		choice: [
			{ href: p200Href, label: 'P200' },
			{ href: p300Href, label: 'P300' },
		],
		reason: 'Выбор зависит от теплопотерь, длины окна и доступной высоты.',
	},
	{
		task: 'Полностью скрытое отопление',
		choice: [{ href: '/convector', label: 'Внутрипольный конвектор' }],
		reason: 'Если радиатор не должен быть виден, лучше смотреть конвектор в полу.',
	},
]

const floorVsConvectorRows = [
	{
		criterion: 'Видимость',
		floor: 'Видим в интерьере',
		convector: 'Скрыт в полу, видна решетка',
	},
	{
		criterion: 'Монтаж',
		floor: 'Проще, не нужен канал в полу',
		convector: 'Нужна ниша, лучше планировать на стадии ремонта',
	},
	{
		criterion: 'Где использовать',
		floor: 'Готовые интерьеры, низкие подоконники, входные зоны',
		convector: 'Окна в пол, новые проекты, скрытое отопление',
	},
	{
		criterion: 'Визуальная роль',
		floor: 'Часть интерьера',
		convector: 'Максимально незаметное решение',
	},
	{
		criterion: 'Что выбрать',
		floor: 'Если прибор может быть видимым',
		convector: 'Если отопление нужно спрятать',
	},
]

const benefits = [
	['Производство под заказ', 'Подбираем модель, длину, подключение и цвет под конкретную зону установки.'],
	['Цвета RAL', 'Радиатор можно сделать в цвет пола, стен, оконных рам, мебели или использовать как акцент.'],
	['Решение для панорамных окон', 'P200 и P300 подходят для длинных зон остекления, где важно создать тепловую завесу.'],
	['Радиатор как часть интерьера', 'Q500 можно использовать как выразительный объект и визуально связать с мебелью или архитектурой.'],
	['Подбор мощности', 'Расчет выполняется по размерам помещения, длине остекления, теплопотерям и температурному режиму системы.'],
	['Доставка по России', 'Подберем способ доставки до вашего города и заранее согласуем условия упаковки и отправки.'],
]

const orderSteps = [
	['01', 'Выберите задачу', 'Укажите, где будет стоять радиатор: перед панорамным окном, в гостиной, зимнем саду, входной зоне, холле или коммерческом помещении.'],
	['02', 'Выберите модель', 'Q500 - если нужен радиатор-скамейка, P200 - если нужен низкий аккуратный радиатор, P300 - если требуется больше мощности.'],
	['03', 'Отправьте параметры', 'Передайте длину зоны установки, высоту подоконника или остекления, город доставки, фото помещения, план или проект.'],
	['04', 'Получите расчет', 'Менеджер рассчитает мощность, длину, подключение, цвет, стоимость и срок производства.'],
	['05', 'Согласуйте оплату и документы', 'После проверки конфигурации согласуем итоговую цену, договор, предоплату и способ оплаты для физического или юридического лица.'],
	['06', 'Производство и доставка', 'Радиатор запускается в производство или резервируется, если подходящий вариант доступен. После готовности выполняется доставка по России.'],
]

const faqItems = [
	[
		'Где устанавливают напольные радиаторы?',
		'Напольные радиаторы устанавливают перед панорамными окнами, в гостиных, зимних садах, входных группах, холлах и коммерческих помещениях. Они подходят для ситуаций, когда настенный радиатор поставить сложно, а внутрипольный конвектор невозможен или не нужен.',
	],
	[
		'Чем напольный радиатор отличается от внутрипольного конвектора?',
		'Напольный радиатор ставится поверх пола и остается видимым элементом интерьера. Внутрипольный конвектор монтируется в нишу в полу и закрывается декоративной решеткой. Если нужно скрыть отопление полностью, выбирают конвектор. Если радиатор может быть частью интерьера или нет возможности делать канал в полу, выбирают напольную модель.',
	],
	[
		'Можно ли заказать напольный радиатор в цвет RAL?',
		'Да, напольные радиаторы Velar можно окрашивать в цвета палитры RAL. Радиатор можно сделать в цвет пола, стен, оконных рам, мебели или использовать как акцентный элемент интерьера.',
	],
	[
		'Как выбрать между Q500, P200 и P300?',
		'Q500 стоит рассматривать как радиатор-скамейку и выразительный интерьерный объект. P200 подойдет, если нужен низкий аккуратный радиатор перед остеклением. P300 стоит выбрать, если требуется более мощное решение для просторного помещения, зимнего сада или зоны с большими теплопотерями.',
	],
	[
		'Сколько занимает производство?',
		'Ориентировочный срок производства составляет 5-6 недель без учета доставки. Актуальные сроки нужно уточнять у менеджера, потому что они зависят от модели, длины, цвета, подключения и загрузки производства.',
	],
	[
		'Можно ли подобрать радиатор по плану помещения?',
		'Да, можно отправить план, размеры зоны установки, фото помещения или дизайн-проект. Менеджер поможет выбрать модель, длину, цвет, мощность и параметры подключения.',
	],
	[
		'Что выбрать для панорамного окна?',
		'Для панорамного окна обычно выбирают P200 или P300. P200 подходит, если нужен низкий аккуратный прибор, который не перекрывает обзор. P300 выбирают, если помещение просторное, есть большие теплопотери или нужна большая теплоотдача вдоль остекления.',
	],
	[
		'Можно ли поставить напольный радиатор в готовом ремонте?',
		'Часто да, потому что напольный радиатор не требует канала в полу, как внутрипольный конвектор. Но нужно проверить разводку труб, место подключения, расстояния до окна и возможность аккуратного монтажа.',
	],
	[
		'Какой напольный радиатор выбрать для входной зоны?',
		'Для входной зоны можно рассмотреть Q500, если радиатор должен быть заметным интерьерным объектом или работать как скамейка. Если важна низкая высота вдоль остекления, лучше смотреть P200 или P300.',
	],
	[
		'Что нужно отправить для расчета?',
		'Для расчета желательно отправить город, размеры зоны установки, длину панорамного окна, высоту подоконника или остекления, фото помещения, план, желаемую модель, цвет RAL и информацию по подключению.',
	],
]

const usefulLinkGroups = [
	{
		title: 'Выбор решения для панорамных окон',
		items: usefulLinks.filter(([, title]) =>
			[
				'Радиаторы для панорамных окон: типы и особенности',
				'Что поставить перед панорамным окном',
				'Тепловая завеса у панорамных окон',
			].includes(title),
		),
	},
	{
		title: 'Напольный радиатор или конвектор',
		items: usefulLinks.filter(([, title]) =>
			[
				'Напольные дизайн-радиаторы: особенности, преимущества и недостатки',
				'Когда вместо напольного радиатора выбрать внутрипольный конвектор',
			].includes(title),
		),
	},
]

const seo = getCategorySeo({
	category: {
		slug: 'floor',
		url: '/floor',
		name: 'Напольные радиаторы',
		h1: 'Напольные радиаторы отопления Velar',
		seoTitle: 'Напольные радиаторы Velar для панорамных окон и интерьеров',
		seoDescription: pageDescription,
		ogTitle: 'Напольные радиаторы Velar - Q500, P200 и P300',
		ogDescription:
			'Напольные радиаторы для панорамных окон, готовых интерьеров и коммерческих помещений: подбор Q500, P200 и P300, расчет мощности и доставка по России.',
		ogImage: '/images/main/main0.jpg',
		ogImageAlt: 'Напольные радиаторы Velar',
		breadcrumbs,
		itemListName: 'Модели напольных радиаторов Velar',
		products: floorModels.map(model => ({
			name: model.title,
			url: model.href,
		})),
		productOffers: floorModels.map(model => ({
			name: model.title,
			url: model.href,
			image: model.image,
			description: model.description,
			category: 'Напольные радиаторы',
			lowPrice: model.priceFrom,
		})),
		faq: faqItems.map(([question, answer]) => ({
			question,
			answer,
		})),
	},
})
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalUrl={seo.canonicalUrl}
	robots={seo.robots}
	ogType='website'
	ogTitle={seo.ogTitle}
	ogDescription={seo.ogDescription}
	ogUrl={seo.canonicalUrl}
	ogImageUrl={seo.ogImage}
	ogImageAlt={seo.ogImageAlt}
	twitterCard='summary_large_image'
	twitterTitle={seo.twitterTitle}
	twitterDescription={seo.twitterDescription}
	twitterImage={seo.twitterImage}
	twitterImageAlt={seo.twitterImageAlt}
	breadcrumbs={breadcrumbs}
	disableBreadcrumbJsonLd={true}
	paddings={false}
>
	<JsonLd data={seo.jsonLd} />

	<section class='border-b border-neutral-200 bg-white'>
		<div class='mx-auto grid max-w-[1240px] gap-7 px-4 pb-8 pt-6 md:px-6 md:pb-10 md:pt-9 lg:grid-cols-[minmax(0,1fr)_minmax(340px,460px)] lg:items-start lg:gap-10 xl:px-8 xl:py-12'>
			<div class='min-w-0'>
				<h1 class='max-w-[760px] text-[34px] font-semibold leading-[1.04] tracking-tight text-neutral-950 md:text-[44px] xl:text-[56px]'>
					Напольные радиаторы отопления Velar
				</h1>
				<p class='mt-4 max-w-[820px] text-sm font-normal leading-6 text-neutral-700 md:text-base md:leading-7'>
					Напольные радиаторы Velar - решение для панорамных окон, низких подоконников, гостиных, зимних садов и интерьеров, где настенный радиатор поставить сложно или нежелательно. В линейке есть Q500 радиатор-скамейка, низкий P200 и более мощный P300 для зон с большими теплопотерями. Выберите модель ниже или отправьте размеры зоны установки - менеджер рассчитает мощность, стоимость, оплату и доставку по России.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row min-[420px]:flex-wrap'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
						Получить расчет
					</a>
					<a href='#floor-models' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Смотреть модели
					</a>
					<a href='#floor-calculator' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Подобрать по параметрам
					</a>
				</div>
				<div class='mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm text-neutral-600'>
					{heroFacts.map(item => (
						<span class='inline-flex items-center gap-2'>
							<span class='h-1 w-1 rounded-full bg-red-700'></span>
							<span>{item}</span>
						</span>
					))}
				</div>
			</div>

			<div id='floor-calculator' class='min-w-0'>
				<HeroQuickConfigurator
					client:load
					models={floorConfiguratorModels}
					defaultModelId={defaultFloorModelId}
					initialDetails={initialFloorDetails}
					variant='category'
					title='Быстрый выбор'
					subtitle='Выберите модель, длину, цвет и подключение - покажем подходящий вариант.'
					addToCartLabel='Добавить в запрос'
					goToCartLabel='Перейти к запросу'
