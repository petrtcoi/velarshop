---
import { getCollection } from 'astro:content';
import Layout from '@shared/layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { Picture } from '@astrojs/image/components';

export async function getStaticPaths() {
  const articles = await getCollection('news');
  return articles.map(article => ({
    params: { article: article.slug },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<'news'>;
};
const { article } = Astro.props as Props;
const { Content } = await article.render();
const { title, short_description, thumbnail, date } = article.data;
const readingMinutes = Math.max(1, Math.ceil((article.body ?? '').split(/\s+/).filter(Boolean).length / 180));
const publishedAt = new Date(`${date}T00:00:00+03:00`).toISOString();
const humanDate = new Intl.DateTimeFormat('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(`${date}T00:00:00+03:00`));

const imgPath = thumbnail.length > 0 ? `/images/news/${thumbnail}` : null;
const imageUrl = imgPath ? new URL(imgPath, 'https://velarshop.ru').toString() : null;
const articleUrl = new URL(`/news/${article.slug}`, 'https://velarshop.ru').toString();
const crumbs = [
  { title: 'Главная', url: '/' },
  { title: 'Новости', url: '/news' },
  { title, url: `/news/${article.slug}` },
];

const newsArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: short_description,
  url: articleUrl,
  datePublished: publishedAt,
  dateModified: publishedAt,
  mainEntityOfPage: articleUrl,
  inLanguage: 'ru-RU',
  author: {
    '@type': 'Organization',
    name: 'Velar',
    url: 'https://velarshop.ru',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Velar',
    url: 'https://velarshop.ru',
    logo: {
      '@type': 'ImageObject',
      url: 'https://velarshop.ru/images/logo.png',
    },
  },
  ...(imageUrl ? { image: [imageUrl] } : {}),
};
---

<Layout
  title={`${title} | VelarShop.ru`}
  description={short_description}
  breadcrumbs={crumbs}
  paddings={false}
  ogImageUrl={imgPath ?? undefined}
  ogImageAlt={title}
  ogType='article'
>
  <Fragment slot='head'>
    <script type='application/ld+json' set:html={JSON.stringify(newsArticleSchema)} />
  </Fragment>

  <div class='article-page article-page--info'>
    <header class='article-hero'>
      <div class='article-shell article-shell--reading'>
        <div class='article-hero__meta'>
          <span>Новости</span>
          <span>{humanDate}</span>
          <span>{readingMinutes} мин чтения</span>
          <a href='/news'>Все новости</a>
        </div>
        <h1 class='article-hero__title'>{title}</h1>
        <p class='article-hero__lead'>{short_description}</p>
      </div>
    </header>

    <div class='article-shell article-shell--reading article-layout'>
      <article
        class='article-content article-prose'
        itemscope
        itemtype='https://schema.org/NewsArticle'
      >
        <meta itemprop='headline' content={title} />
        {imageUrl && <meta itemprop='image' content={imageUrl} />}
        <meta itemprop='datePublished' content={publishedAt} />
        <meta itemprop='dateModified' content={publishedAt} />
        <meta itemprop='mainEntityOfPage' content={articleUrl} />
        <meta itemprop='author' content='Velar' />
        <meta itemprop='publisher' content='Velar' />
        <Content />

        {
          imgPath && (
            <Picture
              src={imgPath}
              alt={title}
              title={title}
              loading='lazy'
              aspectRatio='1:1'
              widths={[400, 800]}
              width={800}
              height={800}
              sizes='800'
            />
          )
        }
        <p class='text-xs text-slate-600'>Использованы материалы с сайта <a href='https://velarwh.ru'>velarwh.ru</a></p>
      </article>
    </div>
  </div>
</Layout>
