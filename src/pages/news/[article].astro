---
import { getCollection } from 'astro:content';
import Layout from '@shared/layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { Picture } from '@astrojs/image/components';

export async function getStaticPaths() {
  const articles = await getCollection('news');
  return articles.map(article => ({
    params: { article: article.slug },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<'news'>;
};
const { article } = Astro.props as Props;
const { Content } = await article.render();
const { title, short_description, thumbnail, date } = article.data;
const readingMinutes = Math.max(1, Math.ceil((article.body ?? '').split(/\s+/).filter(Boolean).length / 180));

const imgPath = thumbnail.length > 0 ? `/images/news/${thumbnail}` : null;
const imageUrl = imgPath ? new URL(imgPath, 'https://velarshop.ru').toString() : null;
const crumbs = [
  { title: 'Главная', url: '/' },
  { title: 'Новости', url: '/news' },
  { title, url: `/news/${article.slug}` },
];
---

<Layout
  title={`${title} | VelarShop.ru`}
  description={short_description}
  breadcrumbs={crumbs}
  paddings={false}
  ogImageUrl={imgPath ?? undefined}
  ogImageAlt={title}
>
  <div class='article-page'>
    <header class='article-hero'>
      <div class='article-shell'>
        <div class='article-hero__meta'>
          <span>Новости</span>
          <span>{date}</span>
          <span>{readingMinutes} мин чтения</span>
          <a href='/news'>Все новости</a>
        </div>
        <h1 class='article-hero__title'>{title}</h1>
        <p class='article-hero__lead'>{short_description}</p>
      </div>
    </header>

    <div class='article-shell article-layout'>
      <article
        class='article-content article-prose'
        itemscope
        itemtype='https://schema.org/NewsArticle'
      >
        <meta itemprop='headline' content={title} />
        {imageUrl && <meta itemprop='image' content={imageUrl} />}
        <meta itemprop='datePublished' content={`${date}T00:00:00+03:00`} />
        <Content />

        {
          imgPath && (
            <Picture
              src={imgPath}
              alt={title}
              title={title}
              loading='lazy'
              aspectRatio='1:1'
              widths={[400, 800]}
              width={800}
              height={800}
              sizes='800'
            />
          )
        }
        <p class='text-xs text-slate-600'>Использованы материалы с сайта https://velarwh.ru</p>
      </article>
    </div>
  </div>
</Layout>
