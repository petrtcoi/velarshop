---
import { Picture } from '@astrojs/image/components';
import Layout from '@shared/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('news');

const crumbs = [
  { title: 'Главная', url: '/' },
  { title: 'Новости', url: '/news' },
];

const newsItems = articles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((article, index) => {
    const imagePath =
      article.data.thumbnail.length > 0
        ? `/images/news/${article.data.thumbnail}`
        : '/images/news/empty.jpg';
    const articleUrl = new URL(`/news/${article.slug}`, 'https://velarshop.ru').toString();
    const imageUrl = new URL(imagePath, 'https://velarshop.ru').toString();
    const publishedAt = new Date(`${article.data.date}T00:00:00+03:00`).toISOString();

    return {
      article,
      articleUrl,
      imagePath,
      imageUrl,
      publishedAt,
      position: index + 1,
    };
  });

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Новости Velar',
  url: 'https://velarshop.ru/news',
  description: 'Новости Velar: обновления продукции, цены, сроки производства и события компании.',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: newsItems.map((item) => ({
      '@type': 'ListItem',
      position: item.position,
      item: {
        '@type': 'NewsArticle',
        headline: item.article.data.title,
        description: item.article.data.short_description,
        url: item.articleUrl,
        image: [item.imageUrl],
        datePublished: item.publishedAt,
        dateModified: item.publishedAt,
      },
    })),
  },
};
---

<Layout
  title='Новости | дизайн радиаторы и конвекторы | VelarShop.ru'
  description='Новости Velar: обновления продукции, цены, сроки производства и события компании.'
  breadcrumbs={crumbs}
>
  <Fragment slot='head'>
    <script type='application/ld+json' set:html={JSON.stringify(pageSchema)} />
  </Fragment>

  <section class='mx-auto max-w-6xl p-5 md:px-10'>
    <div class='space-y-4'>
      <h1 class='m-0 text-[34px] font-semibold leading-[1.08] tracking-tight text-neutral-950 md:text-[44px]'>Новости</h1>
      <p class='max-w-[840px] text-base leading-7 text-neutral-700 md:text-[18px] md:leading-8'>
        Обновления Velar по моделям, ценам, срокам производства и ключевым событиям компании.
      </p>
    </div>

    <div
      id='articles_list'
      aria-label='Список новостей'
      class='mt-10 flex flex-row flex-wrap items-start gap-8 justify-start'
    >
      {newsItems.map(({ article, imagePath }) => {
        const { title, short_description, slug, date } = article.data;
        const articleHref = `/news/${slug}`;

        return (
          <div class='group w-72 mx-auto sm:mx-0'>
            <a href={articleHref}>
              <Picture
                src={imagePath}
                alt={title}
                title={title}
                loading='lazy'
                aspectRatio='1:1'
                widths={[290, 500]}
                width={290}
                height={290}
                sizes='290px'
                class='rounded-lg opacity-100 md:opacity-75 group-hover:opacity-100 group-hover:shadow-lg transition-opacity duration-300'
              />
              <div class='text-sm mt-2 group-hover:text-red-600 transition-colors duration-300'>
                {title}
              </div>
              <div class='text-xs mt-1 text-neutral-600 group-hover:text-neutral-900'>
                {short_description}
              </div>
              <div class='mt-2 text-xs text-slate-700 font-normal'>{date}</div>
            </a>
          </div>
        );
      })}
    </div>
  </section>
</Layout>
