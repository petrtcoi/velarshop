---
import { getCollection } from "astro:content";
import Layout from "@shared/layouts/Layout.astro";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { article: article.slug },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<"articles">;
};

const { article } = Astro.props as Props;
const { Content } = await article.render();
const { title, short_description, metaTitle, metaDescription } = article.data;
const allArticles = await getCollection("articles");
const articleTitleBySlug = new Map(allArticles.map((entry) => [entry.slug, entry.data.title]));

type Topic = "safety" | "design" | "columns" | "convector" | "retro" | "generic";

type ArticleCandidate = {
  slug: string;
  label?: string;
};

type SectionLink = {
  href: string;
  label: string;
};

const relatedArticleSets: Record<Topic, ArticleCandidate[]> = {
  safety: [
    { slug: "power" },
    { slug: "oshibki-pri-vybore-radiatorov", label: "Как выбрать радиатор отопления для квартиры" },
    { slug: "column-radiators-pros-cons", label: "Трубчатые радиаторы: особенности и выбор" },
    { slug: "kak-podobrat-radiatory-dlya-kuhni", label: "Радиаторы для кухни: как подобрать" },
  ],
  design: [
    { slug: "kak-podobrat-radiator-pod-dizajn-kvartiry", label: "Как выбрать дизайнерский радиатор" },
    { slug: "vertical-designer-radiators", label: "Вертикальные или горизонтальные радиаторы" },
    { slug: "horizontal-designer-radiators", label: "Радиаторы в интерьере: горизонтальные модели" },
    { slug: "colors", label: "Цвета RAL для радиаторов" },
  ],
  columns: [
    { slug: "steel-tube-radiators-guide", label: "Как выбрать трубчатый радиатор" },
    { slug: "power", label: "Как рассчитать мощность радиатора" },
    { slug: "column-radiators-pros-cons", label: "Трубчатые или панельные радиаторы" },
    { slug: "tube-radiators", label: "Трубчатые радиаторы для квартиры" },
  ],
  convector: [
    { slug: "kak-vybirat-vnutripolnye-konvektory", label: "Как выбрать внутрипольный конвектор" },
    { slug: "vnutripolnye-konvektory-s-ventilyatorom", label: "Конвекторы с вентилятором" },
    { slug: "teplovaya-zavesa-u-panoramnyh-okon", label: "Конвекторы для панорамных окон" },
    { slug: "vnutripolnye-konvektory-podbor-i-montazh", label: "Монтаж внутрипольных конвекторов" },
  ],
  retro: [
    { slug: "ironcast", label: "Как выбрать чугунный ретро-радиатор" },
    { slug: "kak-otlichit-kachestvennoe-lite-radiatorov", label: "Радиаторы с орнаментом: качество литья" },
    { slug: "colors", label: "Патина и цвета для ретро-радиаторов" },
    { slug: "restavratsiya-chugunnyh-radiatorov", label: "Ретро-радиаторы в интерьере" },
  ],
  generic: [
    { slug: "power" },
    { slug: "kak-podobrat-radiator-pod-dizajn-kvartiry" },
    { slug: "steel-tube-radiators-guide" },
    { slug: "kak-vybirat-vnutripolnye-konvektory" },
  ],
};

const sectionLinkSets: Record<Topic, SectionLink[]> = {
  safety: [
    { href: "/columns", label: "Трубчатые радиаторы Velar" },
    { href: "/design", label: "Дизайн-радиаторы Velar" },
  ],
  design: [
    { href: "/design", label: "Дизайн-радиаторы Velar" },
    { href: "/design/vertikalnye", label: "Вертикальные дизайн-радиаторы" },
    { href: "/design/gorizontalnye", label: "Горизонтальные дизайн-радиаторы" },
  ],
  columns: [
    { href: "/columns", label: "Трубчатые радиаторы Velar" },
    { href: "/floor", label: "Напольные радиаторы" },
  ],
  convector: [
    { href: "/convector", label: "Внутрипольные конвекторы Velar" },
    { href: "/model/kwh", label: "KWH" },
    { href: "/model/kwhv", label: "KWHV" },
    { href: "/model/kwhv24", label: "KWHV 24V" },
  ],
  retro: [
    { href: "/retro", label: "Чугунные ретро-радиаторы" },
  ],
  generic: [
    { href: "/design", label: "Дизайн-радиаторы Velar" },
    { href: "/columns", label: "Трубчатые радиаторы Velar" },
    { href: "/convector", label: "Внутрипольные конвекторы Velar" },
    { href: "/retro", label: "Чугунные ретро-радиаторы" },
  ],
};

function getTopicBySlug(slug: string): Topic {
  if (/convektor|konvektor|convector|panoram|teplovaya-zavesa|220v|24v|kwh/.test(slug)) return "convector";
  if (/trubchat|tube|column|sekci|panelnyh|termostat|chistit/.test(slug)) return "columns";
  if (/chugun|retro|iron|lite|restavrats/.test(slug)) return "retro";
  if (/design|vertical|horizontal|tsvet|interer|colors|wall|kuhni|chernye|forma-trub/.test(slug)) return "design";
  if (/bezopasnost|vybor|oshibki|power|radiator-ne-greet|kreplenie|teplootdacha|heating/.test(slug)) return "safety";
  return "generic";
}

function normalizeText(value: string): string {
  return value
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/&[a-z]+;/gi, " ")
    .replace(/[`*_~]/g, " ")
    .replace(/[^\p{L}\p{N}\s]/gu, " ")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase();
}

function getFirstHeadingFromBody(body: string): { level: number; text: string } | null {
  const lines = body.split("\n");

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (!line) continue;
    if (line.startsWith("import ") || line.startsWith("export ")) continue;

    const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
    if (headingMatch) {
      return {
        level: headingMatch[1].length,
        text: headingMatch[2].trim(),
      };
    }

    return null;
  }

  return null;
}

const topic = getTopicBySlug(article.slug);

const existingRelatedLinks = new Set<string>();
const readMoreLinks = [...relatedArticleSets[topic], ...relatedArticleSets.generic]
  .filter((candidate) => candidate.slug !== article.slug)
  .filter((candidate) => articleTitleBySlug.has(candidate.slug))
  .filter((candidate) => {
    if (existingRelatedLinks.has(candidate.slug)) return false;
    existingRelatedLinks.add(candidate.slug);
    return true;
  })
  .slice(0, 4)
  .map((candidate) => ({
    href: `/info/${candidate.slug}`,
    label: candidate.label ?? articleTitleBySlug.get(candidate.slug) ?? candidate.slug,
    description: articleTitleBySlug.get(candidate.slug) ?? "",
  }));

const sectionLinks = sectionLinkSets[topic];

const firstBodyHeading = getFirstHeadingFromBody(article.body ?? "");
const shouldHideDuplicateIntroHeading =
  firstBodyHeading !== null &&
  (firstBodyHeading.level === 1 || firstBodyHeading.level === 2) &&
  normalizeText(firstBodyHeading.text) === normalizeText(title);

const crumbs = [
  { title: "Главная", url: "/" },
  { title: "Полезные материалы", url: "/info" },
  { title, url: `/info/${article.slug}` },
];
---

<Layout
  title={metaTitle || `${title} | VelarShop.ru`}
  description={metaDescription || short_description}
  breadcrumbs={crumbs}
  paddings={false}
>
  <div class='article-page article-page--info'>
    <header class='article-hero'>
      <div class='article-shell article-shell--reading'>
        <h1 class='article-hero__title'>{title}</h1>
        <p class='article-hero__lead'>{short_description}</p>
      </div>
    </header>

    <div class='article-shell article-shell--reading article-layout'>
      <article class:list={['article-content', 'article-prose', shouldHideDuplicateIntroHeading && 'article-prose--hide-duplicate-intro-heading']}>
        <Content />

        <section class='not-prose article-related'>
          <div class='article-related__block'>
            <h2 class='article-related__title'>Читайте также</h2>
            <ul class='article-related__cards'>
              {readMoreLinks.map((item) => (
                <li>
                  <a class='article-related__card' href={item.href}>
                    <span class='article-related__card-title'>{item.label}</span>
                    <span class='article-related__card-more'>Подробнее →</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class='article-related__block'>
            <h2 class='article-related__title'>Перейти в раздел</h2>
            <ul class='article-related__chips'>
              {sectionLinks.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </article>
    </div>
  </div>
</Layout>
