---
import { getCollection } from "astro:content";
import Layout from "@shared/layouts/Layout.astro";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { article: article.slug },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<"articles">;
};
const { article } = Astro.props as Props;
const { Content } = await article.render();
const { title, short_description, metaTitle, metaDescription } = article.data;
const readingMinutes = Math.max(1, Math.ceil((article.body ?? '').split(/\s+/).filter(Boolean).length / 180));
const relatedLinkSets = {
  convector: [
    ['/convector', 'Внутрипольные конвекторы Velar'],
    ['/model/kwh', 'Velar KWH без вентилятора'],
    ['/model/kwhv', 'Velar KWHV с вентилятором'],
    ['/info/vnutripolnye-konvektory-podbor-i-montazh', 'Подбор и монтаж внутрипольных конвекторов'],
  ],
  columns: [
    ['/columns', 'Трубчатые радиаторы Velar'],
    ['/info/steel-tube-radiators-guide', 'Как выбрать стальной трубчатый радиатор'],
    ['/info/column-radiators-pros-cons', 'Плюсы и минусы трубчатых радиаторов'],
    ['/info/raschet-sekciy-trubchatogo-radiatora-uglovaya-komnata', 'Расчет секций для угловой комнаты'],
  ],
  retro: [
    ['/retro', 'Чугунные ретро-радиаторы Velar'],
    ['/info/ironcast', 'Особенности чугунных радиаторов'],
    ['/info/restavratsiya-chugunnyh-radiatorov', 'Реставрация чугунных радиаторов'],
    ['/info/pravila-ekspluatacii-chugunnyh-radiatorov', 'Правила эксплуатации чугунных радиаторов'],
  ],
  floor: [
    ['/floor', 'Напольные радиаторы Velar'],
    ['/info/floor-design-radiators', 'Напольные дизайн-радиаторы'],
    ['/convector', 'Внутрипольные конвекторы для панорамных окон'],
    ['/info/radiatory-dlya-panoramnykh-okon-tipy-osobennosti', 'Радиаторы для панорамных окон'],
  ],
  design: [
    ['/design', 'Дизайн-радиаторы Velar'],
    ['/design/vertikalnye', 'Вертикальные дизайн-радиаторы'],
    ['/design/gorizontalnye', 'Горизонтальные дизайн-радиаторы'],
    ['/info/power', 'Как рассчитать мощность радиатора'],
  ],
  generic: [
    ['/design', 'Дизайн-радиаторы Velar'],
    ['/columns', 'Трубчатые радиаторы Velar'],
    ['/convector', 'Внутрипольные конвекторы Velar'],
    ['/info/power', 'Как рассчитать мощность радиатора'],
  ],
} as const

function getRelatedLinks(slug: string): readonly (readonly [string, string])[] {
  if (/convektor|konvektor|panoram|teplovaya-zavesa|220v|24v/.test(slug)) return relatedLinkSets.convector
  if (/trubchat|tube|column|sekci|panelnyh|termostat/.test(slug)) return relatedLinkSets.columns
  if (/chugun|retro|iron|restavrats|lite/.test(slug)) return relatedLinkSets.retro
  if (/floor|napoln/.test(slug)) return relatedLinkSets.floor
  if (/design|vertical|horizontal|tsvet|interer|wall|steel|kuhni/.test(slug)) return relatedLinkSets.design
  return relatedLinkSets.generic
}

const relatedLinks = getRelatedLinks(article.slug).filter(([href]) => href !== `/info/${article.slug}`).slice(0, 4)

const crumbs = [
	{title: 'Главная', url: '/'},
	{title: 'Полезные материалы', url: '/info'},
  {title: title, url: `/info/${article.slug}`},
]
---

<Layout
  title={metaTitle || `${title} | VelarShop.ru`}
  description={metaDescription || short_description}
  breadcrumbs={crumbs}
  paddings={false}
>
  <div class='article-page'>
    <header class='article-hero'>
      <div class='article-shell'>
        <div class='article-hero__meta'>
          <span>Полезные материалы</span>
          <span>{readingMinutes} мин чтения</span>
          <a href='/info'>Все статьи</a>
        </div>
        <h1 class='article-hero__title'>{title}</h1>
        <p class='article-hero__lead'>{short_description}</p>
      </div>
    </header>

    <div class='article-shell article-layout'>
      <article class='article-content article-prose'>
        <Content />
        <section class='not-prose mt-12 border-t border-neutral-200 pt-6'>
          <h2 class='text-xl font-semibold leading-tight tracking-tight text-neutral-950 md:text-2xl'>Полезные материалы по теме</h2>
          <ul class='mt-4 grid gap-2 text-sm leading-6 text-neutral-700 md:grid-cols-2'>
            {relatedLinks.map(([href, label]) => (
              <li>
                <a class='text-red-700 underline decoration-red-700/40 underline-offset-[0.18em] transition hover:text-red-800 hover:decoration-transparent' href={href}>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </article>
    </div>
  </div>
</Layout>
