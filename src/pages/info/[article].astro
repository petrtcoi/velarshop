    <header class='article-hero'>
      <div class='article-shell article-shell--reading'>
        <h1 class='article-hero__title'>{title}</h1>
        <p class='article-hero__lead'>{short_description}</p>
      </div>
    </header>

    <div class='article-shell article-shell--reading article-layout'>
      <article class:list={['article-content', 'article-prose', shouldHideDuplicateIntroHeading && 'article-prose--hide-duplicate-intro-heading']}>
        <Content />

        <ArticleCta
          className='article-cta--footer'
          variant='light'
          size='compact'
          title={endingCta.title}
          description={endingCta.description}
          buttonText={endingCta.buttonText}
          buttonHref={endingCta.buttonHref}
          linkText={endingCta.linkText}
          linkHref={endingCta.linkHref}
        />

        <section class='not-prose article-related'>
          <div class='article-related__block'>
            <h2 class='article-related__title'>Полезные материалы по теме</h2>
            <ul class='article-related__list'>
              {readMoreLinks.map((item) => (
                <li>
                  <a class='article-related__list-link' href={item.href}>
                    <span class='article-related__arrow'>→</span>
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class='article-related__block'>
            <h2 class='article-related__title'>Перейти в раздел</h2>
            <ul class='article-related__chips'>
              {sectionLinks.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <div class='article-related__block'>
            <h2 class='article-related__title'>Популярные модели</h2>
            <ul class='article-related__chips'>
              {modelLinks.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </article>
    </div>
  </div>
</Layout>
