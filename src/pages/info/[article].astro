function getTopicBySlug(slug: string): Topic {
  if (/convektor|konvektor|convector|panoram|teplovaya-zavesa|220v|24v|kwh/.test(slug)) return "convector";
  if (/trubchat|tube|column|sekci|panelnyh|termostat|chistit/.test(slug)) return "columns";
  if (/chugun|retro|iron|lite|restavrats/.test(slug)) return "retro";
  if (/design|vertical|horizontal|tsvet|interer|colors|wall|kuhni|chernye|forma-trub/.test(slug)) return "design";
  if (/bezopasnost|vybor|oshibki|power|radiator-ne-greet|kreplenie|teplootdacha|heating/.test(slug)) return "safety";
  return "generic";
}

function normalizeText(value: string): string {
  return value
    .replace(/ё/gi, "е")
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/&[a-z]+;/gi, " ")
    .replace(/[—–−‑‒-]+/g, " ")
    .replace(/[`*_~]/g, " ")
    .replace(/[^\p{L}\p{N}\s]/gu, " ")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase();
}

function stemToken(token: string): string {
  if (token.length <= 5) return token;

  return token.replace(
    /(ами|ями|ого|ему|ому|ыми|ими|иях|иям|ием|ией|ах|ях|ов|ев|ом|ем|ой|ый|ий|ая|яя|ое|ее|ые|ие|ам|ям|ую|юю|а|я|ы|и|о|е|у|ю)$/u,
    "",
  );
}

function getCoreTokenSet(value: string): Set<string> {
  const stopwords = new Set([
    "и",
    "в",
    "во",
    "на",
    "по",
    "для",
    "с",
    "со",
    "к",
    "ко",
    "о",
    "об",
    "от",
    "до",
    "из",
    "у",
    "а",
    "но",
    "или",
    "что",
    "это",
    "как",
    "при",
    "их",
  ]);

  const tokens = normalizeText(value)
    .split(" ")
    .map((token) => token.trim())
    .filter(Boolean)
    .filter((token) => !stopwords.has(token))
    .map(stemToken);

  return new Set(tokens);
}

function isSoftDuplicateDashHeading(titleValue: string, headingValue: string): boolean {
  const hasDashInBoth = /[—–−‑‒-]/.test(titleValue) && /[—–−‑‒-]/.test(headingValue);
  if (!hasDashInBoth) return false;

  const normalizedTitle = normalizeText(titleValue);
  const normalizedHeading = normalizeText(headingValue);
  const firstTitleWord = normalizedTitle.split(" ")[0] ?? "";
  const firstHeadingWord = normalizedHeading.split(" ")[0] ?? "";

  if (!firstTitleWord || firstTitleWord !== firstHeadingWord) return false;

  const titleTokens = getCoreTokenSet(titleValue);
  const headingTokens = getCoreTokenSet(headingValue);
  if (titleTokens.size < 4 || headingTokens.size < 4) return false;

  let intersectionCount = 0;
  for (const token of titleTokens) {
    if (headingTokens.has(token)) intersectionCount += 1;
  }

  const minSetSize = Math.min(titleTokens.size, headingTokens.size);
  const overlapRatio = minSetSize > 0 ? intersectionCount / minSetSize : 0;

  return intersectionCount >= 3 && overlapRatio >= 0.55;
}

function isLikelyDuplicateTitleHeading(titleValue: string, headingValue: string): boolean {
  const normalizedTitle = normalizeText(titleValue);
  const normalizedHeading = normalizeText(headingValue);

  if (!normalizedTitle || !normalizedHeading) return false;
  if (normalizedTitle === normalizedHeading) return true;

  const [shorter, longer] =
    normalizedTitle.length <= normalizedHeading.length
      ? [normalizedTitle, normalizedHeading]
      : [normalizedHeading, normalizedTitle];

  if (longer.startsWith(shorter)) {
    const overlapRatio = shorter.length / longer.length;
    if (overlapRatio >= 0.72) return true;
  }

  return isSoftDuplicateDashHeading(titleValue, headingValue);
}

function getFirstHeadingFromBody(body: string): { level: number; text: string } | null {
  const lines = body.split("\n");

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (!line) continue;
    if (line.startsWith("import ") || line.startsWith("export ")) continue;

    const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
    if (headingMatch) {
      return {
        level: headingMatch[1].length,
        text: headingMatch[2].trim(),
      };
    }

    return null;
  }

  return null;
}

const topic = getTopicBySlug(article.slug);

const existingRelatedLinks = new Set<string>();
const readMoreLinks = [...relatedArticleSets[topic], ...relatedArticleSets.generic]
  .filter((candidate) => candidate.slug !== article.slug)
  .filter((candidate) => articleTitleBySlug.has(candidate.slug))
  .filter((candidate) => {
    if (existingRelatedLinks.has(candidate.slug)) return false;
    existingRelatedLinks.add(candidate.slug);
    return true;
  })
  .slice(0, 4)
  .map((candidate) => ({
    href: `/info/${candidate.slug}`,
    label: candidate.label ?? articleTitleBySlug.get(candidate.slug) ?? candidate.slug,
    description: articleTitleBySlug.get(candidate.slug) ?? "",
  }));

const sectionLinks = sectionLinkSets[topic];
const modelLinks = modelLinkSets[topic];
const endingCta = endingCtaByTopic[topic];

const firstBodyHeading = getFirstHeadingFromBody(article.body ?? "");
const shouldHideDuplicateIntroHeading =
  firstBodyHeading !== null &&
  (firstBodyHeading.level === 1 || firstBodyHeading.level === 2) &&
  isLikelyDuplicateTitleHeading(title, firstBodyHeading.text);

const crumbs = [
  { title: "Главная", url: "/" },
  { title: "Полезные материалы", url: "/info" },
  { title, url: `/info/${article.slug}` },
];
---

<Layout
  title={metaTitle || `${title} | VelarShop.ru`}
  description={metaDescription || short_description}
  breadcrumbs={crumbs}
  paddings={false}
>
