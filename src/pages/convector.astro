const convectorConfiguratorModels = preferredModelOrder
	.map(id => convectorConfiguratorMap.get(id))
	.filter((model): model is NonNullable<typeof model> => Boolean(model))
const defaultConvectorModelId = convectorConfiguratorModels.find(model => model.id === 'kwh')?.id ?? convectorConfiguratorModels[0]?.id ?? 'kwh'

