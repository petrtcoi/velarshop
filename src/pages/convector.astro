const convectorModels = preferredModelOrder
	.map(id => modelsJsonData.find(model => model.id === id))
	.filter(Boolean)
	.map(model => {
		const radiators = radiatorsJsonData.filter(radiator => radiator.model_id === model!.id)
		const prices = radiators.map(radiator => toNum(radiator.price)).filter(value => value > 0)
		const priceFrom = prices.length ? Math.min(...prices) : 0
		const copy = modelCopy[model!.id]

		return {
			id: model!.id,
			name: `Velar ${model!.name}`,
			fullName: `${model!.prefix} Velar ${model!.name}`,
			href: getModelSlug(model!),
			image: `/images/models/${model!.slug}/main.jpg`,
			priceFrom,
			description: copy.description,
			whenToChoose: copy.whenToChoose,
			useCase: copy.useCase,
			schemaDescription: copy.schemaDescription,
			cardSpecs: copy.cardSpecs,
			width: copy.width,
			height: copy.height,
			typeLabel: copy.typeLabel,
		}
	})

