---
import { Picture } from '@astrojs/image/components'
import Layout from '@shared/layouts/Layout.astro'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from './api/hero-configurator/[model].json'
import JsonLd from '../components/seo/JsonLd.astro'

const canonicalUrl = 'https://velarshop.ru/convector/'
const pageTitle = 'Внутрипольные конвекторы Velar — KWH, KWHV и KWHV 24V'
const pageDescription =
	'Внутрипольные конвекторы Velar для панорамных окон, квартир, домов и коммерческих помещений. Модели KWH, KWHV и KWHV 24V, естественная и принудительная конвекция, доставка по России.'

const breadcrumbs = [
	{ title: 'Главная', url: '/' },
	{ title: 'Внутрипольные конвекторы', url: '/convector' },
]

const convectorModels = [
	{
		id: 'kwh',
		name: 'Velar KWH',
		fullName: 'Внутрипольный конвектор Velar KWH',
		href: '/model/kwh',
		image: '/images/models/kwh/main.jpg',
		convectionType: 'Естественная конвекция',
		width: '150-420 мм',
		height: '65-140 мм',
		priceFrom: 8348,
		description: 'Естественная конвекция. Ширина 150-420 мм. Высота 65-140 мм.',
		useCase: 'Для спокойной тепловой завесы без вентиляторов и лишнего шума.',
	},
	{
		id: 'kwhv',
		name: 'Velar KWHV',
		fullName: 'Внутрипольный конвектор Velar KWHV',
		href: '/model/kwhv',
		image: '/images/models/kwhv/main.jpg',
		convectionType: 'Принудительная конвекция',
		width: '250-420 мм',
		height: '85-140 мм',
		priceFrom: 17582,
		description: 'Принудительная конвекция. Ширина 250-420 мм. Высота 85-140 мм.',
		useCase: 'Для панорамных окон, холодных зон и активного обогрева.',
	},
	{
		id: 'kwhv24',
		name: 'Velar KWHV 24V',
		fullName: 'Внутрипольный конвектор Velar KWHV 24V',
		href: '/model/kwhv24',
		image: '/images/models/kwhv24/main.jpg',
		convectionType: 'Принудительная конвекция, вентиляторы 24В',
		width: '200-420 мм',
		height: '85-140 мм',
		priceFrom: 27442,
		description: 'Принудительная конвекция. Вентиляторы 24В. Ширина 200-420 мм. Высота 85-140 мм.',
		useCase: 'Для проектов с низковольтными вентиляторами и гибким управлением.',
	},
]

const convectorModelOrder = ['kwh', 'kwhv', 'kwhv24']
const convectorConfiguratorMap = new Map(buildQuickConfiguratorModels({ type: 'convector' }).map(model => [model.id, model]))
const convectorConfiguratorModels = convectorModelOrder
	.map(id => convectorConfiguratorMap.get(id))
	.filter((model): model is NonNullable<typeof model> => Boolean(model))
const defaultConvectorModelId = convectorConfiguratorModels.find(model => model.id === 'kwh')?.id ?? convectorConfiguratorModels[0]?.id ?? 'kwh'
let initialConvectorDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultConvectorModelId },
	} as any)
	if (response.ok) initialConvectorDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload convector configurator model:', error)
}

function formatRub(value: number): string {
	return `${value.toLocaleString('ru-RU')} ₽`
}

const trustPoints = [
	['Для панорамных окон', 'создают тепловую завесу вдоль остекления'],
	['KWH и KWHV', 'естественная и принудительная конвекция'],
	['Низкий монтаж в пол', 'высота от 65 мм'],
	['Производство под заказ', 'срок 2-3 недели'],
]

const comparisonRows = [
	['KWH', 'естественная', 'когда достаточно спокойной тепловой завесы без вентиляторов', 'простая конструкция, тихая работа'],
	['KWHV', 'принудительная', 'когда нужны высокая мощность и активный обогрев у панорамных окон', 'вентиляторы, повышенная теплоотдача'],
	['KWHV 24V', 'принудительная 24V', 'когда важны низковольтные вентиляторы и гибкое управление', 'вентиляторы 24В, современная автоматика'],
]

const chooseItems = [
	['Оцените остекление', 'Чем больше площадь панорамных окон, тем важнее правильно рассчитать тепловую завесу.'],
	['Выберите тип конвекции', 'KWH работает за счет естественной конвекции. KWHV и KWHV 24V используют вентиляторы для более активного обогрева.'],
	['Подберите размеры', 'Важны длина, ширина и высота канала. Они зависят от ниши в полу и требуемой мощности.'],
	['Уточните теплопотери', 'Для точного подбора нужны площадь помещения, высота потолков, тип остекления и регион.'],
	['Выберите решетку', 'Решетка должна подходить по цвету, материалу и направлению укладки к напольному покрытию.'],
	['Продумайте обслуживание', 'К конвектору должен сохраняться доступ для чистки теплообменника, корпуса и вентиляторов.'],
]

const useCases = [
	['Панорамные окна', 'Создают тепловую завесу вдоль стекла и помогают снизить ощущение холода у остекления.'],
	['Балконные двери', 'Помогают компенсировать теплопотери в зоне выхода на балкон или террасу.'],
	['Частные дома', 'Подходят для гостиных, кухонь-гостиных и помещений с большими окнами.'],
	['Квартиры', 'Используются там, где обычный настенный радиатор мешает интерьеру или планировке.'],
	['Коммерческие помещения', 'Подходят для офисов, шоурумов, ресторанов, салонов и входных зон.'],
	['Дизайнерские интерьеры', 'Позволяют скрыть отопительный прибор в полу и сохранить чистую архитектуру пространства.'],
]

const benefits = [
	['Естественная и принудительная конвекция', 'Можно выбрать спокойную работу без вентиляторов или усиленный обогрев.'],
	['Для панорамного остекления', 'Конвекторы помогают создать тепловую завесу вдоль окон.'],
	['Широкий размерный ряд', 'Можно подобрать длину, ширину и высоту под проект.'],
	['Аккуратный монтаж в пол', 'Отопительный прибор не занимает стену и не мешает интерьеру.'],
	['Решетки под интерьер', 'Возможны разные варианты декоративных решеток под покрытие пола.'],
	['Производство под заказ', 'Подбор параметров под помещение, теплопотери и проект.'],
]

const mountItems = [
	'заранее подготовить нишу в полу',
	'учесть глубину корпуса и уровень чистового пола',
	'предусмотреть подключение к системе отопления',
	'для моделей с вентиляторами предусмотреть питание и управление',
	'обеспечить ровную установку корпуса',
	'согласовать расположение решетки с напольным покрытием',
]

const serviceItems = [
	'периодически очищать решетку',
	'убирать пыль внутри канала',
	'очищать теплообменник',
	'проверять вентиляторы в моделях KWHV и KWHV 24V',
	'сохранять доступ к корпусу после отделочных работ',
	'не закрывать решетку коврами или мебелью',
]

const orderSteps = [
	['01', 'Подберите модель', 'KWH, KWHV или KWHV 24V — в зависимости от остекления, мощности и требований к управлению.'],
	['02', 'Укажите параметры', 'Длина, ширина, высота, тип решетки, помещение, город доставки и особенности проекта.'],
	['03', 'Получите расчет', 'Менеджер уточнит детали, поможет подобрать мощность и подготовит стоимость.'],
	['04', 'Производство и доставка', 'Конвектор изготавливается под заказ и доставляется по России.'],
]

const usefulLinks = [
	['/info/panoramnie-okna', 'Конвекторы для панорамного остекления'],
	['/info/teplovaya-zavesa-u-panoramnyh-okon', 'Тепловая завеса у панорамных окон'],
	['/info/vnutripolnye-konvektory-podbor-i-montazh', 'Подбор и монтаж внутрипольных конвекторов'],
	['/info/kak-vybirat-vnutripolnye-konvektory', 'Как выбирать внутрипольные конвекторы: подробное руководство'],
	['/info/vnutripolnye-konvektory-prinuditelnaia-vs-estestvennaia-konvekciia', 'Внутрипольные конвекторы с принудительной вентиляцией vs естественная конвекция'],
	['/info/obsluzhivanie-vnutripolnyh-konvektorov', 'Обслуживание внутрипольных конвекторов и защита системы отопления от магнетита'],
	['/info/vnutripolnye-konvektory-s-ventilyatorom', 'Внутрипольные конвекторы с вентилятором - плюсы, минусы и когда выбирать'],
]

const deliveryItems = [
	['Доставка по России', 'Через транспортные компании, с отправкой до терминала или доставкой до двери в отдельных городах.'],
	['Жесткая упаковка', 'Груз отправляется в защитной упаковке и со страховкой, если услуга предусмотрена перевозчиком.'],
	['Удобная оплата', 'Банковский перевод, онлайн-оплата, QR-код, работа с физическими и юридическими лицами.'],
	['Под заказ', 'Для индивидуального производства заключается договор и вносится предоплата.'],
]

const faqItems = [
	['Чем внутрипольный конвектор отличается от обычного радиатора?', 'Внутрипольный конвектор монтируется в нишу пола и закрывается решеткой. Он не занимает стену и помогает создать тепловую завесу вдоль остекления.'],
	['Когда нужен конвектор с вентилятором?', 'Вентилятор нужен, когда требуется более высокая мощность, активный обогрев у панорамных окон или компенсация заметных теплопотерь.'],
	['Чем отличаются KWH, KWHV и KWHV 24V?', 'KWH работает без вентиляторов за счет естественной конвекции. KWHV использует вентиляторы. KWHV 24V — версия с низковольтными вентиляторами 24В и гибким управлением.'],
	['Подходит ли KWH для панорамных окон?', 'Да, если теплопотери умеренные и достаточно спокойной тепловой завесы. Для больших окон и холодных зон чаще рассматривают KWHV или KWHV 24V.'],
	['Что выбрать для частного дома с большими окнами?', 'Для частного дома с большим остеклением обычно стоит рассматривать модели с вентиляторами: KWHV или KWHV 24V. Точный выбор зависит от расчета теплопотерь.'],
	['Можно ли установить внутрипольный конвектор в квартире?', 'Да, если есть возможность подготовить нишу в полу и согласовать подключение. На этапе ремонта это сделать проще.'],
	['Какая высота конвектора нужна?', 'Высота зависит от глубины пола, нужной мощности и типа модели. У Velar есть решения высотой от 65 мм.'],
	['Как подобрать длину конвектора?', 'Длину подбирают по линии остекления, теплопотерям и доступной нише. Для точного подбора лучше отправить план помещения.'],
	['Нужно ли обслуживание?', 'Да. Нужно очищать решетку, корпус, теплообменник и проверять вентиляторы в моделях KWHV и KWHV 24V.'],
	['Можно ли заказать решетку под цвет пола?', 'Да, доступны разные варианты декоративных решеток. Подбор зависит от материала пола, цвета и задачи интерьера.'],
	['Сколько занимает производство?', 'Ориентировочный срок производства — 2-3 недели без учета доставки. Актуальные сроки уточняйте у менеджера.'],
	['Как получить точный расчет?', 'Отправьте размеры зоны установки, параметры помещения, город доставки и, если есть, план или фото. Менеджер подготовит расчет.'],
]

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: 'Внутрипольные конвекторы Velar',
		description: pageDescription,
		url: canonicalUrl,
		mainEntity: {
			'@type': 'ItemList',
			itemListElement: convectorModels.map((model, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				url: new URL(model.href, canonicalUrl).toString(),
				item: {
					'@type': 'Product',
					name: model.fullName,
					image: new URL(model.image, canonicalUrl).toString(),
					description: model.description,
					brand: { '@type': 'Brand', name: 'Velar' },
					category: 'Внутрипольные конвекторы',
					offers: {
						'@type': 'Offer',
						priceCurrency: 'RUB',
						price: model.priceFrom,
						availability: 'https://schema.org/InStock',
						url: new URL(model.href, canonicalUrl).toString(),
					},
				},
			})),
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map(([question, answer]) => ({
			'@type': 'Question',
			name: question,
			acceptedAnswer: { '@type': 'Answer', text: answer },
		})),
	},
]
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} breadcrumbs={breadcrumbs} paddings={false}>
	<JsonLd data={schema} />

	<section class='bg-white pb-12 pt-7 md:pb-16 xl:pb-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-[minmax(0,1fr)_220px_minmax(340px,390px)] lg:items-start xl:grid-cols-[minmax(0,1fr)_280px_minmax(360px,420px)] xl:px-8'>
			<div>
				<h1 class='max-w-4xl text-[38px] font-semibold leading-[0.98] tracking-tight text-neutral-950 md:text-[54px] xl:text-[64px]'>Внутрипольные конвекторы Velar</h1>
				<p class='mt-5 max-w-3xl text-[16px] leading-7 text-neutral-700 md:text-lg'>
					Внутрипольные конвекторы Velar для панорамных окон, квартир, частных домов и коммерческих помещений. Модели с естественной и принудительной конвекцией, широкий размерный ряд, аккуратная установка в пол и производство под заказ.
				</p>
				<div class='mt-7 flex flex-wrap gap-3'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>Получить расчет</a>
					<a href='#convector-models' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 px-5 text-sm font-semibold text-neutral-950 transition hover:border-red-700 hover:text-red-700'>Смотреть модели</a>
				</div>
				<div class='mt-8 grid gap-3 sm:grid-cols-2'>
					{trustPoints.map(([title, text]) => (
						<div class='border-t border-neutral-200 pt-3'>
							<div class='text-sm font-semibold text-neutral-950'>{title}</div>
							<div class='mt-1 text-sm leading-5 text-neutral-600'>{text}</div>
						</div>
					))}
				</div>
			</div>

			<div class='order-3 flex justify-center lg:order-none'>
				<Picture
					src='/images/convector/hero/top-view-convector.png'
					alt='Внутрипольный конвектор Velar вид сверху'
					title='Внутрипольный конвектор Velar вид сверху'
					loading='eager'
					aspectRatio='1:4'
					widths={[240, 360, 520]}
					width={360}
					height={1440}
					sizes='(max-width: 1024px) 240px, 280px'
					class='hero-product-image max-h-[360px] w-full object-contain md:max-h-[440px] lg:max-h-[560px]'
				/>
			</div>

			<div class='min-w-0'>
				<HeroQuickConfigurator
					client:load
					models={convectorConfiguratorModels}
					defaultModelId={defaultConvectorModelId}
					initialDetails={initialConvectorDetails}
					variant='category'
					title='Быстрый выбор'
				/>
			</div>
		</div>
	</section>

	<section id='convector-models' class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='max-w-3xl'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Модели внутрипольных конвекторов Velar</h2>
				<p class='mt-4 text-[15px] leading-6 text-neutral-600 md:text-base'>Три серии закрывают основные сценарии: естественная конвекция, принудительный обогрев и низковольтные вентиляторы 24В.</p>
			</div>
			<div class='mt-7 flex flex-col gap-4 md:flex-row md:flex-wrap md:justify-center md:gap-6'>
				{convectorModels.map((model, index) => (
					<article class='flex w-full flex-col rounded-[18px] border border-neutral-200 bg-white p-3.5 transition hover:border-neutral-300 hover:bg-neutral-50 md:max-w-[280px] md:p-4'>
						<a href={model.href} class='convector-model-image-wrapper flex h-[240px] w-full items-center justify-center overflow-hidden rounded-xl bg-white md:h-[240px] min-[900px]:h-[250px] min-[1280px]:h-[260px] min-[1440px]:h-[280px]'>
							<Picture
								src={model.image}
								alt={model.fullName}
								title={model.fullName}
								loading={index > 1 ? 'lazy' : 'eager'}
								aspectRatio='4:3'
								widths={[220, 320, 420]}
								width={260}
								height={195}
								sizes='(max-width: 640px) 100vw, (max-width: 1279px) 50vw, 25vw'
								class='convector-model-image block h-auto w-full max-w-full object-contain'
							/>
						</a>
						<h3 class='mt-3 text-[17px] font-semibold leading-tight text-neutral-950 min-[1280px]:text-lg'>{model.name}</h3>
						<p class='mt-1.5 text-[14px] leading-[1.42] text-neutral-600'>{model.useCase}</p>
						<div class='mt-3 grid gap-1.5 border-t border-neutral-200 pt-3 text-[13px] leading-5 text-neutral-700'>
							<div><span class='text-neutral-500'>Тип:</span> {model.convectionType}</div>
							<div><span class='text-neutral-500'>Ширина:</span> {model.width}</div>
							<div><span class='text-neutral-500'>Высота:</span> {model.height}</div>
						</div>
						<div class='mt-3 text-base font-semibold text-neutral-950'>от {formatRub(model.priceFrom)}</div>
						<div class='mt-auto pt-3'>
							<a href={model.href} class='inline-flex h-9 w-full items-center justify-center rounded-lg border border-neutral-300 bg-white px-3 text-[13px] font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-white'>
								Подробнее
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Чем отличаются KWH, KWHV и KWHV 24V</h2>
			<div class='mt-7 overflow-x-auto rounded-lg border border-neutral-200 bg-white'>
				<table class='min-w-[820px] w-full text-left text-sm'>
					<thead class='bg-neutral-100 text-xs uppercase text-neutral-500'>
						<tr>
							<th class='px-4 py-2.5 font-semibold'>Модель</th>
							<th class='px-4 py-2.5 font-semibold'>Тип конвекции</th>
							<th class='px-4 py-2.5 font-semibold'>Когда выбрать</th>
							<th class='px-4 py-2.5 font-semibold'>Особенности</th>
						</tr>
					</thead>
					<tbody class='divide-y divide-neutral-200 text-neutral-700'>
						{comparisonRows.map(row => (
							<tr>
								{row.map((cell, index) => (
									<td class:list={['px-4 py-3', index === 0 ? 'font-semibold text-neutral-950' : '']}>{cell}</td>
								))}
							</tr>
						))}
					</tbody>
				</table>
			</div>
			<p class='mt-5 max-w-4xl text-[15px] leading-6 text-neutral-700 md:text-base'>
