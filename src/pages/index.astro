---
import Layout from '@shared/layouts/Layout.astro'
import BestSellers from '@widgets/pageMain/BestSellers.astro'
import AboutVelar from '@widgets/pageMain/AboutVelar.astro'
import BuyFromUs from '@widgets/pageMain/BuyFromUs.astro'
import Docs from '@widgets/pageMain/Docs.astro'
import Hero from '@widgets/pageMain/Hero.astro'
import HowToOrder from '@widgets/pageMain/HowToOrder.astro'
import News from '@widgets/pageMain/News.astro'
import QuickChoice from '@widgets/pageMain/QuickChoice.astro'
import ScenarioCta from '@widgets/pageMain/ScenarioCta.astro'
import WhyVelar from '@widgets/pageMain/WhyVelar.astro'
---

<Layout
	title='Радиаторы Velar — магазин VelarShop'
	description='Радиаторы Velar для квартир, домов и дизайн-проектов. Дизайн-радиаторы, трубчатые, ретро-модели и конвекторы. Подбор, расчет, гарантия и доставка по России.'
	paddings={false}
>
	<Fragment slot='head'>
		<link rel='preload' as='image' href='/main/hero.avif' type='image/avif' fetchpriority='high' />
	</Fragment>
	<Hero />
	<ScenarioCta />
	<BestSellers />
	<QuickChoice />
	<AboutVelar />
	<WhyVelar />
	<Docs />
	<BuyFromUs />
	<HowToOrder />
	<News />
</Layout>
