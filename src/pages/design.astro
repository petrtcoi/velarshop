---
import Picture from '@shared/components/Picture.astro';
import Layout from '@shared/layouts/Layout.astro'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import JsonLd from '../components/seo/JsonLd.astro'
import DesignSeriesGrid from '../components/design/DesignSeriesGrid.astro'
import DesignUsefulLinks from '../components/design/DesignUsefulLinks.astro'
import DesignFaq from '../components/design/DesignFaq.astro'
import { designSeries, getDesignSeriesBySlug, type DesignSeries } from '../components/design/designData'
import { get as getHeroConfiguratorData } from './api/hero-configurator/[model].json'
import { getCategorySeo } from '../lib/seo/categorySeo'

type LinkItem = {
	href: string
	label: string
}

const breadcrumbs = [{ title: 'Главная', url: '/' }, { title: 'Дизайн-радиаторы', url: '/design' }]

const designConfiguratorModels = buildQuickConfiguratorModels({ type: 'design' })
const defaultDesignModelId = designConfiguratorModels.find(model => model.id === 'p30v')?.id ?? designConfiguratorModels[0]?.id ?? 'p30v'
let initialDesignDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultDesignModelId },
	} as any)
	if (response.ok) initialDesignDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload design configurator model:', error)
}

function getSeries(slug: string): DesignSeries {
	const series = getDesignSeriesBySlug(slug)
	if (!series) throw new Error(`Design series not found: ${slug}`)
	return series
}

function createLink(href: string | undefined, label: string): LinkItem | null {
	return href ? { href, label } : null
}

function isLinkItem(item: LinkItem | null): item is LinkItem {
	return Boolean(item)
}

const p30 = getSeries('p30')
const p60 = getSeries('p60')
const q40 = getSeries('q40')
const q60 = getSeries('q60')
const q80 = getSeries('q80')
const r32 = getSeries('r32')
const r42 = getSeries('r42')
const r89 = getSeries('r89')
const s = getSeries('s')
const sp = getSeries('sp')
const rt1 = getSeries('rt1')
const qt1 = getSeries('qt1')
const rt2 = getSeries('rt2')
const qt2 = getSeries('qt2')

const chipItems = [
	{ label: 'Вертикальные', href: '/design/vertikalnye' },
	{ label: 'Горизонтальные', href: '/design/gorizontalnye' },
	{ label: 'Плоский P', href: '#series-p30' },
	{ label: 'Квадратный Q', href: '#series-q40' },
	{ label: 'Круглый R', href: '#series-r32' },
	{ label: 'Овальный S', href: '#series-s' },
	{ label: 'В цвет RAL', href: '#design-calculator' },
	{ label: 'С ТЭНом', href: '#design-calculator' },
] as const

const quickChoiceCards = [
	{
		title: 'Вертикальный радиатор на узкую стену',
		text: 'Для простенка, прихожей и акцентной стены.',
		href: '/design/vertikalnye',
		cta: 'Смотреть вертикальные',
		links: [
			createLink(p30.verticalModel?.href, p30.verticalModel?.name ?? 'P 30 V'),
			createLink(q40.verticalModel?.href, q40.verticalModel?.name ?? 'Q 40 V'),
			createLink(r32.verticalModel?.href, r32.verticalModel?.name ?? 'R 32 V'),
			createLink('/collections/verticalnye-radiatory-1800-mm', 'Подборка 1800 мм'),
		].filter(isLinkItem),
	},
	{
		title: 'Горизонтальный радиатор под окно',
		text: 'Для подоконников, низких зон и длинных стен.',
		href: '/design/gorizontalnye',
		cta: 'Смотреть горизонтальные',
		links: [
			createLink(p30.horizontalModel?.href, p30.horizontalModel?.name ?? 'P 30 H'),
			createLink(q40.horizontalModel?.href, q40.horizontalModel?.name ?? 'Q 40 H'),
			createLink(r32.horizontalModel?.href, r32.horizontalModel?.name ?? 'R 32 H'),
		].filter(isLinkItem),
	},
	{
		title: 'Спокойный плоский профиль',
		text: 'Для спокойного минимализма без лишней графики.',
		href: p30.href,
		cta: 'Смотреть P-серии',
		links: [
			createLink(p30.href, 'Velar P30'),
			createLink(p60.href, 'Velar P60'),
		].filter(isLinkItem),
	},
	{
		title: 'Четкая квадратная геометрия',
		text: 'Для строгой геометрии, лофта и современных пространств.',
		href: q40.href,
		cta: 'Смотреть Q-серии',
		links: [
			createLink(q40.href, 'Velar Q40'),
			createLink(q60.href, 'Velar Q60'),
			createLink(q80.href, 'Velar Q80'),
		].filter(isLinkItem),
	},
	{
		title: 'Мягкий круглый профиль',
		text: 'Для жилых интерьеров и более мягкого силуэта.',
		href: r32.href,
		cta: 'Смотреть R-серии',
		links: [
			createLink(r32.href, 'Velar R32'),
			createLink(r42.href, 'Velar R42'),
			createLink(r89.href, 'Velar R89'),
		].filter(isLinkItem),
	},
	{
		title: 'Радиатор в цвет RAL',
		text: 'Под интерьер, стены, мебель или как контрастный акцент.',
		href: '#design-calculator',
		cta: 'Подобрать цвет',
		links: [
			createLink('/info/tsvet-interera-i-radiator', 'Статья о цвете в интерьере'),
			createLink('/request', 'Запрос на подбор'),
		].filter(isLinkItem),
	},
	{
		title: 'Радиатор с ТЭНом',
		text: 'Для межсезонья и задач с дополнительным источником тепла.',
		href: '#design-calculator',
		cta: 'Уточнить по ТЭНу',
		links: [
			createLink('/request', 'Запрос на проверку'),
			createLink(s.href, 'Velar S'),
			createLink(sp.href, 'Velar SP'),
		].filter(isLinkItem),
	},
]

const seriesChooserRows = [
	{
		task: 'спокойный минимализм',
		series: [
			createLink(p30.href, 'P30'),
			createLink(p60.href, 'P60'),
		].filter(isLinkItem),
		why: 'плоский профиль выглядит аккуратно и не спорит с интерьером',
	},
	{
		task: 'строгая современная геометрия',
		series: [
			createLink(q40.href, 'Q40'),
			createLink(q60.href, 'Q60'),
			createLink(q80.href, 'Q80'),
		].filter(isLinkItem),
		why: 'квадратный профиль подходит для минимализма, лофта и коммерческих пространств',
	},
	{
		task: 'мягкий жилой интерьер',
		series: [
			createLink(r32.href, 'R32'),
			createLink(r42.href, 'R42'),
			createLink(s.href, 'S'),
		].filter(isLinkItem),
		why: 'круглая и овальная форма выглядит менее жестко',
	},
	{
		task: 'сильный интерьерный акцент',
		series: [
			createLink(r89.href, 'R89'),
			createLink(q80.href, 'Q80'),
			createLink(rt2.href, 'RT2'),
			createLink(qt2.href, 'QT2'),
		].filter(isLinkItem),
		why: 'крупный профиль и вертикальный формат делают радиатор заметным объектом',
	},
	{
		task: 'узкая стена или простенок',
		series: [
			createLink(p30.verticalModel?.href, p30.verticalModel?.name ?? 'P 30 V'),
			createLink(q40.verticalModel?.href, q40.verticalModel?.name ?? 'Q 40 V'),
			createLink(r32.verticalModel?.href, r32.verticalModel?.name ?? 'R 32 V'),
			createLink(rt1.href, 'RT1'),
			createLink(qt1.href, 'QT1'),
		].filter(isLinkItem),
		why: 'вертикальный радиатор сохраняет полезную ширину стены',
	},
	{
		task: 'установка под окно',
		series: [
			createLink(p30.horizontalModel?.href, p30.horizontalModel?.name ?? 'P 30 H'),
			createLink(q40.horizontalModel?.href, q40.horizontalModel?.name ?? 'Q 40 H'),
			createLink(r32.horizontalModel?.href, r32.horizontalModel?.name ?? 'R 32 H'),
			createLink(s.horizontalModel?.href, s.horizontalModel?.name ?? 'S H'),
		].filter(isLinkItem),
		why: 'горизонтальная версия работает в привычной зоне под окном',
	},
]

const fitGoodItems = [
	'нужен вертикальный радиатор на узкую стену или простенок;',
	'нужен горизонтальный радиатор под окно;',
	'радиатор должен быть в цвет стены, мебели или оконных рам;',
	'хочется сделать радиатор интерьерным акцентом;',
	'нужен профиль P, Q, R или S под стиль проекта;',
	'важно согласовать мощность, размеры, цвет и подключение заранее;',
	'требуется радиатор под проект с визуализациями или чертежами.',
]

const chooseAnotherItems = [
	{
		href: '/columns',
		text: 'если нужен более простой и спокойный стальной секционный радиатор - смотрите трубчатые радиаторы;',
	},
	{
		href: '/retro',
		text: 'если нужен чугун, патина и исторический стиль - смотрите ретро-радиаторы;',
	},
	{
		href: '/convector',
		text: 'если отопление нужно скрыть в полу - смотрите внутрипольные конвекторы;',
	},
	{
		href: '/floor',
		text: 'если радиатор должен стоять перед панорамным окном без монтажа в пол - смотрите напольные радиаторы;',
	},
	{
		href: '/columns',
		text: 'если нужен самый дешевый типовой прибор, дизайн-радиатор может быть избыточным.',
	},
]

const chooseSections = [
	['По ориентации', 'Вертикальные модели подходят для узких стен, простенков, прихожих и акцентных зон. Горизонтальные чаще используют под окнами, в кухнях-гостиных и вдоль стен, где нужна привычная линия отопления.'],
	['По форме профиля', 'Плоский P выглядит спокойнее, квадратный Q дает строгую современную геометрию, круглый R смягчает силуэт, овальный S подходит для более плавных интерьеров.'],
	['По визуальной роли', 'Если радиатор должен быть почти незаметным, выбирайте спокойный профиль и цвет стены. Если радиатор нужен как акцент, смотрите крупные профили, вертикальные версии и контрастные цвета RAL.'],
	['По мощности', 'Мощность зависит не только от площади комнаты, но и от высоты потолков, остекления, теплопотерь, температурного графика и места установки. Для точного расчета лучше отправить параметры помещения.'],
	['По цвету', 'Радиатор можно сделать белым, графитовым, черным, в цвет стены, под мебель или как акцент. Для дизайн-проекта лучше заранее согласовать RAL-номер.'],
	['По подключению', 'Подключение нужно согласовать до отделочных работ. Если трубы уже выведены, радиатор подбирают под существующую схему. Если проект новый, можно заранее выбрать более аккуратный вариант подключения.'],
	['По ТЭНу', 'ТЭН может быть полезен для межсезонья, ванной, прихожей или помещения, где нужен дополнительный источник тепла. Возможность установки зависит от модели, подключения и задач проекта.'],
] as const

const orderSteps = [
	['01. Отправьте задачу', 'Укажите помещение, размеры стены или окна, город, желаемую серию, ориентацию и цвет. Можно приложить фото, план или визуализацию.'],
	['02. Получите подбор серии', 'Менеджер предложит подходящие серии Velar: P, Q, R, S, вертикальное или горизонтальное исполнение, спокойный или акцентный вариант.'],
	['03. Рассчитайте мощность', 'Проверим нужную теплоотдачу с учетом площади, остекления, высоты потолков и режима отопления.'],
	['04. Согласуйте цвет и подключение', 'Подберем цвет RAL, тип подключения, возможность ТЭНа и дополнительные параметры.'],
	['05. Получите цену и условия оплаты', 'После согласования конфигурации менеджер подтвердит стоимость, срок производства, документы и способ оплаты.'],
	['06. Производство и доставка', 'После оплаты заказ уходит в производство или резервируется, если подходящий вариант есть в наличии. Доставка выполняется по России.'],
] as const

const benefitItems = [
	['Вертикальные и горизонтальные модели', 'Можно выбрать вертикальное исполнение для узкой стены или горизонтальное для зоны под окном.'],
	['Профили P, Q, R, S', 'Плоские, квадратные, круглые и овальные профили дают разный визуальный характер - от спокойного минимализма до акцентного объекта.'],
	['Цвета RAL', 'Радиатор можно сделать в цвет стены, мебели, оконных рам или использовать как контрастный элемент.'],
	['Возможность ТЭНа', 'Для некоторых задач можно рассмотреть вариант с ТЭНом - для межсезонья или дополнительного отопления.'],
	['Подбор мощности', 'Мощность подбирается под помещение, теплопотери, остекление и температурный режим системы.'],
	['Производство и доставка', 'Радиаторы изготавливаются под параметры заказа, а доставка выполняется по России.'],
] as const

const galleryImages = [
	['/images/articles/design.jpg', 'Дизайн-радиатор Velar в современном интерьере'],
	['/images/articles/vertical-designer-radiators.jpg', 'Вертикальный дизайнерский радиатор Velar'],
	['/images/articles/horizontal-designer-radiators.jpg', 'Горизонтальный дизайн-радиатор Velar под окном'],
	['/images/articles/colors.jpg', 'Дизайн-радиаторы Velar в цветах RAL'],
] as const

const faqItems: Array<[string, string]> = [
	['Чем дизайн-радиатор отличается от обычного радиатора?', 'Дизайн-радиатор выполняет ту же отопительную задачу, но подбирается еще и как видимый элемент интерьера: по форме профиля, ориентации, цвету, размеру и способу размещения. Его выбирают, когда радиатор должен выглядеть лучше обычной батареи и соответствовать дизайн-проекту.'],
	['Какие дизайн-радиаторы Velar бывают?', 'В ассортименте есть вертикальные и горизонтальные модели с плоским, квадратным, круглым и овальным профилем. Серии P выглядят спокойнее, Q дают строгую геометрию, R - мягкий круглый силуэт, S и SP - овальную форму.'],
	['Можно ли заказать радиатор в цвет RAL?', 'Да, дизайн-радиаторы Velar можно окрашивать в цвета палитры RAL, чтобы подобрать прибор под стены, мебель, оконные рамы или сделать его акцентом. Для дизайн-проекта лучше заранее указать RAL-номер.'],
	['Что выбрать: вертикальный или горизонтальный радиатор?', 'Вертикальный радиатор выбирают для узких стен, простенков, прихожих и интерьерных акцентов. Горизонтальный удобен под окнами, в низких зонах и там, где важно сохранить привычную линию отопления.'],
	['Как рассчитать мощность дизайн-радиатора?', 'Мощность рассчитывают по площади, высоте потолков, теплопотерям, остеклению и режиму системы отопления. Для точного подбора лучше отправить план помещения, размеры зоны установки и желаемую серию.'],
	['Можно ли заказать расчет по дизайн-проекту?', 'Да, можно отправить план, визуализацию или фото помещения. Менеджер поможет подобрать серию, ориентацию, размер, цвет, подключение и мощность под проект.'],
	['Какой профиль выбрать: P, Q, R или S?', 'P выбирают для спокойного плоского минимализма, Q - для строгой квадратной геометрии, R - для более мягкого круглого силуэта, S и SP - для овальной формы без резких линий. Если нужен сильный акцент, смотрите крупные профили Q80 или R89.'],
	['Какой дизайн-радиатор выбрать на узкую стену?', 'Для узкой стены чаще выбирают вертикальные модели: P30 V, Q40 V, R32 V, RT1 или QT1. Они занимают меньше ширины и могут работать как интерьерный акцент.'],
	['Какой дизайн-радиатор выбрать под окно?', 'Под окно обычно выбирают горизонтальные исполнения: P30 H, Q40 H, R32 H или S H. Конкретная серия зависит от высоты подоконника, нужной мощности, стиля интерьера и схемы подключения.'],
	['Можно ли поставить ТЭН в дизайн-радиатор?', 'Возможность установки ТЭНа зависит от модели, подключения и задачи. ТЭН может быть полезен для межсезонья или дополнительного отопления, но его нужно согласовать до заказа.'],
	['Что нужно отправить для расчета?', 'Для расчета желательно отправить город, помещение, размеры стены или окна, площадь, высоту потолка, фото места установки, желаемую серию, цвет RAL и информацию по подключению. Если есть дизайн-проект, приложите план или визуализацию.'],
]

const seo = getCategorySeo({
	category: {
		slug: 'design',
		url: '/design',
		name: 'Дизайн-радиаторы',
		h1: 'Дизайн-радиаторы отопления Velar',
		seoTitle: 'Дизайнерские радиаторы Velar - вертикальные и горизонтальные модели',
		seoDescription:
			'Дизайн-радиаторы Velar для квартиры, дома и интерьера. Вертикальные и горизонтальные модели, профили P, Q, R, S, цвета RAL, расчет и доставка по России.',
		ogTitle: 'Дизайнерские радиаторы Velar - вертикальные и горизонтальные модели',
		ogDescription:
			'Дизайн-радиаторы Velar для квартиры, дома и интерьера: вертикальные и горизонтальные модели, профили P, Q, R, S, цвета RAL и подбор под проект.',
		ogImage: '/images/design/hero/vertical-design-radiator.jpg',
		ogImageAlt: 'Дизайнерские радиаторы Velar в интерьере',
		breadcrumbs,
		itemListName: 'Серии дизайнерских радиаторов Velar',
		products: designSeries.map(series => ({
			name: series.title,
			url: series.href,
		})),
		productOffers: designSeries.map(series => ({
			name: series.title,
			url: series.href,
			image: series.image,
			description: series.description,
			category: 'Дизайн-радиаторы',
			lowPrice: series.priceFrom,
			availability: 'https://schema.org/PreOrder',
		})),
		faq: faqItems.map(([question, answer]) => ({
			question,
			answer,
		})),
	},
})
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalUrl={seo.canonicalUrl}
	robots={seo.robots}
	ogType='website'
	ogTitle={seo.ogTitle}
	ogDescription={seo.ogDescription}
	ogUrl={seo.canonicalUrl}
	ogImageUrl={seo.ogImage}
	ogImageAlt={seo.ogImageAlt}
	twitterCard='summary_large_image'
	twitterTitle={seo.twitterTitle}
	twitterDescription={seo.twitterDescription}
	twitterImage={seo.twitterImage}
	twitterImageAlt={seo.twitterImageAlt}
	breadcrumbs={breadcrumbs}
	disableBreadcrumbJsonLd={true}
	paddings={false}
>
	<JsonLd data={seo.jsonLd} />

	<section class='border-b border-neutral-200 bg-white'>
		<div class='mx-auto grid max-w-[1240px] gap-7 px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:gap-8 min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(200px,280px)_minmax(360px,420px)] min-[1250px]:items-center min-[1250px]:gap-10 xl:px-8 xl:py-12'>
			<div class='min-w-0'>
				<h1 class='max-w-[760px] text-[34px] font-semibold leading-[1.04] tracking-tight text-neutral-950 md:text-[42px] min-[1250px]:text-[56px]'>
					Дизайн-радиаторы отопления Velar
				</h1>
