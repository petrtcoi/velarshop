---
import Layout from '@shared/layouts/Layout.astro'
import Breadcrumbs from '@widgets/breadcrumbs/Breadcrumbs.astro';
import BuyerInfo from '@widgets/buyerInfo/BuyerInfo.astro'
import ModelList from '@widgets/ModelList.astro'

const crumbs = [
	{title: 'Главная', url: '/'},
	{title: 'Дизайн-радиаторы', url: '/design'},
]
---

<Layout
	title='Дизайн-радиаторы Velar | полный каталог | VelarShop.ru'
	description='Каталог дизайн-радиаторов Velar: вертикальные и горизонтальные модели, подбор размеров и конфигураций, доставка по России.'
>
<Breadcrumbs items={crumbs} />

	<h1 class='text-3xl font-bold mt-7 md:mt-5'>Радиаторы Velar дизайнерские — каталог</h1>
	<div class='text-sm max-w-xl mt-3 leading-6'>
		В каталоге представлены дизайнерские радиаторы Velar. Поможем подобрать
		модель по размерам, мощности и типу подключения.
	</div>

	<ModelList type='design' />

	<div class='mt-[40px] text-xs font-light max-w-[500px]'>
		<sup>*</sup> Сроки заказа и доставки зависят от модели, комплектации и
		выбранного цвета. Актуальные сроки уточняйте у менеджера.
	</div>

			<section
  class="justify-center max-w-6xl mx-auto px-5 md:px-10 mt-20"
>
	<h2 class="text-3xl font-light text-left">Полезные материалы</h2>
		<div class="mt-2 text-sm leading-relaxed">
			<ul class="list-disc list-outside pl-4">
				<li>
					<a href="/info/wall" class='font-normal underline hover:no-underline'>
						Настенные дизайнерские радиаторы отопления
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/power" class='font-normal underline hover:no-underline'>
						Как определить требуемую мощность радиатора
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/vertical-designer-radiators" class='font-normal underline hover:no-underline'>
						Вертикальные дизайнерские радиаторы: экономия места и стиль
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/horizontal-designer-radiators" class='font-normal underline hover:no-underline'>
						Горизонтальные дизайн-радиаторы: где использовать лучше
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/forma-trub-dizayn-radiatorov" class='font-normal underline hover:no-underline'>
						Конструкция труб радиаторов
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/oshibki-pri-vybore-radiatorov" class='font-normal underline hover:no-underline'>
						Ошибки при выборе радиаторов отопления
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/bezopasnost-radiatorov-dlya-detej" class='font-normal underline hover:no-underline'>
						Безопасность радиаторов в доме
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/tsvet-interera-i-radiator" class='font-normal underline hover:no-underline'>
						Что говорит цвет интерьера о вас и как выбрать дизайнерский радиатор под стиль
					</a>
				</li>
				<li class="mt-1">
					<a href="/info/kak-podobrat-radiatory-dlya-kuhni" class='font-normal underline hover:no-underline'>
						Как подобрать радиаторы для кухни: советы по выбору
					</a>
				</li>
			</ul>
		</div>
	</section>

	<BuyerInfo productTitle='дизайн-радиаторы Velar' />
</Layout>
