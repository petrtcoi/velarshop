---
import { Picture } from '@astrojs/image/components'
import Layout from '@shared/layouts/Layout.astro'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import JsonLd from '../components/seo/JsonLd.astro'
import DesignSeriesGrid from '../components/design/DesignSeriesGrid.astro'
import DesignUsefulLinks from '../components/design/DesignUsefulLinks.astro'
import DesignFaq from '../components/design/DesignFaq.astro'
import { designSeries, formatRub } from '../components/design/designData'
import { get as getHeroConfiguratorData } from './api/hero-configurator/[model].json'
import { getCategorySeo } from '../lib/seo/categorySeo'

const breadcrumbs = [{ title: 'Главная', url: '/' }, { title: 'Дизайн-радиаторы', url: '/design' }]

const designConfiguratorModels = buildQuickConfiguratorModels({ type: 'design' })
const defaultDesignModelId = designConfiguratorModels.find(model => model.id === 'p30v')?.id ?? designConfiguratorModels[0]?.id ?? 'p30v'
let initialDesignDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultDesignModelId },
	} as any)
	if (response.ok) initialDesignDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload design configurator model:', error)
}

const chooseItems = [
	['по ориентации', 'Вертикальные модели подходят для узких простенков и акцентных стен. Горизонтальные чаще используют под окнами и в низких зонах.'],
	['по высоте', 'Высота влияет на визуальный силуэт, место установки и тепловую отдачу.'],
	['по форме профиля', 'Плоский P, квадратный Q, круглый R и овальный S дают разный характер интерьера.'],
	['по мощности', 'Мощность подбирают по теплопотерям помещения, площади остекления и режиму отопления.'],
	['по месту установки', 'Для спальни, гостиной, кухни, прихожей и коммерческих зон подходят разные форматы.'],
	['по цвету', 'Радиатор можно сделать нейтральным или акцентным за счет цвета RAL.'],
	['по подключению', 'Вариант подключения лучше согласовать до отделочных работ и монтажа труб.'],
]

const benefits = [
	'горизонтальные и вертикальные модели',
	'рабочее давление до 16 атм',
	'возможно подключение ТЭНа',
	'окраска в цвета RAL',
	'производство под заказ',
	'доставка по России',
]

const galleryImages = [
	['/images/articles/design.jpg', 'Дизайн-радиатор Velar в современном интерьере'],
	['/images/articles/vertical-designer-radiators.jpg', 'Вертикальный дизайнерский радиатор Velar'],
	['/images/articles/horizontal-designer-radiators.jpg', 'Горизонтальный дизайн-радиатор Velar под окном'],
	['/images/articles/colors.jpg', 'Дизайн-радиаторы Velar в цветах RAL'],
]

const faqItems: Array<[string, string]> = [
	['Чем дизайн-радиатор отличается от обычного радиатора?', 'Дизайн-радиатор выполняет ту же отопительную задачу, но подбирается еще и как видимый элемент интерьера: по форме профиля, ориентации, цвету, размеру и способу размещения.'],
	['Какие дизайн-радиаторы Velar бывают?', 'В ассортименте есть вертикальные и горизонтальные модели с плоским, квадратным, круглым и овальным профилем. Конкретные исполнения доступны на страницах серий и товарных страницах.'],
	['Можно ли заказать радиатор в цвет RAL?', 'Да, дизайн-радиаторы Velar можно окрашивать в цвета палитры RAL, чтобы подобрать прибор под стены, мебель, оконные рамы или сделать его акцентом.'],
	['Что выбрать: вертикальный или горизонтальный радиатор?', 'Вертикальный радиатор выбирают для узких стен, простенков и интерьерных акцентов. Горизонтальный удобен под окнами, в низких зонах и там, где важно сохранить привычную линию отопления.'],
	['Как рассчитать мощность дизайн-радиатора?', 'Мощность рассчитывают по площади, теплопотерям, остеклению и режиму системы отопления. Для точного подбора лучше отправить план помещения или размеры зоны установки.'],
	['Можно ли заказать расчет по дизайн-проекту?', 'Да, можно отправить план, визуализацию или фото помещения. Менеджер поможет подобрать серию, ориентацию, размер, цвет и подключение.'],
]

const seo = getCategorySeo({
	category: {
		slug: 'design',
		url: '/design',
		name: 'Дизайн-радиаторы',
		h1: 'Дизайн-радиаторы отопления Velar',
		seoTitle: 'Дизайнерские радиаторы Velar — вертикальные и горизонтальные модели',
		seoDescription:
			'Дизайнерские радиаторы Velar для квартир, домов и интерьеров: вертикальные и горизонтальные модели, разные профили, цвета RAL, подбор и доставка по России.',
		ogTitle: 'Дизайнерские радиаторы Velar — каталог моделей',
		ogDescription:
			'Вертикальные и горизонтальные дизайн-радиаторы Velar: разные профили, цвета RAL, подбор мощности и доставка по России.',
		ogImage: '/images/design/hero/vertical-design-radiator.jpg',
		ogImageAlt: 'Дизайнерские радиаторы Velar в интерьере',
		breadcrumbs,
		itemListName: 'Серии дизайнерских радиаторов Velar',
		products: designSeries.map(series => ({
			name: series.title,
			url: series.href,
		})),
		faq: faqItems.map(([question, answer]) => ({
			question,
			answer,
		})),
	},
})
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalUrl={seo.canonicalUrl}
	robots={seo.robots}
	ogType='website'
	ogTitle={seo.ogTitle}
	ogDescription={seo.ogDescription}
	ogUrl={seo.canonicalUrl}
	ogImageUrl={seo.ogImage}
	ogImageAlt={seo.ogImageAlt}
	twitterCard='summary_large_image'
	twitterTitle={seo.twitterTitle}
	twitterDescription={seo.twitterDescription}
	twitterImage={seo.twitterImage}
	twitterImageAlt={seo.twitterImageAlt}
	breadcrumbs={breadcrumbs}
	disableBreadcrumbJsonLd={true}
	paddings={false}
>
	<JsonLd data={seo.jsonLd} />

	<section class='border-b border-neutral-200 bg-white'>
		<div class='mx-auto grid max-w-[1240px] gap-7 px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:gap-8 min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(200px,280px)_minmax(360px,420px)] min-[1250px]:items-center min-[1250px]:gap-10 xl:px-8 xl:py-12'>
			<div class='min-w-0'>
				<h1 class='max-w-[680px] text-[34px] font-semibold leading-[1.04] tracking-tight text-neutral-950 md:text-[42px] min-[1250px]:text-[56px]'>
					Дизайн-радиаторы отопления Velar
				</h1>
				<p class='mt-5 max-w-[620px] text-sm leading-6 text-neutral-700 md:text-base md:leading-7'>
					Дизайнерские радиаторы Velar для квартир, домов и современных интерьеров. Вертикальные и горизонтальные модели, разные формы профиля, цвета RAL, подбор под помещение и дизайн-проект.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>Получить расчет</a>
					<a href='#design-series' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>Смотреть модели</a>
				</div>
			</div>

			<div class='hidden justify-center min-[1250px]:flex min-[1250px]:items-center'>
				<Picture
					src='/images/design/hero/vertical-design-radiator.jpg'
					alt='Вертикальный дизайн-радиатор Velar'
					title='Вертикальный дизайн-радиатор Velar'
					loading='eager'
					aspectRatio='1:4'
					widths={[220, 320, 440]}
					width={320}
					height={1280}
					sizes='260px'
					class='h-auto max-h-[560px] w-full max-w-[260px] object-contain'
				/>
			</div>

			<div class='grid min-w-0 gap-5 sm:grid-cols-[150px_minmax(0,1fr)] sm:items-start md:grid-cols-[180px_minmax(0,1fr)] min-[900px]:col-start-2 min-[900px]:block min-[1250px]:col-start-3'>
				<div class='hidden justify-center sm:flex min-[900px]:hidden'>
					<Picture
						src='/images/design/hero/vertical-design-radiator.jpg'
						alt='Вертикальный дизайн-радиатор Velar'
						title='Вертикальный дизайн-радиатор Velar'
						loading='lazy'
						aspectRatio='1:4'
						widths={[180, 260, 360]}
						width={260}
						height={1040}
						sizes='180px'
						class='h-auto max-h-[430px] w-full max-w-[180px] object-contain'
					/>
				</div>

				<HeroQuickConfigurator
					client:load
					models={designConfiguratorModels}
					defaultModelId={defaultDesignModelId}
					initialDetails={initialDesignDetails}
					variant='category'
					title='Быстрый выбор'
				/>
			</div>
		</div>
	</section>

	<section id='design-series' class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='max-w-3xl'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Популярные серии дизайн-радиаторов</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-600 md:text-base'>На общей странице показаны серии Velar. Внутри каждой серии доступны конкретные вертикальные и горизонтальные исполнения, если они есть в ассортименте.</p>
			</div>
			<div class='mt-8'>
				<DesignSeriesGrid series={designSeries} />
			</div>
		</div>
	</section>

	<section class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Как выбрать дизайн-радиатор</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-700 md:text-base'>Дизайн-радиатор выбирают не только по мощности. Важно заранее понять ориентацию, профиль, место установки, цвет и схему подключения.</p>
			</div>
			<div class='grid gap-3 sm:grid-cols-2'>
				{chooseItems.map(([title, text]) => (
					<div class='border-t border-neutral-200 py-3'>
						<h3 class='text-base font-semibold text-neutral-950'>{title}</h3>
						<p class='mt-1 text-sm leading-6 text-neutral-600'>{text}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='grid gap-5 md:grid-cols-2'>
				<a href='/design/vertikalnye' class='rounded-lg border border-neutral-200 bg-white p-6 transition hover:border-red-700'>
					<h2 class='text-2xl font-semibold text-neutral-950'>Вертикальные дизайн-радиаторы</h2>
					<p class='mt-3 text-sm leading-6 text-neutral-600'>Для узких простенков, акцентных стен, прихожих и помещений, где нужно сохранить полезную ширину стены.</p>
				</a>
				<a href='/design/gorizontalnye' class='rounded-lg border border-neutral-200 bg-white p-6 transition hover:border-red-700'>
					<h2 class='text-2xl font-semibold text-neutral-950'>Горизонтальные дизайн-радиаторы</h2>
					<p class='mt-3 text-sm leading-6 text-neutral-600'>Для установки под окнами, в низких зонах и интерьерах, где радиатор должен работать в привычной горизонтальной линии.</p>
				</a>
			</div>
		</div>
	</section>

	<section class='bg-neutral-950 py-12 text-white md:py-16 xl:py-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight md:text-[34px] xl:text-[38px]'>Преимущества Velar</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-300 md:text-base'>Радиаторы изготавливаются под параметры проекта и помогают совместить отопление с задачами интерьера.</p>
			</div>
			<ul class='grid gap-3 sm:grid-cols-2'>
				{benefits.map(item => (
					<li class='flex items-center gap-3 border-t border-white/15 py-3 text-sm font-semibold text-white'>
						<span class='h-1.5 w-1.5 shrink-0 rounded-full bg-red-600'></span>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='max-w-3xl'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Дизайн-радиаторы в интерьере</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-600 md:text-base'>Вертикальные, горизонтальные и цветные модели можно вписать в спокойную отделку или сделать заметным интерьерным акцентом.</p>
			</div>
			<div class='mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4'>
				{galleryImages.map(([src, alt], index) => (
					<Picture
						src={src}
						alt={alt}
						title={alt}
						loading={index > 1 ? 'lazy' : 'eager'}
						aspectRatio='4:3'
						widths={[360, 520, 720]}
						width={520}
						height={390}
						sizes='(max-width: 768px) 100vw, 25vw'
						class='h-full w-full rounded-lg object-cover'
					/>
				))}
			</div>
		</div>
	</section>

	<section class='bg-neutral-950 py-12 text-white md:py-16'>
		<div class='mx-auto grid max-w-[1240px] gap-6 px-4 md:px-6 lg:grid-cols-[minmax(0,1fr)_260px] lg:items-center xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-tight tracking-tight md:text-[34px]'>Получить расчет дизайн-радиатора</h2>
				<p class='mt-3 max-w-3xl text-sm leading-6 text-neutral-300 md:text-base'>
					Отправьте размеры помещения, желаемую серию, ориентацию, цвет и город доставки. Мы поможем подобрать модель и рассчитать стоимость.
				</p>
			</div>
			<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>Получить расчет</a>
		</div>
	</section>

	<DesignFaq items={faqItems} />
	<DesignUsefulLinks />
</Layout>
