---
import Layout from '@shared/layouts/Layout.astro'
import JsonLd from '../components/seo/JsonLd.astro'

import ColumnsCatalog from '../components/columns/ColumnsCatalog.astro'
import ColumnsComparison from '../components/columns/ColumnsComparison.astro'
import ColumnsFaq from '../components/columns/ColumnsFaq.astro'
import ColumnsHero from '../components/columns/ColumnsHero.astro'
import ColumnsHowToOrder from '../components/columns/ColumnsHowToOrder.astro'
import ColumnsInteriors from '../components/columns/ColumnsInteriors.astro'
import PopularModels from '../components/columns/PopularModels.astro'
import ColumnsTubeDifferences from '../components/columns/ColumnsTubeDifferences.astro'
import ColumnsUseCases from '../components/columns/ColumnsUseCases.astro'
import ColumnsWhatIs from '../components/columns/ColumnsWhatIs.astro'
import ColumnsWhyVelar from '../components/columns/ColumnsWhyVelar.astro'
import UsefulArticles from '../components/columns/UsefulArticles.astro'
import {
	columnsFaqItems,
	columnsModels,
	popularModels,
	usefulArticles,
} from '../components/columns/columnsData'
import { getCategorySeo } from '../lib/seo/categorySeo'

const breadcrumbs = [
	{ title: 'Главная', url: '/' },
	{ title: 'Трубчатые радиаторы', url: '/columns' },
]

const seo = getCategorySeo({
	category: {
		slug: 'columns',
		url: '/columns',
		name: 'Трубчатые радиаторы',
		h1: 'Трубчатые радиаторы Velar',
		seoTitle: 'Трубчатые радиаторы Velar — стальные радиаторы отопления на заказ',
		seoDescription:
			'Стальные трубчатые радиаторы Velar для квартир, домов и дизайнерских интерьеров. Разные высоты, количество секций, цвета RAL, производство под заказ.',
		ogTitle: 'Трубчатые радиаторы Velar — каталог моделей',
		ogDescription:
			'Стальные трубчатые радиаторы Velar разных высот и секционности. Подбор мощности, цвета RAL и доставка по России.',
		ogImage: '/images/models/columns/hero-black-column-radiator.png',
		ogImageAlt: 'Стальные трубчатые радиаторы Velar',
		breadcrumbs,
		itemListName: 'Модели трубчатых радиаторов Velar',
		products: columnsModels.map(model => ({
			name: `Velar ${model.name}`,
			url: model.href,
		})),
		faq: columnsFaqItems.map(item => ({
			question: item.question,
			answer: item.answer,
		})),
	},
})

---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalUrl={seo.canonicalUrl}
	robots={seo.robots}
	ogType='website'
	ogTitle={seo.ogTitle}
	ogDescription={seo.ogDescription}
	ogUrl={seo.canonicalUrl}
	ogImageUrl={seo.ogImage}
	ogImageAlt={seo.ogImageAlt}
	twitterCard='summary_large_image'
	twitterTitle={seo.twitterTitle}
	twitterDescription={seo.twitterDescription}
	twitterImage={seo.twitterImage}
	twitterImageAlt={seo.twitterImageAlt}
	paddings={false}
	breadcrumbs={breadcrumbs}
	disableBreadcrumbJsonLd={true}
>
	<JsonLd data={seo.jsonLd} />

	<ColumnsHero />

	<PopularModels models={popularModels} />

	<ColumnsCatalog models={columnsModels} />

	<ColumnsTubeDifferences />

	<ColumnsInteriors />

	<ColumnsWhatIs />

	<ColumnsHowToOrder />

	<ColumnsComparison />

	<ColumnsUseCases />

	<ColumnsWhyVelar />

	<UsefulArticles articles={usefulArticles} />

	<ColumnsFaq />
</Layout>
