---
import LeadWidget from '@widgets/lead'
import Layout from '@shared/layouts/Layout.astro';
// TODO !! Форма закрывает часть сайта
---

<Layout
  title='🔥 Расчёт радиаторов и конвекторов | VelarShop.ru'
  description='Запрос на подбор и расчет радиаторов и конвекторов Velar.'
  robots='noindex,follow'
  hideShoppingCartWidgt={true}
>
<div class='mx-auto flex max-w-4xl flex-col px-4 py-8 md:px-10 md:py-12'>
  <h1 class='mb-3 text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl'>Запрос на подбор радиаторов</h1>

  <div class='mb-7 max-w-2xl text-sm leading-6 text-neutral-600 md:text-base md:leading-7'>
    Заполните форму, и мы подготовим расчет стоимости, подберем подходящую модель, размеры, подключение и цвет.
    Если в корзине есть выбранные позиции, они будут учтены при расчете.
  </div>

  <LeadWidget
    client:load
    webhook='https://arufefet.beget.app/webhook/calc-notify'
    successUrl='/accepted'
    store='VelarShop.ru'
    primary='#c1121f'
    border='#e5e5e5'
    privacyUrl='/privacy'
    termsUrl='/agreement'
  />
 
</div>
</Layout>

<script>
  var widgetOptions472580 = { bg_color: "transparent" };
  (function () {
    var a = document.createElement("script"),
      h = "head";
    a.async = true;
    a.style.zIndex = "0";
    a.src =
      (document.location.protocol == "https:" ? "https:" : "http:") +
      "//ucalc.pro/api/widget.js?id=472580&t=" +
      Math.floor((new Date() as unknown as number) / 18e5);
    document.getElementsByTagName(h)[0].appendChild(a);
  })();
</script>
