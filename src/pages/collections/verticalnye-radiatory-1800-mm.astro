<script is:inline>
	const filterButtons = document.querySelectorAll('[data-vertical-filter]')
	const rows = document.querySelectorAll('[data-vertical-row]')
	const quickFilterLinks = document.querySelectorAll('[data-quick-filter]')

	function applyVerticalFilter(value) {
		rows.forEach(row => {
			if (!(row instanceof HTMLElement)) return
			const filters = row.dataset.verticalFilters || ''
			const isVisible = value === 'all' || filters.split(' ').includes(value)
			row.style.display = isVisible ? '' : 'none'
		})

		filterButtons.forEach(button => {
			if (!(button instanceof HTMLElement)) return
			const isActive = button.dataset.verticalFilter === value
			button.classList.toggle('border-neutral-950', isActive)
			button.classList.toggle('bg-neutral-950', isActive)
			button.classList.toggle('text-white', isActive)
			button.classList.toggle('border-neutral-300', !isActive)
			button.classList.toggle('bg-white', !isActive)
			button.classList.toggle('text-neutral-800', !isActive)
			button.setAttribute('aria-pressed', isActive ? 'true' : 'false')
		})
	}

	filterButtons.forEach(button => {
		button.addEventListener('click', () => {
			applyVerticalFilter(button.dataset.verticalFilter || 'all')
		})
	})

	quickFilterLinks.forEach(link => {
		link.addEventListener('click', event => {
			if (!(link instanceof HTMLAnchorElement)) return
			const filterValue = link.dataset.quickFilter
			if (!filterValue) return

			applyVerticalFilter(filterValue)

			const targetId = link.getAttribute('href')
			if (!targetId?.startsWith('#')) return

			const target = document.querySelector(targetId)
			if (!(target instanceof HTMLElement)) return

			event.preventDefault()
			target.scrollIntoView({ behavior: 'smooth', block: 'start' })
		})
	})
</script>

