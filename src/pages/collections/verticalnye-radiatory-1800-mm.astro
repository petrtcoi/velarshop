function toNumber(value?: string): number {
	if (!value) return 0
	const parsed = Number.parseFloat(value)
	return Number.isFinite(parsed) ? parsed : 0
}

function normalizeModelName(name: string): string {
	return name.replace(/([A-Za-zА-Яа-я])\s+(\d+)/g, '$1$2').replace(/\s+/g, ' ').trim()
}

function resolveConnectionText(connections: string): string {
	const values = connections.split(',').map(item => item.trim()).filter(Boolean)
	const labels: string[] = []

	if (values.includes('lat')) labels.push('боковое')
	if (values.some(value => ['l50', 'r50', '050'].includes(value))) labels.push('нижнее')
	if (values.includes('lr')) labels.push('по схеме модели')

	return labels.length ? labels.join(' / ') : 'уточняйте'
}

function buildModelCollectionItem(modelId: string): CollectionModel {
	const model = modelsJsonData.find(item => item.id === modelId)
	if (!model) throw new Error(`Model not found: ${modelId}`)

	const radiators = radiatorsJsonData.filter(item => item.model_id === model.id)
	const prices = radiators.map(item => toNumber(item.price)).filter(Boolean)
	const powerValues = radiators.map(item => toNumber(item.dt60)).filter(Boolean)
	const heights = [...new Set(radiators.map(item => toNumber(item.height)).filter(Boolean))].sort((a, b) => a - b)
	const minHeight = heights[0] ?? 0
	const maxHeight = heights[heights.length - 1] ?? 0
	const minPrice = prices.length ? Math.min(...prices) : 0
	const minPower = powerValues.length ? Math.min(...powerValues) : 0
	const maxPower = powerValues.length ? Math.max(...powerValues) : 0
	const isColumns = model.type === 'columns'
	const meta = isColumns ? columnMeta[model.id] : designMeta[model.id]
	const name = normalizeModelName(model.name)
	const image = getModelMainImagePath(model.slug, isColumns)
	const powerLabel =
		minPower > 0 && maxPower > 0
			? minPower === maxPower
				? `${Math.round(minPower)} Вт`
				: `${Math.round(minPower)}-${Math.round(maxPower)} Вт`
			: 'по расчету'
	const heightLabel = isColumns
		? `${Math.round(maxHeight)} мм`
		: minHeight > 0 && maxHeight > 0
			? `${Math.round(minHeight)}-${Math.round(maxHeight)} мм`
			: 'около 180 см'
	const typeLabel = isColumns ? 'Трубчатый' : 'Профильный'

	return {
		id: model.id,
		name,
		title: `Velar ${name}`,
		href: getModelSlug(model),
		image,
		type: isColumns ? 'columns' : 'design',
		typeLabel,
		subtitleLabel: `${typeLabel} · ${meta?.profile ?? model.short_comment}`,
		heightLabel,
		profileLabel: meta?.profile ?? model.short_comment,
		powerLabel,
		connectionLabel: resolveConnectionText(model.connections),
		priceFrom: minPrice,
		priceLabel: minPrice > 0 ? `от ${minPrice.toLocaleString('ru-RU')} ₽` : 'уточняйте',
		whenChoose: meta?.whenChoose ?? model.short_comment,
		filters: isColumns ? ['columns', meta.filter] : ['design', meta.filter],
	}
}

