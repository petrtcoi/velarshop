---
import { Picture } from '@astrojs/image/components'
import Layout from '@shared/layouts/Layout.astro'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import JsonLd from '../../components/seo/JsonLd.astro'
import DesignSeriesGrid from '../../components/design/DesignSeriesGrid.astro'
import DesignFaq from '../../components/design/DesignFaq.astro'
import {
	designSeries,
	formatRub,
	type DesignSeries,
} from '../../components/design/designData'
import { get as getHeroConfiguratorData } from '../api/hero-configurator/[model].json'
import { getSeriesSeo } from '../../lib/seo/seriesSeo'

export function getStaticPaths() {
	return designSeries
		.filter(series => series.models.length > 1)
		.map(series => ({
			params: { series: series.slug },
			props: { series },
		}))
}

type Props = {
	series: DesignSeries
}

const { series } = Astro.props as Props
const hasBothOrientations = Boolean(series.verticalModel && series.horizontalModel)
const showSeriesHeroImage = Boolean(series.heroImage) && !['q60', 'q80'].includes(series.slug)
const seriesDisplayImage = series.heroImage ?? series.image
const orientationText = hasBothOrientations
	? 'вертикальные и горизонтальные модели'
	: series.verticalModel
		? 'вертикальные модели'
		: 'горизонтальные модели'
const breadcrumbs = [
	{ title: 'Главная', url: '/' },
	{ title: 'Дизайн-радиаторы', url: '/design' },
	{ title: series.title, url: `/design/${series.slug}` },
]

const seriesModelIds = new Set(series.models.map(model => model.id))
const seriesConfiguratorModels = buildQuickConfiguratorModels({ type: 'design' }).filter(model => seriesModelIds.has(model.id))
const defaultSeriesModelId = series.verticalModel?.id ?? series.models[0]?.id ?? seriesConfiguratorModels[0]?.id ?? ''
let initialSeriesDetails: ModelDetails | null = null

try {
	if (defaultSeriesModelId) {
		const response = await getHeroConfiguratorData({
			params: { model: defaultSeriesModelId },
		} as any)
		if (response.ok) initialSeriesDetails = (await response.json()) as ModelDetails
	}
} catch (error) {
	console.error(`Failed to preload design series configurator model ${series.slug}:`, error)
}

const relatedSeries = designSeries
	.filter(item => item.slug !== series.slug)
	.filter(item => item.profile[0] === series.profile[0] || item.orientations.some(orientation => series.orientations.includes(orientation)))
	.slice(0, 4)

function modelCode(model: DesignSeries['models'][number]): string {
	return model.name.replace(/\s+/g, '')
}

function normalizeVariantTitle(title: string): string {
	return title.replace(/([A-Za-zА-Яа-я])\s+(\d+)/g, '$1$2').replace(/\s+/g, ' ').trim()
}

function modelUse(model: DesignSeries['models'][number]): string {
	if (model.orientation === 'vertical') return 'Вертикальный дизайн-радиатор для установки на стене, в простенках и как интерьерный акцент.'
	return 'Горизонтальный дизайн-радиатор для установки под окнами и вдоль стен.'
}

const heroBenefits = [
	series.profile,
	orientationText,
	'рабочее давление до 16 атм',
	'окраска в цвета RAL',
	series.horizontalModel ? 'возможно подключение ТЭНа' : 'производство под заказ',
]

const featureItems = [
	series.profile,
	orientationText,
	'рабочее давление до 16 атм',
	'окраска в цвета RAL',
	series.horizontalModel ? 'возможно подключение ТЭНа' : 'ТЭН зависит от выбранной конфигурации',
	'производство под заказ',
]

const useCases = [
	'квартиры и апартаменты',
	'частные дома',
	'гостиные и спальни',
	'кухни и зоны с панорамным остеклением',
	'коммерческие помещения',
	'интерьеры в стиле минимализм, лофт, современная классика',
]

const specs: Array<[string, string]> = [
	['Серия', series.title],
	['Профиль', series.profile],
	['Исполнение', orientationText],
	['Рабочее давление', 'до 16 атм'],
	['Цвет', 'палитра RAL'],
	['ТЭН', series.horizontalModel ? 'возможно подключение, если поддерживается выбранной конфигурацией' : 'зависит от выбранной модели и подключения'],
	['Производство', 'под заказ'],
]

const faqItems: Array<[string, string]> = [
	[
		`Чем отличается ${series.title} от других серий?`,
		`${series.title} использует ${series.profile}. Это влияет на визуальный силуэт радиатора, его массивность и то, как модель смотрится в интерьере.`,
	],
	[
		`Есть ли вертикальная и горизонтальная версия ${series.label}?`,
		`В серии доступны: ${series.models.map(model => model.orientation === 'vertical' ? `вертикальная ${modelCode(model)}` : `горизонтальная ${modelCode(model)}`).join(', ')}.`,
	],
	[
		`Можно ли заказать ${series.title} в цвет RAL?`,
		'Да, радиатор можно окрасить в цвета RAL и дополнительные декоративные покрытия, если они доступны для выбранной конфигурации.',
	],
	[
		'Можно ли подключить ТЭН?',
		'Для отдельных конфигураций возможно подключение ТЭНа. Это нужно проверять по выбранной модели, размеру и типу подключения.',
	],
	[
		`Как выбрать исполнение ${series.label}?`,
		hasBothOrientations
			? `${modelCode(series.verticalModel!)} чаще выбирают для вертикальной установки на стене или в простенке. ${modelCode(series.horizontalModel!)} подходит для установки под окнами и вдоль длинных стен.`
			: 'Ориентируйтесь на место установки, доступную площадь стены, нужную мощность и схему подключения.',
	],
]

const internalLinks = [
	...series.models.map(model => [model.href, model.title] as [string, string]),
	['/design', 'Все дизайн-радиаторы'],
	['/design/vertikalnye', 'Вертикальные дизайн-радиаторы'],
	['/design/gorizontalnye', 'Горизонтальные дизайн-радиаторы'],
	...designSeries
		.filter(item => item.slug !== series.slug)
		.slice(0, 3)
		.map(item => [item.href, item.title] as [string, string]),
]

const seo = getSeriesSeo({
	series: {
		slug: series.slug,
		label: series.label,
		url: `/design/${series.slug}`,
		profile: series.profile,
		image: seriesDisplayImage,
		breadcrumbs,
		variants: series.models.map(model => ({
			name: normalizeVariantTitle(model.title),
			url: model.href,
			image: model.image,
		})),
		faq: faqItems.map(([question, answer]) => ({
			question,
			answer,
		})),
	},
})
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalUrl={seo.canonicalUrl}
	robots={seo.robots}
	ogType='website'
	ogTitle={seo.ogTitle}
	ogDescription={seo.ogDescription}
	ogUrl={seo.canonicalUrl}
	ogImageUrl={seo.ogImage}
	ogImageAlt={seo.ogImageAlt}
	twitterCard='summary_large_image'
	twitterTitle={seo.twitterTitle}
	twitterDescription={seo.twitterDescription}
	twitterImage={seo.twitterImage}
	twitterImageAlt={seo.twitterImageAlt}
	breadcrumbs={breadcrumbs}
	disableBreadcrumbJsonLd={true}
	paddings={false}
>
	<JsonLd data={seo.jsonLd} />

	<section class='border-b border-neutral-200 bg-white'>
		<div
			class:list={[
				'mx-auto grid max-w-[1240px] gap-7 px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:gap-8 min-[1250px]:items-center min-[1250px]:gap-10 xl:px-8 xl:py-12',
				showSeriesHeroImage
					? 'min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(200px,280px)_minmax(360px,420px)]'
					: 'min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(360px,420px)]',
			]}
		>
			<div class='min-w-0'>
				<h1 class='max-w-[760px] text-[34px] font-semibold leading-[1.04] tracking-tight text-neutral-950 md:text-[44px] xl:text-[58px]'>
					Дизайн-радиатор {series.title}
				</h1>
				<p class='mt-5 max-w-[760px] text-sm leading-6 text-neutral-700 md:text-base md:leading-7'>
					{series.title} — серия дизайн-радиаторов Velar: {series.description} Радиаторы окрашиваются в цвета RAL, производятся под заказ и подбираются по размеру, мощности и подключению.
				</p>
				<div class='mt-6 grid max-w-[720px] grid-cols-1 gap-x-8 gap-y-3 text-sm leading-5 text-neutral-700 min-[520px]:grid-cols-2'>
					{heroBenefits.map(item => (
						<div class='flex gap-2.5 border-t border-neutral-200 pt-3'>
							<span class='mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-red-700'></span>
							<span>{item}</span>
						</div>
					))}
				</div>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row min-[420px]:flex-wrap'>
					{series.models.map(model => (
						<a href={model.href} class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
							{model.orientation === 'vertical' ? 'Вертикальный' : 'Горизонтальный'} {modelCode(model)}
						</a>
					))}
				</div>
			</div>

			{showSeriesHeroImage && (
				<div class='hidden justify-center min-[1250px]:flex min-[1250px]:items-center'>
					<Picture
						src={seriesDisplayImage}
						alt={`Дизайн-радиатор ${series.title}`}
						title={`Дизайн-радиатор ${series.title}`}
						loading='eager'
						aspectRatio='1:4'
						widths={[220, 320, 440]}
						width={320}
						height={1280}
						sizes='260px'
						class='h-auto max-h-[560px] w-full max-w-[260px] object-contain'
					/>
				</div>
			)}

			<div
				class:list={[
					'grid min-w-0 gap-5 sm:items-start min-[900px]:col-start-2 min-[900px]:block',
					showSeriesHeroImage
						? 'sm:grid-cols-[150px_minmax(0,1fr)] md:grid-cols-[180px_minmax(0,1fr)] min-[1250px]:col-start-3'
						: '',
				]}
			>
				{showSeriesHeroImage && <div class='hidden justify-center sm:flex min-[900px]:hidden'>
					<Picture
						src={seriesDisplayImage}
						alt={`Дизайн-радиатор ${series.title}`}
						title={`Дизайн-радиатор ${series.title}`}
						loading='lazy'
						aspectRatio='1:4'
						widths={[180, 260, 360]}
						width={260}
						height={1040}
						sizes='180px'
						class='h-auto max-h-[430px] w-full max-w-[180px] object-contain'
					/>
				</div>}
				<HeroQuickConfigurator
					client:load
					models={seriesConfiguratorModels}
					defaultModelId={defaultSeriesModelId}
					initialDetails={initialSeriesDetails}
					variant='category'
					title='Быстрый выбор'
				/>
			</div>
		</div>
	</section>

	<section id='series-variants' class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='max-w-3xl'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Варианты исполнения {series.label}</h2>
				<p class='mt-3 text-sm leading-6 text-neutral-700 md:text-base md:leading-7'>
					Серия ведет на конкретные товарные страницы исполнений. Если у серии есть вертикальная и горизонтальная версия, показываем обе.
				</p>
			</div>
			<div class='mt-7 grid gap-4 md:grid-cols-2'>
				{series.models.map((model, index) => (
					<article class='grid gap-5 rounded-[18px] border border-neutral-200 bg-white p-4 transition hover:border-neutral-300 sm:grid-cols-[150px_minmax(0,1fr)]'>
						<a href={model.href} class='flex h-[150px] items-center justify-center overflow-hidden rounded-xl bg-white'>
							<Picture
								src={model.image}
								alt={model.title}
								title={model.title}
								loading={index > 1 ? 'lazy' : 'eager'}
								aspectRatio='1:1'
								widths={[180, 260, 360]}
								width={260}
								height={260}
								sizes='150px'
								class='h-full w-full object-contain p-3'
							/>
						</a>
						<div>
							<h3 class='text-xl font-semibold leading-tight text-neutral-950'>{model.title}</h3>
							<p class='mt-2 text-sm leading-6 text-neutral-600'>{modelUse(model)}</p>
							{model.priceFrom > 0 && <div class='mt-3 text-base font-semibold text-neutral-950'>от {formatRub(model.priceFrom)}</div>}
							<a href={model.href} class='mt-4 inline-flex h-9 items-center justify-center rounded-lg border border-neutral-300 bg-white px-4 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-white'>
								Подробнее
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Особенности серии {series.label}</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-700 md:text-base'>{series.description}</p>
			</div>
			<div class='grid content-start gap-3 sm:grid-cols-2'>
				{featureItems.map(item => (
					<div class='border-t border-neutral-200 py-3'>
						<p class='text-sm font-semibold leading-6 text-neutral-800'>{item}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-2 xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Где использовать {series.title}</h2>
				<div class='mt-7 grid gap-3 sm:grid-cols-2'>
					{useCases.map(item => (
						<div class='border-t border-neutral-200 py-3 text-sm leading-6 text-neutral-700'>{item}</div>
					))}
				</div>
			</div>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Характеристики серии</h2>
				<div class='mt-7 overflow-hidden rounded-2xl border border-neutral-200 bg-white'>
					{specs.map(([name, value]) => (
						<div class='grid grid-cols-[140px_minmax(0,1fr)] gap-4 border-b border-neutral-200 px-4 py-3 text-sm last:border-b-0 md:grid-cols-[180px_minmax(0,1fr)]'>
							<div class='text-neutral-500'>{name}</div>
							<div class='font-medium text-neutral-950'>{value}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class='bg-neutral-50 py-12 md:py-16 xl:py-20'>
		<div class='mx-auto grid max-w-[1240px] gap-8 px-4 md:px-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:px-8'>
			<div>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Полезные переходы</h2>
				<p class='mt-4 text-sm leading-6 text-neutral-700 md:text-base'>Страница серии связывает категорию, конкретные исполнения и соседние серии дизайн-радиаторов.</p>
			</div>
			<ul class='content-start divide-y divide-neutral-200 border-y border-neutral-200'>
				{internalLinks.map(([href, title]) => (
					<li>
						<a href={href} class='group flex gap-3 py-3.5 text-sm leading-6 text-neutral-700 transition hover:text-red-700 md:text-base'>
							<span class='text-neutral-400 transition group-hover:text-red-700'>→</span>
							<span>{title}</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	</section>

	{relatedSeries.length > 0 && (
		<section class='bg-white py-12 md:py-16 xl:py-20'>
			<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Похожие серии</h2>
				<div class='mt-8'>
					<DesignSeriesGrid series={relatedSeries} />
				</div>
			</div>
		</section>
	)}

	<DesignFaq items={faqItems} title={`Частые вопросы о ${series.title}`} />
</Layout>
