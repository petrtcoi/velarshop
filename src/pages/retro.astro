const preferredModelOrder = ['nostalgia500', 'historic500', 'nostalgia300', 'historic300']
const retroConfiguratorMap = new Map(buildQuickConfiguratorModels({ type: 'ironcast' }).map(model => [model.id, model]))
const retroConfiguratorModels = preferredModelOrder
	.map(id => retroConfiguratorMap.get(id))
	.filter((model): model is NonNullable<typeof model> => Boolean(model))
const defaultRetroModelId = retroConfiguratorModels.find(model => model.id === 'nostalgia500')?.id ?? retroConfiguratorModels[0]?.id ?? 'nostalgia500'
let initialRetroDetails: ModelDetails | null = null

try {
	const response = (await getHeroConfiguratorData({
		params: { model: defaultRetroModelId },
	} as any)) as Response
	if (response.ok) initialRetroDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload retro configurator model:', error)
}

const retroModels = preferredModelOrder
	.map(id => modelsJsonData.find(model => model.id === id))
	.filter(Boolean)
	.map(model => {
		const radiators = radiatorsJsonData.filter(radiator => radiator.model_id === model!.id)
		const prices = radiators.map(radiator => toNum(radiator.price)).filter(value => value > 0)
		const minPrice = prices.length ? Math.min(...prices) : 0

		return {
			id: model!.id,
			name: model!.name,
			title: `Velar ${model!.name}`,
			href: getModelSlug(model!),
			image: `/images/models/${model!.slug}/main.jpg`,
			priceFrom: minPrice,
			cardSpecs: modelCopy[model!.id]?.cardSpecs ?? 'чугун',
			cardWhen: modelCopy[model!.id]?.cardWhen ?? model!.short_comment,
		}
	})

const modelLinkById = Object.fromEntries(retroModels.map(model => [model.id, { href: model.href, name: model.name }]))

function resolveModelHref(id: string): string {
	return modelLinkById[id]?.href ?? '/retro'
}

