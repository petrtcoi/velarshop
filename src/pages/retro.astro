---
import { Picture } from '@astrojs/image/components'
import { modelsJsonData } from '@entities/Model'
import { radiatorsJsonData } from '@entities/Radiator'
import Layout from '@shared/layouts/Layout.astro'
import { getModelSlug } from '@shared/utils/getModelSlug'
import HeroQuickConfigurator from '@widgets/pageMain/HeroQuickConfigurator'
import type { ModelDetails } from '@widgets/pageMain/HeroQuickConfigurator'
import { buildQuickConfiguratorModels } from '@widgets/pageMain/quickConfiguratorData'
import { get as getHeroConfiguratorData } from './api/hero-configurator/[model].json'
import JsonLd from '../components/seo/JsonLd.astro'

const canonicalUrl = 'https://velarshop.ru/retro/'
const pageTitle = 'Чугунные ретро-радиаторы Velar | выгодные цены | VelarShop.ru'
const pageDescription =
	'Чугунные ретро радиаторы Velar представлены 4 моделями (с орнаментом и без). Покраска в любой цвет, включая состаренные цвета, а также нанесение текстур. Срок производства - 2 недели.'
const heroImage = '/images/retro/hero/nostalgia-section.jpg'

const crumbs = [
	{ title: 'Главная', url: '/' },
	{ title: 'Чугунные ретро-радиаторы', url: '/retro' },
]

function toNum(value: string | undefined): number {
	if (!value) return 0
	const parsed = Number.parseFloat(value)
	return Number.isFinite(parsed) ? parsed : 0
}

function formatRub(value: number): string {
	return `${value.toLocaleString('ru-RU')} ₽`
}

const modelCopy: Record<string, { description: string; short: string }> = {
	nostalgia300: {
		short: 'Чугунный ретро-радиатор в стиле ретро. Украшен цветочным орнаментом.',
		description: 'Чугунный ретро-радиатор в стиле ретро. Украшен цветочным орнаментом.',
	},
	nostalgia500: {
		short: 'Чугунный ретро-радиатор в стиле ретро. Украшен цветочным орнаментом.',
		description: 'Чугунный ретро-радиатор в стиле ретро. Украшен цветочным орнаментом.',
	},
	historic300: {
		short: 'Чугунный радиатор без орнамента. Отлично подходит для интерьеров в стиле лофт.',
		description: 'Чугунный радиатор без орнамента. Отлично подходит для интерьеров в стиле лофт.',
	},
	historic500: {
		short: 'Чугунный радиатор без орнамента. Отлично подходит для интерьеров в стиле лофт.',
		description: 'Чугунный радиатор без орнамента. Отлично подходит для интерьеров в стиле лофт.',
	},
}

const preferredModelOrder = ['nostalgia500', 'historic500', 'nostalgia300', 'historic300']
const retroConfiguratorMap = new Map(buildQuickConfiguratorModels({ type: 'ironcast' }).map(model => [model.id, model]))
const retroConfiguratorModels = preferredModelOrder
	.map(id => retroConfiguratorMap.get(id))
	.filter((model): model is NonNullable<typeof model> => Boolean(model))
const defaultRetroModelId = retroConfiguratorModels.find(model => model.id === 'nostalgia500')?.id ?? retroConfiguratorModels[0]?.id ?? 'nostalgia500'
let initialRetroDetails: ModelDetails | null = null

try {
	const response = await getHeroConfiguratorData({
		params: { model: defaultRetroModelId },
	} as any)
	if (response.ok) initialRetroDetails = (await response.json()) as ModelDetails
} catch (error) {
	console.error('Failed to preload retro configurator model:', error)
}

const retroModels = preferredModelOrder
	.map(id => modelsJsonData.find(model => model.id === id))
	.filter(Boolean)
	.map(model => {
		const radiators = radiatorsJsonData.filter(radiator => radiator.model_id === model!.id)
		const prices = radiators.map(radiator => toNum(radiator.price)).filter(value => value > 0)
		const minPrice = prices.length ? Math.min(...prices) : 0
		const firstRadiator = radiators[0]
		const width = firstRadiator?.width ? `${firstRadiator.width} мм` : 'уточняется'
		const height = firstRadiator?.height ? `${firstRadiator.height} мм` : 'уточняется'
		const dt70 = firstRadiator?.dt70 && firstRadiator?.sections
			? Math.round(toNum(firstRadiator.dt70) / toNum(firstRadiator.sections)).toString()
			: ''
		const weight = firstRadiator?.weight && firstRadiator?.sections
			? `${(toNum(firstRadiator.weight) / toNum(firstRadiator.sections)).toFixed(1)} кг/секц.`
			: 'уточняется'

		return {
			id: model!.id,
			name: model!.name,
			title: `Velar ${model!.name}`,
			href: getModelSlug(model!),
			image: `/images/models/${model!.slug}/main.jpg`,
			priceFrom: minPrice,
			height,
			width,
			dt70,
			weight,
			short: modelCopy[model!.id]?.short ?? model!.short_comment,
			description: modelCopy[model!.id]?.description ?? model!.short_comment,
		}
	})

const trustPoints = [
	{ title: '4 модели', text: 'Nostalgia и Historic', icon: 'star' },
	{ title: 'Высоты 300 и 500 мм', text: 'низкие и универсальные', icon: 'shield' },
	{ title: 'Покраска RAL', text: 'любой цвет по запросу', icon: 'palette' },
	{ title: 'Патинация', text: 'бронза, золото, серебро', icon: 'palette' },
	{ title: 'От 2 недель', text: 'срок производства', icon: 'factory' },
	{ title: 'Доставка по России', text: 'через ТК и до двери', icon: 'factory' },
]

const benefits = [
	'Долговечность',
	'Устойчивость к коррозии',
	'Нетребовательность к теплоносителю',
	'Высокая тепловая инерция',
	'Мягкое тепло',
	'Интерьерный внешний вид',
]

const finishChips = ['RAL', 'патина', 'бронза', 'медь', 'золото', 'серебро', 'двухцветная покраска', 'выделение орнамента', 'текстуры']

const interiorImages = [
	['/images/retro/retro_1.jpg', 'Чугунный ретро-радиатор Velar Nostalgia в интерьере'],
	['/images/retro/retro_2.jpg', 'Ретро-радиатор с патиной в классическом интерьере'],
	['/images/retro/retro_3.jpg', 'Белый чугунный радиатор Velar у стены'],
	['/images/retro/retro_4.jpg', 'Чугунный радиатор Velar Historic в интерьере loft'],
	['/images/retro/retro_5.jpg', 'Чугунный ретро-радиатор Velar в загородном интерьере'],
	['/images/retro/retro_6.jpg', 'Чугунный ретро-радиатор Velar в интерьерном проекте'],
]

const orderSteps = [
	['01', 'Выберите модель', 'Nostalgia или Historic, высота 300 или 500 мм.'],
	['02', 'Укажите параметры', 'Количество секций, цвет, патина или декоративная отделка.'],
	['03', 'Получите расчет', 'Менеджер уточнит детали и подготовит стоимость.'],
	['04', 'Производство и доставка', 'Радиатор изготавливается под заказ и доставляется по России.'],
]

const mountingItems = [
	['Согласование марки антифриза', 'Если планируется использование антифриза, необходимо заранее согласовать его марку. Некоторые составы могут повреждать прокладки и провоцировать протечки между секциями.'],
	['Контроль давления', 'При первом запуске важно плавно открывать запорный вентиль, чтобы избежать резкого скачка давления и повреждения отопительного прибора.'],
	['Правильная транспортировка', 'Ретро-радиаторы достаточно тяжелые, поэтому их следует переносить вертикально. Переноска плашмя может привести к деформации и ослаблению соединений между секциями.'],
	['Осторожность при монтаже запорной арматуры', 'При установке вентилей нельзя прилагать чрезмерное усилие, чтобы не повредить прокладки и соединения.'],
	['Проверка соединений', 'Перед установкой необходимо проверить ниппельные соединения. Они могли ослабнуть во время транспортировки.'],
	['Монтажные расстояния', 'Рекомендуемые расстояния: от пола до низа радиатора — 7–10 см, от подоконника до верха — 8–12 см, от стены до задней стороны — 3–5 см.'],
	['Диагональное подключение', 'Для радиаторов свыше 10 секций рекомендуется диагональная схема подключения, чтобы тепло распределялось равномернее.'],
	['Установка воздухоотводчика', 'Воздухоотводный клапан следует устанавливать только на верхнем присоединительном отверстии.'],
	['Испытания после монтажа', 'После установки необходимо провести испытания радиатора и составить акт ввода в эксплуатацию.'],
]

const usefulLinks = [
	['/info/iron-cast-radiators', 'Чугунные радиаторы в ретро-стиле'],
	['/info/ironcast', 'Особенности чугунных радиаторов отопления'],
	['/info/restavratsiya-chugunnyh-radiatorov', 'Реставрация чугунных радиаторов'],
	['/info/pravila-ekspluatacii-chugunnyh-radiatorov', 'Правила эксплуатации чугунных радиаторов: переноска, монтаж и первый запуск'],
	['/info/kak-otlichit-kachestvennoe-lite-radiatorov', 'Как отличить качественное художественное литье чугунных радиаторов'],
]

const faqItems = [
	['Чем ретро-радиаторы Velar отличаются от обычных чугунных батарей?', 'Ретро-радиаторы Velar выбирают не только для отопления, но и для интерьера: доступны модели с орнаментом, патинацией и декоративной окраской.'],
	['Какие модели доступны на странице?', 'На странице представлены Velar Nostalgia 500, Velar Historic 500, Velar Nostalgia 300 и Velar Historic 300.'],
	['Можно ли заказать радиатор в цвет RAL?', 'Да, ретро-радиаторы можно окрасить в цвет RAL по запросу.'],
	['Можно ли сделать патинацию или выделить орнамент?', 'Да, доступны патинация, бронза, медь, золото, серебро, двухцветная покраска и выделение орнамента.'],
	['Сколько занимает производство?', 'Срок производства чугунных ретро-радиаторов начинается от 2 недель без учета доставки.'],
	['Подходят ли чугунные ретро-радиаторы для квартиры?', 'Да, при корректном подборе модели и согласовании параметров системы отопления такие радиаторы можно использовать в квартире.'],
	['Какой тип подключения выбрать?', 'Подключение выбирают по разводке труб, количеству секций и месту установки. Для радиаторов свыше 10 секций часто рекомендуют диагональную схему.'],
	['Как доставляются тяжелые чугунные радиаторы?', 'Радиаторы отправляются в жесткой упаковке через транспортные компании, при возможности со страховкой груза.'],
]

const iconSvg = {
	shield: '<path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3v8Z"></path><path d="m9 12 2 2 4-4"></path>',
	palette: '<circle cx="13.5" cy="6.5" r=".5"></circle><circle cx="17.5" cy="10.5" r=".5"></circle><circle cx="8.5" cy="7.5" r=".5"></circle><circle cx="6.5" cy="12.5" r=".5"></circle><path d="M12 22a10 10 0 1 1 10-10c0 2.5-1.5 3.5-3.5 3.5h-1.8c-1 0-1.7.7-1.7 1.7 0 .4.1.8.3 1.1.4.7.2 1.7-.5 2.2A5 5 0 0 1 12 22Z"></path>',
	star: '<path d="m12 2 3.1 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.8 21 7 14.2 2 9.3l6.9-1L12 2Z"></path>',
	factory: '<path d="M2 20h20"></path><path d="M4 20V8l6 4V8l6 4V4h4v16"></path><path d="M17 12h1"></path><path d="M12 16h1"></path><path d="M7 16h1"></path>',
}

const productJsonLd = retroModels.map(model => ({
	'@type': 'Product',
	name: model.title,
	image: new URL(model.image, canonicalUrl).toString(),
	description: model.description,
	brand: {
		'@type': 'Brand',
		name: 'Velar',
	},
	category: 'Чугунные ретро-радиаторы',
	offers: model.priceFrom
		? {
				'@type': 'Offer',
				priceCurrency: 'RUB',
				price: String(model.priceFrom),
				availability: 'https://schema.org/InStock',
				url: new URL(model.href, canonicalUrl).toString(),
			}
		: undefined,
}))

const collectionJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Чугунные ретро-радиаторы Velar',
	url: canonicalUrl,
	description: pageDescription,
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: retroModels.map((model, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: new URL(model.href, canonicalUrl).toString(),
			item: productJsonLd[index],
		})),
	},
}

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map(([question, answer]) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: answer,
		},
	})),
}

const organizationJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'VelarShop.ru',
	url: 'https://velarshop.ru/',
	logo: 'https://velarshop.ru/images/logo.png',
}
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogImageUrl={heroImage}
	breadcrumbs={crumbs}
	paddings={false}
>
	<JsonLd data={collectionJsonLd} />
	<JsonLd data={faqJsonLd} />
	<JsonLd data={organizationJsonLd} />

	<section class='border-b border-neutral-200 bg-white'>
		<div class='mx-auto grid max-w-[1240px] gap-7 px-4 pb-8 pt-6 md:px-6 md:pb-12 md:pt-9 min-[900px]:grid-cols-[minmax(0,1fr)_minmax(420px,520px)] min-[900px]:gap-8 min-[1250px]:grid-cols-[minmax(0,1fr)_minmax(200px,280px)_minmax(360px,420px)] min-[1250px]:items-center min-[1250px]:gap-10 xl:px-8 xl:py-12'>
			<div class='min-w-0'>
				<h1 class='max-w-[680px] text-[34px] font-semibold leading-[1.04] tracking-tight text-neutral-950 md:text-[42px] min-[1250px]:text-[56px]'>
					Чугунные ретро-радиаторы Velar
				</h1>
				<p class='mt-5 max-w-[620px] text-[15px] leading-6 text-neutral-700 md:text-base md:leading-7'>
					Чугунные ретро-радиаторы Velar подходят для классических интерьеров, лофта, ресторанов, отелей и загородных домов. В каталоге представлены модели с выразительным орнаментом и более сдержанным историческим силуэтом. Радиаторы можно окрасить в любой цвет RAL, выполнить патинацию или выделить орнамент оттенками золота, бронзы, серебра и меди.
				</p>
				<div class='mt-7 flex flex-col gap-3 min-[420px]:flex-row'>
					<a href='/request' class='inline-flex h-11 items-center justify-center rounded-lg bg-red-700 px-5 text-sm font-semibold text-white transition hover:bg-red-800'>
						Получить расчет
					</a>
					<a href='#retro-models' class='inline-flex h-11 items-center justify-center rounded-lg border border-neutral-300 bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-neutral-50'>
						Смотреть модели
					</a>
				</div>
				<div class='mt-7 grid max-w-[720px] grid-cols-1 gap-x-8 gap-y-5 text-[13px] leading-tight text-neutral-700 min-[520px]:grid-cols-2 md:text-sm'>
					{trustPoints.map(item => (
						<div class='flex items-start gap-2.5'>
							<span class='inline-flex h-5 w-5 shrink-0 items-center justify-center text-red-700' aria-hidden='true'>
								<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' class='h-5 w-5' set:html={iconSvg[item.icon]} />
							</span>
							<span>
								<span class='block font-semibold leading-5 text-neutral-950'>{item.title}</span>
								<span class='block text-xs leading-5 text-neutral-600'>{item.text}</span>
							</span>
						</div>
					))}
				</div>
			</div>

			<div class='hidden justify-center min-[1250px]:flex min-[1250px]:items-center'>
				<img
					src={heroImage}
					alt='Вертикальная секция чугунного ретро-радиатора Velar Nostalgia'
					title='Вертикальная секция чугунного ретро-радиатора Velar Nostalgia'
					loading='eager'
					class='h-auto max-h-[660px] w-full max-w-[260px] object-contain'
				/>
			</div>

			<div class='grid min-w-0 gap-5 sm:grid-cols-[150px_minmax(0,1fr)] sm:items-start md:grid-cols-[180px_minmax(0,1fr)] min-[900px]:col-start-2 min-[900px]:block min-[1250px]:col-start-3'>
				<div class='hidden justify-center sm:flex min-[900px]:hidden'>
					<img
						src={heroImage}
						alt='Вертикальная секция чугунного ретро-радиатора Velar Nostalgia'
						title='Вертикальная секция чугунного ретро-радиатора Velar Nostalgia'
						loading='lazy'
						class='h-auto max-h-[540px] w-full max-w-[210px] object-contain'
					/>
				</div>

				<HeroQuickConfigurator
					client:load
					models={retroConfiguratorModels}
					defaultModelId={defaultRetroModelId}
					initialDetails={initialRetroDetails}
					variant='category'
					title='Быстрый выбор'
				/>
			</div>
		</div>
	</section>

	<section id='retro-models' class='bg-white py-12 md:py-16 xl:py-20'>
		<div class='mx-auto max-w-[1240px] px-4 md:px-6 xl:px-8'>
			<div class='max-w-3xl'>
				<h2 class='text-[28px] font-semibold leading-[1.12] tracking-tight text-neutral-950 md:text-[34px] xl:text-[38px]'>Модели чугунных ретро-радиаторов</h2>
				<p class='mt-3 text-[15px] leading-6 text-neutral-700 md:text-base md:leading-7'>Всего 4 модели: две серии и две высоты. Выбор зависит от стиля интерьера, места установки и нужной мощности.</p>
			</div>
			<div class='mt-7 flex flex-col gap-4 md:flex-row md:flex-wrap md:justify-center md:gap-6'>
				{retroModels.map(model => (
					<article class='flex w-full flex-col rounded-[18px] border border-neutral-200 bg-white p-3.5 transition hover:border-neutral-300 hover:bg-neutral-50 md:max-w-[280px] md:p-4'>
						<a href={model.href} class='retro-model-image-wrapper flex h-[240px] w-full items-center justify-center overflow-hidden rounded-xl bg-white md:h-[240px] min-[900px]:h-[250px] min-[1280px]:h-[260px] min-[1440px]:h-[280px]'>
							<Picture
								src={model.image}
								alt={`Чугунный ретро-радиатор ${model.title}`}
								title={`Чугунный ретро-радиатор ${model.title}`}
								loading='lazy'
								aspectRatio='1:1'
								widths={[220, 320, 420]}
								width={260}
								sizes='(max-width: 640px) 100vw, (max-width: 1279px) 50vw, 25vw'
								class='retro-model-image block h-auto w-full max-w-full object-contain'
							/>
						</a>
						<h3 class='mt-3 text-[17px] font-semibold leading-tight text-neutral-950 min-[1280px]:text-lg'>{model.title}</h3>
						<p class='mt-1.5 text-[14px] leading-[1.42] text-neutral-600'>{model.description}</p>
						<div class='mt-3 grid gap-1.5 border-t border-neutral-200 pt-3 text-[13px] leading-5 text-neutral-700'>
							<div><span class='text-neutral-500'>Высота:</span> {model.height}</div>
							<div><span class='text-neutral-500'>Глубина:</span> {model.width}</div>
							{model.dt70 && <div><span class='text-neutral-500'>Теплоотдача:</span> {model.dt70} Вт/секц.</div>}
							<div><span class='text-neutral-500'>Вес:</span> {model.weight}</div>
							<div><span class='text-neutral-500'>Производство:</span> от 2 недель</div>
						</div>
						<div class='mt-3 text-base font-semibold text-neutral-950'>от {formatRub(model.priceFrom)}</div>
						<div class='mt-auto pt-3'>
							<a href={model.href} class='inline-flex h-9 w-full items-center justify-center rounded-lg border border-neutral-300 bg-white px-3 text-[13px] font-semibold text-neutral-950 transition hover:border-neutral-400 hover:bg-white'>
								Подробнее
							</a>
						</div>
					</article>
				))}
			</div>
			<div class='mt-6 rounded-2xl border border-neutral-200 bg-neutral-50 p-5 md:p-6'>
