---
const steps = [
  "Выберите модель",
  "Укажите параметры",
  "Получите расчет",
  "Подтвердите заказ",
  "Производство и доставка",
];
---

<section id="how-to-order" class="how-order-section">
  <div class="how-order-wrap">
    <h2>Как заказать радиаторы Velar</h2>

    <ol class="how-order-steps">
      {
        steps.map((step, index) => (
          <li class="how-order-step">
            <span class="how-order-number">{index + 1}</span>
            <span class="how-order-label">{step}</span>
          </li>
        ))
      }
    </ol>

    <a href="/request" class="how-order-button">Получить расчет</a>
  </div>
</section>

<style>
  .how-order-section {
    background: #fff;
    padding: 48px 16px 56px;
  }

  .how-order-wrap {
    max-width: 1180px;
    margin: 0 auto;
  }

  .how-order-wrap h2 {
    margin: 0;
    color: #111;
    font-size: 30px;
    font-weight: 600;
    line-height: 1.16;
  }

  .how-order-steps {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid #e5e5e5;
  }

  .how-order-step {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .how-order-number {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #f5f5f5;
    color: #b91c1c;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
  }

  .how-order-label {
    color: #171717;
    font-size: 15px;
    line-height: 1.35;
    font-weight: 500;
  }

  .how-order-button {
    margin-top: 28px;
    height: 48px;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    border: 1px solid #c1121f;
    background: #c1121f;
    color: #fff;
    padding: 0 28px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
  }

  .how-order-button:hover {
    background: #a30f19;
    border-color: #a30f19;
  }

  @media (min-width: 769px) {
    .how-order-section {
      padding: 72px 24px;
    }

    .how-order-wrap h2 {
      font-size: 38px;
    }

    .how-order-steps {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 24px;
      border-top: 0;
    }

    .how-order-step {
      position: relative;
      display: block;
      padding: 0;
      border-bottom: 0;
    }

    .how-order-step:not(:last-child)::after {
      content: "";
      position: absolute;
      top: 18px;
      left: 46px;
      right: -12px;
      height: 1px;
      background: #e5e5e5;
    }

    .how-order-number {
      position: relative;
      z-index: 1;
      width: 36px;
      height: 36px;
      background: #f5f5f5;
    }

    .how-order-label {
      display: block;
      margin-top: 14px;
      max-width: 150px;
      font-size: 14px;
      line-height: 1.3;
    }

    .how-order-button {
      width: auto;
      min-width: 190px;
    }
  }

  @media (min-width: 1200px) {
    .how-order-section {
      padding: 88px 32px 96px;
    }

    .how-order-label {
      max-width: 170px;
      font-size: 15px;
    }
  }
</style>
