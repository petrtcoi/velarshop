---
const choices = [
  { title: "Под окно", url: "/columns" },
  { title: "Для панорамных окон", url: "/convector" },
  { title: "Для детской комнаты", url: "/info/bezopasnost-radiatorov-dlya-detej" },
  { title: "Для ванной", url: "/design" },
  { title: "Для лофта", url: "/design" },
  { title: "Для классического интерьера", url: "/retro" },
];
---

<section class="quick-choice" aria-labelledby="quick-choice-title">
  <div class="quick-choice__copy">
    <h2 id="quick-choice-title">Не знаете, какой радиатор нужен?</h2>
    <p>Выберите ситуацию, а дальше откроется подходящий раздел или материал для подбора.</p>
  </div>
  <nav class="quick-choice__links" aria-label="Подбор радиатора по задаче">
    {choices.map((choice) => (
      <a href={choice.url}>{choice.title}</a>
    ))}
  </nav>
</section>

<style>
  .quick-choice {
    max-width: 1180px;
    margin: 0 auto;
    padding: 8px 24px 72px;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 40px;
    align-items: start;
  }

  .quick-choice__copy h2 {
    margin: 0;
    color: #111;
    font-size: 32px;
    font-weight: 600;
    line-height: 1.15;
  }

  .quick-choice__copy p {
    margin: 12px 0 0;
    color: #52525b;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
  }

  .quick-choice__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid #e5e7eb;
  }

  .quick-choice__links a {
    min-height: 54px;
    border-bottom: 1px solid #e5e7eb;
    color: #111827;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 4px;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.35;
    text-decoration: none;
  }

  .quick-choice__links a:nth-child(odd) {
    margin-right: 18px;
  }

  .quick-choice__links a::after {
    content: "→";
    color: #b91c1c;
    font-weight: 400;
  }

  .quick-choice__links a:hover {
    color: #991b1b;
  }

  @media (max-width: 768px) {
    .quick-choice {
      padding: 0 16px 52px;
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .quick-choice__copy h2 {
      font-size: 28px;
    }

    .quick-choice__links {
      grid-template-columns: 1fr;
    }

    .quick-choice__links a:nth-child(odd) {
      margin-right: 0;
    }
  }
</style>
