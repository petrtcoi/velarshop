---
import { Picture } from '@astrojs/image/components';
import { getCollection } from 'astro:content';

const news = await getCollection('news');
---

<section
  id="news"
  aria-label="Новости о радиаторах и дайзн-ради аторах"
  class="justify-center max-w-[1180px] mx-auto px-4 md:px-6 xl:px-8 py-12 md:py-20 lg:py-24">
  <h2 class="text-3xl md:text-4xl font-semibold text-left">Полезные материалы и новости</h2>
  <div
    id="articles_list"
    aria-label="Список статей"
    class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    {
      news
        .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
        .slice(0, 3)
        .map(a => {
          const { title, slug, date, short_description, thumbnail } = a.data;

          const imgPath =
            thumbnail.length > 0
              ? `/images/news/${thumbnail}`
              : '/images/news/empty.jpg';
          const articleHref = `/news/${slug}`;

          return (
            <div class="group">
              <a href={articleHref}>
                <Picture
                  src={imgPath}
                  alt={title}
                  title={title}
                  loading="lazy"
                  aspectRatio="1:1"
                  widths={[290, 500]}
                  width={290}
                  height={290}
                  sizes="290px"
                  class="rounded-lg opacity-100 md:opacity-75 group-hover:opacity-100 group-hover:shadow-lg transition-opacity duration-300"
                />
                <div class="mt-1 text-xs text-slate-700 font-light">{date}</div>
                <div class="text-sm mt-1 group-hover:text-red-700 transition-colors duration-300">
                  {title}
                </div>
                <div class="text-xs mt-1 text-neutral-600 group-hover:text-neutral-900">
                  {short_description}
                </div>
              </a>
            </div>
          );
        })
    }
  </div>

  <div class="mt-[20px]">
    <a href={'/news'}>
      <div
        class="text-sm font-medium text-red-700 hover:underline transition-all duration-300">
        Все материалы →
      </div>
    </a>
  </div>
</section>
