---
import HeroQuickConfigurator from "./HeroQuickConfigurator";
import type { ModelDetails } from "./HeroQuickConfigurator";
import { buildQuickConfiguratorModels } from "./quickConfiguratorData";
import { get as getHeroConfiguratorData } from "../../pages/api/hero-configurator/[model].json";

const modelOptions = buildQuickConfiguratorModels();

const defaultModelId = "3030";
let initialDetails: ModelDetails | null = null;

try {
  const response = await getHeroConfiguratorData({
    params: { model: defaultModelId },
  } as any);
  if (response.ok) {
    initialDetails = (await response.json()) as ModelDetails;
  }
} catch (error) {
  console.error("Failed to preload hero configurator model:", error);
}

const scenarios = [
  {
    title: "Трубчатые радиаторы",
    desc: "Компактные и эффективные решения",
    image: "/images/columns/about.jpg",
    href: "/columns",
  },
  {
    title: "Дизайн-радиаторы",
    desc: "Вертикальные и горизонтальные модели",
    image: "/images/articles/design.jpg",
    href: "/design",
  },
  {
    title: "Внутрипольные конвекторы",
    desc: "Для панорамных окон",
    image: "/images/articles/convector.jpeg",
    href: "/convector",
  },
  {
    title: "Ретро-радиаторы",
    desc: "Чугунные радиаторы в классическом стиле",
    image: "/images/retro/retro_1.jpg",
    href: "/retro",
  },
  {
    title: "Напольные радиаторы",
    desc: "Перед окнами и витражным остеклением",
    image: "/images/articles/floor-0.jpg",
    href: "/floor",
  },
];
---

<section id="hero" class="hero">
  <picture class="hero-picture">
    <source srcset="/main/hero.avif" type="image/avif" />
    <source srcset="/main/hero.webp" type="image/webp" />
    <img
      src="/main/hero.jpg"
      alt=""
      aria-hidden="true"
      class="hero-bg"
      loading="eager"
    />
  </picture>
  <div class="hero-overlay"></div>

  <div class="hero-content items-stretch">
    <div class="hero-left flex flex-col justify-between h-full min-h-[460px]">
      <div class="hero-main-copy">
        <h1 class="hero-title">
          Радиаторы Velar — решения для современных интерьеров
        </h1>
        <p class="hero-subtitle">
          <span class="hero-subtitle-desktop">
            Дизайн-радиаторы, трубчатые модели, ретро-радиаторы и конвекторы — подбираем под стиль, мощность и задачи помещения.
          </span>
          <span class="hero-subtitle-mobile">
            Подберём по стилю, мощности, размерам и задаче помещения.
          </span>
        </p>
        <div class="hero-actions">
          <a href="/request" class="hero-btn hero-btn-primary">
            <span class="hero-btn-desktop">Подобрать радиатор</span>
            <span class="hero-btn-mobile">Подобрать</span>
          </a>
          <a href="#catalog" class="hero-btn hero-btn-secondary">
            <span class="hero-btn-desktop">Смотреть каталог</span>
            <span class="hero-btn-mobile">Каталог</span>
          </a>
        </div>
      </div>

      <div class="hero-features">
        <div class="hero-feature hero-feature-first">
          <span class="hero-feature-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 16h.01"></path><path d="M16 16h.01"></path><path
                d="M3 19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5a.5.5 0 0 0-.77-.42l-4.46 2.84a.5.5 0 0 1-.77-.42v-2a.5.5 0 0 0-.77-.42L9.77 10.92A.5.5 0 0 1 9 10.5V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"
              ></path><path d="M8 16h.01"></path></svg
            >
          </span>
          <span>
            <span class="hero-feature-desktop">В наличии и под заказ</span>
            <span class="hero-feature-mobile">В наличии / заказ</span>
          </span>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"
              ></path><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"
              ></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"
              ></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"
              ></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"
              ></circle></svg
            >
          </span>
          <span>
            <span class="hero-feature-desktop">Цвета RAL</span>
            <span class="hero-feature-mobile">Цвета RAL</span>
          </span>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
              ></path></svg
            >
          </span>
          <span>
            <span class="hero-feature-desktop">Гарантия до 10 лет</span>
            <span class="hero-feature-mobile">Гарантия 10 лет</span>
          </span>
        </div>
        <div class="hero-feature">
          <span class="hero-feature-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"
              ></path><path d="M15 18H9"></path><path
                d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"
              ></path><circle cx="17" cy="18" r="2"></circle><circle
                cx="7"
                cy="18"
                r="2"></circle></svg
            >
          </span>
          <span>
            <span class="hero-feature-desktop">Доставка по России</span>
            <span class="hero-feature-mobile">Доставка</span>
          </span>
        </div>
      </div>
    </div>

    <div class="hero-configurator">
      <HeroQuickConfigurator
        client:load
        models={modelOptions}
        defaultModelId={defaultModelId}
        initialDetails={initialDetails}
      />
    </div>
  </div>
</section>

<section class="category-entry-section">
  <div class="category-entry-wrap">
    <div class="category-entry-heading">
      <h2 class="category-entry-title">Выберите направление</h2>
      <a href="/columns" class="category-entry-all">Весь каталог →</a>
    </div>
    
    <div class="mobile-category-links">
      {
        scenarios.map((item) => (
          <a href={item.href} class="mobile-category-link">
            <img src={item.image} alt="" loading="eager" class="mobile-category-link-image" />
            <span>
              <span class="mobile-category-link-title">{item.title}</span>
              <span class="mobile-category-link-desc">{item.desc}</span>
            </span>
            <span class="mobile-category-link-arrow" aria-hidden="true">›</span>
          </a>
        ))
      }
    </div>
    <div class="desktop-scenarios">
      {
        scenarios.map((item) => (
          <a href={item.href} class="scenario-card">
            <img
              src={item.image}
              alt={item.title}
              class="scenario-card-image"
              loading="eager"
            />
            <div class="scenario-card-copy">
              <div class="scenario-card-title">{item.title}</div>
              <div class="scenario-card-desc">{item.desc}</div>
              <div class="scenario-card-cta">Смотреть варианты →</div>
            </div>
            <span class="scenario-card-arrow" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 620px;
    overflow: hidden;
    background: #fff;
  }

  .hero-picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 55% center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.86) 0%,
      rgba(0, 0, 0, 0.72) 34%,
      rgba(0, 0, 0, 0.3) 62%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    margin: 0 auto;
    padding: 82px 32px 44px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(390px, 440px);
    gap: 42px;
    align-items: start;
  }

  .hero-left h1 {
    font-family: var(--font-heading);
    font-size: 56px;
    line-height: 1.08;
    font-weight: 500;
    letter-spacing: 0;
    color: #fff;
    max-width: 640px;
    margin: 0 0 24px;
  }

  .hero-left p {
    font-size: 18px;
    line-height: 1.55;
    font-weight: 400 !important;
    color: rgba(255, 255, 255, 0.88);
    max-width: 620px;
    margin: 0 0 32px;
  }

  .hero-subtitle-mobile,
  .hero-btn-mobile,
  .hero-feature-mobile {
    display: none;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    padding: 16px 28px;
    font-size: 14px;
    font-weight: 600;
    min-width: 210px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .hero-btn:hover {
    opacity: 0.8;
  }

  .hero-btn-primary {
    background: #c1121f;
    color: #fff;
    border: 1px solid #c1121f;
  }

  .hero-btn-primary:hover {
    background: #a30f19;
    border-color: #a30f19;
  }

  .hero-btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.65);
  }

  .hero-configurator {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    min-width: 0;
  }

  .hero-features {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    margin: 0 auto;
    padding: 4px 32px 32px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .hero-feature {
    min-height: 78px;
    padding: 0 22px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fff;
    border-left: 1px solid rgba(255, 255, 255, 0.28);
    font-size: 14px;
    line-height: 1.3;
  }

  .hero-feature-first {
    border-left: 0;
  }

  .hero-feature-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    color: #fff;
    opacity: 0.95;
  }

  .hero-feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .category-entry-section {
    background: #fff;
    padding: 34px 32px 28px;
  }

  .category-entry-wrap {
    max-width: 1180px;
    margin: 0 auto;
  }

  .category-entry-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .category-entry-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
    color: #111;
    margin: 0;
  }

  .category-entry-all {
    color: #b91c1c;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    white-space: nowrap;
  }

  .category-entry-all:hover {
    color: #991b1b;
  }

  .category-entry-subtitle {
    font-size: 14px;
    line-height: 1.5;
    color: #404040;
    margin-bottom: 16px;
  }

  .mobile-scenarios {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .desktop-scenarios {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .mobile-category-links {
    display: none;
  }

  .scenario-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    gap: 10px;
    padding: 10px;
    border: 1px solid #eee;
    border-radius: 10px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease,
      background-color 0.18s ease;
  }

  .scenario-card:hover {
    transform: translateY(-2px);
    border-color: #d5d5d5;
    background: #fcfcfc;
  }

  .scenario-card-image {
    width: 100%;
    height: 82px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .scenario-card-copy {
    min-width: 0;
  }

  .scenario-card-title {
    font-size: 13px;
    line-height: 1.25;
    font-weight: 600;
    color: #111;
    margin-bottom: 4px;
  }

  .scenario-card-desc {
    font-size: 12px;
    line-height: 1.35;
    color: #404040;
  }

  .scenario-card-cta {
    margin-top: 6px;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 600;
    color: #c1121f;
  }

  .scenario-card-arrow {
    margin-left: auto;
    display: inline-flex;
    color: #111;
    opacity: 0.5;
    flex-shrink: 0;
  }

  @media (max-width: 1279px) {
    .desktop-scenarios {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1024px) {
    .hero-bg {
      object-position: 58% center;
    }

    .hero {
      min-height: auto;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-top: 64px;
    }

    .hero-configurator {
      justify-content: stretch;
      align-items: stretch;
      width: 100%;
    }

    .desktop-scenarios {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .scenario-card {
      flex-direction: row;
      min-height: auto;
    }

    .scenario-card-image {
      width: 72px;
      height: 72px;
    }
  }

  @media (min-width: 820px) and (max-width: 1024px) {
    .hero {
      min-height: 620px;
    }

    .hero-content {
      grid-template-columns: minmax(0, 1fr) minmax(330px, 390px);
      gap: 24px;
      padding: 64px 24px 34px;
    }

    .hero-left h1 {
      max-width: 430px;
      font-size: 38px;
      line-height: 1.1;
    }

    .hero-left p {
      max-width: 420px;
      font-size: 16px;
      margin-bottom: 24px;
    }

    .hero-btn {
      min-width: 0;
      padding-left: 18px;
      padding-right: 18px;
    }

    .hero-configurator {
      justify-content: flex-end;
      align-items: flex-start;
    }

    .hero-features {
      padding: 0;
      margin-top: 44px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .hero-feature {
      min-height: auto;
      padding: 0;
      border-left: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      overflow: hidden;
    }

    .hero-bg {
      object-position: 60% center;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.38) 0%,
        rgba(0, 0, 0, 0.58) 44%,
        rgba(0, 0, 0, 0.78) 100%
      );
    }

    .hero-content {
      display: grid;
      max-width: none;
      padding: 42px 12px 24px;
      gap: 14px;
    }

    .hero-left {
      display: contents;
    }

    .hero-main-copy {
      order: 1;
      max-width: none;
      width: 100%;
    }

    .hero-left h1 {
      max-width: 330px;
      font-size: 31px;
      line-height: 1.12;
      font-weight: 500;
      letter-spacing: 0;
      margin: 0 0 18px;
    }

    .hero-left p {
      max-width: 280px;
      font-size: 14px;
      line-height: 1.5;
      margin: 0 0 16px;
      color: rgba(255, 255, 255, 0.82);
    }

    .hero-subtitle-desktop,
    .hero-btn-desktop,
    .hero-feature-desktop {
      display: none;
    }

    .hero-subtitle-mobile,
    .hero-btn-mobile,
    .hero-feature-mobile {
      display: inline;
    }

    .hero-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      max-width: 100%;
      width: 100%;
    }

    .hero-actions a {
      width: 100%;
      height: 44px;
      padding: 0 12px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .hero-configurator {
      order: 2;
      margin-top: 34px;
      position: relative;
      z-index: 4;
    }

    .hero-btn-primary,
    .hero-primary {
      background: #c1121f;
      border-color: #c1121f;
      color: #fff;
    }

    .hero-btn-secondary,
    .hero-secondary {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.4);
      color: #fff;
    }

    .hero-features {
      order: 3;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      max-width: none;
      width: 100%;
      padding: 0;
      margin: 4px 0 0;
    }

    .hero-feature {
      min-width: 0;
      min-height: auto;
      box-sizing: border-box;
      padding: 0;
      color: rgba(255, 255, 255, 0.88);
      gap: 6px;
      border: none !important;
      display: flex;
      align-items: center;
    }

    .hero-feature svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      opacity: 0.85;
    }

    .hero-feature span,
    .hero-feature p {
      min-width: 0;
      font-size: 13px;
      line-height: 1.1;
      font-weight: 500;
      word-break: normal;
      color: rgba(255, 255, 255, 0.8);
    }

    .category-entry-section {
      padding: 40px 16px 8px;
    }

    .category-entry-heading {
      display: block;
      margin-bottom: 10px;
    }

    .category-entry-all {
      display: none;
    }

    .category-entry-title {
      font-size: 22px;
      margin-bottom: 10px;
    }

    .category-entry-subtitle {
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 14px;
    }

    .desktop-scenarios {
      display: none;
    }

    .mobile-category-links {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .mobile-category-link {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr) 18px;
      gap: 12px;
      width: 100%;
      min-height: 72px;
      align-items: center;
      padding: 8px 10px 8px 8px;
      border: 1px solid #ececec;
      border-radius: 10px;
      color: #111;
      text-decoration: none;
      background: #fff;
    }

    .mobile-category-link-image {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 8px;
      background: #f5f5f5;
    }

    .mobile-category-link-title {
      display: block;
      font-size: 14px;
      line-height: 1.25;
      font-weight: 600;
    }

    .mobile-category-link-desc {
      display: block;
      margin-top: 3px;
      font-size: 12px;
      line-height: 1.25;
      color: #666;
    }

    .mobile-category-link-arrow {
      color: #777;
      font-size: 22px;
      line-height: 1;
      text-align: right;
    }

    .mobile-category-link:hover {
      color: #c1121f;
    }

    .mobile-scenarios {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .scenario-card {
      padding: 11px;
    }

    .scenario-card-image {
      width: 68px;
      height: 68px;
    }
  }

  @media (max-width: 390px) {
    .hero-content {
      padding-left: 12px;
      padding-right: 12px;
    }

    .hero-left h1 {
      font-size: 30px;
      max-width: 280px;
    }

    .hero-left p {
      font-size: 14px;
      max-width: 290px;
    }

    .hero-features {
