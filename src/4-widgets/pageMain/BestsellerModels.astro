---
import { Picture } from "@astrojs/image/components";
import { ModelJson } from "@entities/Model";
import { radiatorsJsonData } from "@entities/Radiator";
import { getModelSlug } from "@shared/utils/getModelSlug";

type Props = {
  models: ModelJson[];
};

const { models } = Astro.props as Props;
const type = models[0]?.type ?? "columns";
---

<div
  id="model_list"
  aria-label="Список моделей"
  class="bestseller-model-list scrollbar-hide"
  itemscope
  itemtype="https://schema.org/ItemList"
>
  {
    models.map((m, i) => {
      const title = `${m.prefix} Velar ${m.name}`;
      const imgPath =
        type !== "columns" // TODO: remove this columns hack :(
          ? `/images/models/${m.slug}/main.jpg`
          : `/images/models/columns/main${m.id[0]}b.jpg`;
      const modelHref = getModelSlug(m);

      const radiators = radiatorsJsonData.filter((r) => r.model_id === m.id);
      const minPrice = Math.min(...radiators.map((r) => Number(r.price)));

      return (
        <div
          class="bestseller-card"
          itemprop="itemListElement"
          itemscope
          itemtype="https://schema.org/Product"
        >
          <a href={modelHref} class="bestseller-link-main">
            <Picture
              itemprop="image"
              src={imgPath}
              alt={title}
              title={title}
              loading={i > 6 ? "lazy" : "eager"}
              aspectRatio="1:1"
              widths={[290, 400]}
              width={200}
              height={200}
              sizes="(max-width: 768px) 180px, 220px"
              class="bestseller-image"
            />
            <div itemprop="name" class="bestseller-name">
              {title}
            </div>
            <div itemprop="description" class="bestseller-description">
              {m.short_comment}
            </div>
          </a>
          <div
            itemprop="offers"
            itemscope
            itemtype="https://schema.org/Offer"
            class="bestseller-price"
          >
            <div
              itemprop="priceSpecification"
              itemscope
              itemtype="http://schema.org/PriceSpecification"
            >
              <meta itemprop="priceCurrency" content="RUB" />
              <meta itemprop="price" content={`${Number(minPrice)}`} />
              Цена от: {minPrice.toLocaleString("ru-RU")} руб.
            </div>
          </div>
          <div class="bestseller-actions">
            <a href={modelHref} class="bestseller-btn bestseller-btn-secondary">
              Подробнее
            </a>
            {/* <a href="/request" class="bestseller-btn bestseller-btn-primary">
              Получить расчет
            </a> */}
          </div>
        </div>
      );
    })
  }
</div>

<style>
  .bestseller-model-list {
    margin-top: 20px;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding-bottom: 4px;
  }

  .bestseller-card {
    flex: 0 0 80vw;
    width: 80vw;
    max-width: 320px;
    min-width: 260px;
    scroll-snap-align: start;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    background: #fff;
    padding: 16px;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .bestseller-card:hover {
    transform: translateY(-2px);
    border-color: #d4d4d4;
  }

  .bestseller-link-main {
    text-decoration: none;
    color: inherit;
  }

  .bestseller-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    height: 190px;
    object-fit: contain;
    background: #fafafa;
    padding: 14px;
    border-radius: 16px;
    display: block;
  }

  .bestseller-name {
    margin-top: 12px;
    font-size: 15px;
    line-height: 1.25;
    font-weight: 600;
    color: #111;
  }

  .bestseller-description {
    margin-top: 8px;
    font-size: 12px;
    line-height: 1.15;
    font-weight: 400;
    color: #808080 !important; 
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bestseller-price {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.3;
    color: #444;
  }

  .bestseller-actions {
    margin-top: auto;
    padding-top: 12px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .bestseller-btn {
    flex: 1;
    height: 42px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
  }

  .bestseller-btn-secondary {
    border-color: #d4d4d4;
    color: #222;
    background: #fff;
  }

  .bestseller-btn-secondary:hover {
    border-color: #a3a3a3;
  }

  .bestseller-btn-primary {
    border-color: #c1121f;
    color: #fff;
    background: #c1121f;
  }

  .bestseller-btn-primary:hover {
    background: #a30f19;
    border-color: #a30f19;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .bestseller-model-list {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      gap: 20px;
      padding-bottom: 6px;
    }

    .bestseller-card {
      flex: 0 0 clamp(250px, 31vw, 320px);
      width: clamp(250px, 31vw, 320px);
      max-width: 320px;
      min-width: 250px;
      scroll-snap-align: start;
      padding: 18px;
    }

    .bestseller-image {
      height: 220px;
    }
  }

  @media (min-width: 1200px) {
    .bestseller-model-list {
      display: grid;
      overflow: visible;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
      padding-bottom: 0;
    }

    .bestseller-card {
      flex: initial;
      width: auto;
      max-width: none;
      min-width: 0;
      scroll-snap-align: unset;
      padding: 18px;
    }

    .bestseller-image {
      aspect-ratio: 1 / 1;
      height: 210px;
      padding: 16px;
    }

    .bestseller-description {
      font-size: 12px;
      -webkit-line-clamp: 3;
    }

    .bestseller-price {
      font-size: 14px;
    }

    .bestseller-btn {
      height: 42px;
    }
  }
</style>
