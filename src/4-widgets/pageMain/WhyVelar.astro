---
const advantages = [
  {
    title: "Подбор под проект",
    text: "Поможем выбрать модель, мощность, размер и подключение.",
    icon: "ruler",
  },
  {
    title: "Цвета RAL",
    text: "Подберем радиатор в цвет интерьера без визуального компромисса.",
    icon: "palette",
  },
  {
    title: "Заказные размеры",
    text: "Можно подобрать нестандартную высоту, длину и количество секций.",
    icon: "box",
  },
  {
    title: "Доставка по России",
    text: "Отправляем радиаторы и конвекторы в разные регионы.",
    icon: "truck",
  },
  {
    title: "Гарантия до 10 лет",
    text: "Официальная гарантия на оборудование Velar.",
    icon: "shield",
  },
  {
    title: "Работа с дизайнерами",
    text: "Помогаем подбирать решения для дизайн-проектов и частных объектов.",
    icon: "handshake",
  },
];

const icons: Record<string, string> = {
  ruler:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 5 5L8 21H3v-5z"/><path d="m15 4 5 5"/><path d="M11 6 9 8"/><path d="M13 10 11 12"/><path d="M15 14 13 16"/></svg>',
  palette:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"/><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/></svg>',
  box:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m21 8-9-5-9 5 9 5 9-5Z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>',
  truck:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>',
  shield:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>',
  handshake:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a2.2 2.2 0 0 0 3.1 0l3.6-3.6a2.2 2.2 0 0 0 0-3.1l-2.2-2.2"/><path d="m13 19-1-1"/><path d="m8 14 4.2-4.2a2.2 2.2 0 0 1 3.1 0l1.2 1.2"/><path d="m5 14-1.6-1.6a2.2 2.2 0 0 1 0-3.1l2.2-2.2a2.2 2.2 0 0 1 3.1 0l1.6 1.6"/><path d="m2 22 3-3"/><path d="m22 22-3-3"/></svg>',
};
---

<section id="advantages" class="why-velar-section">
  <div class="why-velar-wrap">
    <div class="why-velar-copy">
      <h2 class="text-3xl md:text-4xl font-semibold text-left">
        Почему выбирают VelarShop
      </h2>
      <p class="mt-3 text-base md:text-lg leading-7 text-neutral-600">
        Помогаем подобрать радиаторы Velar под интерьер, мощность и условия
        монтажа
      </p>
    </div>

    <div
      aria-label="Преимущества VelarShop"
      class="why-list"
    >
      {
        advantages.map((item) => (
          <article class="why-card">
            <div
              class="why-icon"
              aria-hidden="true"
              set:html={icons[item.icon]}
            />
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why-velar-section {
    background: #fafafa;
    padding: 48px 16px;
  }

  .why-velar-wrap {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    gap: 28px;
  }

  .why-velar-copy {
    max-width: 740px;
  }

  .why-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .why-card {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    border-top: 1px solid #e5e5e5;
    padding: 16px 0 4px;
  }

  .why-card h3 {
    margin: 0;
    font-size: 16px;
    line-height: 1.35;
    font-weight: 600;
    color: #111;
  }

  .why-card p {
    margin: 4px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: #525252;
  }

  .why-icon {
    width: 22px;
    height: 22px;
    color: #b91c1c;
    margin-top: 1px;
  }

  .why-icon :global(svg) {
    width: 22px;
    height: 22px;
    display: block;
  }

  @media (min-width: 769px) {
    .why-velar-section {
      padding: 72px 24px;
    }

    .why-velar-wrap {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 48px;
      align-items: start;
    }

    .why-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 10px;
    }
  }

  @media (min-width: 1200px) {
    .why-velar-section {
      padding: 88px 32px;
    }
  }
</style>
