---
const advantages = [
	{
		title: 'Подбор мощности',
		text: 'Помогаем выбрать радиатор под площадь и параметры отопления.',
	},
	{
		title: 'Цвета RAL',
		text: 'Подбираем цвет под интерьер или проект дизайнера.',
	},
	{
		title: 'Заказные размеры',
		text: 'Подбираем высоту, длину, секции и подключение.',
	},
	{
		title: 'Доставка по России',
		text: 'Организуем доставку транспортными компаниями.',
	},
	{
		title: 'Гарантия и документы',
		text: 'Предоставляем документы, сертификаты и гарантию.',
	},
	{
		title: 'Для частных и проектных заказов',
		text: 'Работаем с квартирами, домами, дизайнерами и организациями.',
	},
]
---

<section
	id='advantages'
	class='py-16 md:py-20 bg-neutral-50'
>
	<div class='max-w-6xl mx-auto px-5 md:px-10'>
		<h2 class='text-3xl font-bold text-left'>Почему выбирают VelarShop</h2>
		<div
			aria-label='Ключевые преимущества VelarShop'
			class='mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5'
		>
			{
				advantages.map(advantage => (
					<div class='h-full rounded-xl border border-neutral-200 bg-white p-5'>
						<h3 class='text-sm font-semibold uppercase'>{advantage.title}</h3>
						<p class='mt-3 text-sm leading-6 text-neutral-700'>{advantage.text}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
