---
const trustCards = [
  { title: "Гарантия до 10 лет", text: "На все радиаторы Velar", icon: "shield" },
  { title: "Сертификаты", text: "Соответствие ГОСТ и ТС", icon: "file" },
  { title: "Испытания", text: "Проверка давлением на каждом этапе", icon: "gauge" },
  { title: "Ответственность", text: "Контроль поставки и документов", icon: "clipboard" },
];

const certs = [
  { href: "/docs/certs/velar_cert_1.jpg", label: "Сертификат соответствия" },
  { href: "/docs/certs/velar_cert_2.jpg", label: "Сертификат соответствия" },
  { href: "/docs/certs/velar_cert_3.jpg", label: "Сертификат соответствия" },
  { href: "/docs/certs/velar_cert_4.jpg", label: "Сертификат соответствия" },
];

const icons: Record<string, string> = {
  shield:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>',
  file:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/></svg>',
  gauge:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/><path d="M12 20h.01"/></svg>',
  clipboard:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>',
};
---

<section id="docs" aria-label="Сертификаты для радиаторов и конвекторов Velar" class="docs-section">
  <div class="docs-wrap">
    <div class="docs-heading">
      <div>
        <h2>Гарантии и сертификаты</h2>
        <p>Качество, подтвержденное документами и опытом поставок.</p>
      </div>
    </div>

    <div class="docs-trust-grid">
      {
        trustCards.map((card) => (
          <article class="docs-trust-card">
            <span class="docs-icon" aria-hidden="true">
              <Fragment set:html={icons[card.icon]} />
            </span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))
      }
    </div>

    <div class="docs-list">
      {
        certs.map((cert) => (
          <a href={cert.href} target="_blank" rel="noopener noreferrer" class="docs-file-card">
            <span class="docs-file-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 15h6"/><path d="M9 18h3"/></svg>
            </span>
            <span>
              <span class="docs-file-title">{cert.label}</span>
              <span class="docs-file-action">Открыть документ →</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .docs-section {
    background: #fff;
    padding: 48px 16px;
  }

  .docs-wrap {
    max-width: 1180px;
    margin: 0 auto;
  }

  .docs-heading {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .docs-heading h2 {
    margin: 0;
    font-size: 30px;
    line-height: 1.16;
    font-weight: 600;
    color: #111;
  }

  .docs-heading p {
    margin: 10px 0 0;
    max-width: 640px;
    color: #666;
    font-size: 16px;
    line-height: 1.55;
  }

  .docs-heading a {
    color: #b91c1c;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .docs-trust-grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .docs-trust-card,
  .docs-file-card {
    border: 1px solid #ececec;
    border-radius: 10px;
    background: #fff;
  }

  .docs-trust-card {
    padding: 14px;
  }

  .docs-icon {
    display: inline-flex;
    width: 24px;
    height: 24px;
    color: #b91c1c;
  }

  .docs-icon svg {
    width: 24px;
    height: 24px;
  }

  .docs-trust-card h3 {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.25;
    font-weight: 600;
    color: #111;
  }

  .docs-trust-card p {
    margin: 5px 0 0;
    color: #666;
    font-size: 12px;
    line-height: 1.35;
  }

  .docs-list {
    margin-top: 16px;
    display: grid;
    gap: 10px;
  }

  .docs-file-card {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 13px;
    color: #111;
    text-decoration: none;
  }

  .docs-file-icon {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #fafafa;
    color: #b91c1c;
  }

  .docs-file-icon svg {
    width: 18px;
    height: 18px;
  }

  .docs-file-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
  }

  .docs-file-action {
    display: block;
    margin-top: 3px;
    color: #666;
    font-size: 12px;
    line-height: 1.25;
  }

  @media (min-width: 768px) {
    .docs-section {
      padding: 72px 24px;
    }

    .docs-heading {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .docs-heading h2 {
      font-size: 38px;
    }

    .docs-trust-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .docs-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
  }

  @media (min-width: 1024px) {
    .docs-trust-grid,
    .docs-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .docs-section {
      padding: 88px 32px;
    }
  }
</style>
