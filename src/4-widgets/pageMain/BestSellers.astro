---
const models = [
  {
    name: "P30",
    href: "/model/p30v",
    text: "Плоский профиль для современных интерьеров",
  },
  {
    name: "P60",
    href: "/model/p60v",
    text: "Широкая плоская труба, больше теплового излучения",
  },
  {
    name: "Q40",
    href: "/model/q40v",
    text: "Квадратный профиль для строгих интерьеров",
  },
  {
    name: "R32",
    href: "/model/r32v",
    text: "Круглая труба и спокойная вертикальная геометрия",
  },
  {
    name: "3030",
    href: "/columns/3030",
    text: "Трубчатый радиатор для установки под окно",
  },
  {
    name: "2180",
    href: "/columns/2180",
    text: "Высокий трубчатый радиатор для стен и простенков",
  },
];
---

<div id="catalog" aria-hidden="true" class="catalog-anchor"></div>
<section id="bestsellers" aria-labelledby="bestsellers-title" class="popular-models">
  <div class="popular-models__head">
    <h2 id="bestsellers-title">Популярные модели Velar</h2>
    <p>
      Несколько базовых серий, с которых удобно начать подбор по форме, месту установки и тепловой задаче.
    </p>
  </div>

  <div class="popular-models__grid">
    {
      models.map((model) => (
        <article class="popular-model">
          <div>
            <h3>{model.name}</h3>
            <p>{model.text}</p>
          </div>
          <div class="popular-model__actions">
            <a href={model.href}>Подробнее</a>
            <a href="/request">Получить расчет</a>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .catalog-anchor {
    position: relative;
    top: -90px;
    height: 0;
  }

  .popular-models {
    max-width: 1180px;
    margin: 0 auto;
    padding: 64px 24px 72px;
  }

  .popular-models__head {
    display: grid;
    gap: 12px;
    max-width: 760px;
  }

  .popular-models__head h2 {
    margin: 0;
    color: #111;
    font-size: 36px;
    font-weight: 600;
    line-height: 1.15;
  }

  .popular-models__head p {
    margin: 0;
    color: #4b5563;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
  }

  .popular-models__grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid #e5e7eb;
    border-left: 1px solid #e5e7eb;
  }

  .popular-model {
    min-height: 190px;
    border-right: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    padding: 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    background: #fff;
  }

  .popular-model h3 {
    margin: 0;
    color: #111;
    font-size: 22px;
    font-weight: 600;
    line-height: 1.15;
  }

  .popular-model p {
    margin: 10px 0 0;
    color: #52525b;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.55;
  }

  .popular-model__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
  }

  .popular-model__actions a {
    color: #b91c1c;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.3;
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: rgba(185, 28, 28, 0.4);
  }

  .popular-model__actions a:hover {
    color: #991b1b;
    text-decoration-color: transparent;
  }

  @media (max-width: 900px) {
    .popular-models {
      padding: 48px 16px 56px;
    }

    .popular-models__head h2 {
      font-size: 30px;
    }

    .popular-models__grid {
      grid-template-columns: 1fr;
    }

    .popular-model {
      min-height: auto;
      padding: 18px;
    }
  }
</style>
