---
const bullets = [
	'Подбор и расчет радиаторов',
	'Работа с частными клиентами и компаниями',
	'Доставка по России',
	'Сотрудничество с дизайнерами и строителями',
]
---

<section id='about-velarshop' aria-label='О VelarShop' class='bg-neutral-50 py-12 md:py-20'>
	<div class='max-w-7xl mx-auto px-5 md:px-10 grid grid-cols-1 lg:grid-cols-2 gap-8'>
		<div>
			<h2 class='text-3xl md:text-4xl font-semibold text-neutral-900'>О VelarShop</h2>
			<p class='mt-5 text-sm md:text-base leading-7 text-neutral-700'>
				VelarShop — магазин радиаторов Velar с подбором под проект.
			</p>
			<p class='mt-4 text-sm md:text-base leading-7 text-neutral-700'>
				Мы помогаем выбрать радиаторы для квартир, домов и коммерческих помещений: подбираем мощность, размеры, подключение, цвет и сроки производства.
			</p>
		</div>

		<div class='rounded-2xl border border-neutral-200 bg-white p-5 md:p-6'>
			<ul class='space-y-3 text-sm md:text-base leading-6 text-neutral-800'>
				{bullets.map(item => <li>{item}</li>)}
			</ul>
			<a
				href='/request'
				class='mt-6 inline-flex h-12 w-full md:w-auto items-center justify-center rounded-[3px] border border-red-700 bg-red-700 px-7 text-base font-semibold text-white transition-colors hover:bg-red-800 hover:border-red-800'
			>
				Получить консультацию
			</a>
		</div>
	</div>
</section>
