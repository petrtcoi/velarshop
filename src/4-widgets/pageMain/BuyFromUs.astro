---
const bullets = [
  "Официальный магазин Velar",
  "Подбор мощности и размеров",
  "Доставка по России",
  "Работа с частными и дизайн-проектами",
];
---

<section id="about-velarshop" aria-label="О VelarShop" class="shop-section">
  <div class="shop-wrap">
    <div class="shop-copy">
      <h2>О VelarShop</h2>
      <p>
        VelarShop — официальный магазин дизайнерских радиаторов Velar с подбором
        решений под интерьер, мощность и условия монтажа.
      </p>
      <p>
        Помогаем выбрать радиаторы для квартир, домов и коммерческих помещений:
        подбираем размер, подключение, цвет RAL и сроки производства.
      </p>
      <ul>
        {bullets.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <aside class="shop-callout">
      <h3>Поможем подобрать модель под проект</h3>
      <p>Можно отправить план, фото помещения или список размеров.</p>
      <a href="/request">Получить консультацию</a>
    </aside>
  </div>
</section>

<style>
  .shop-section {
    background: #fafafa;
    padding: 48px 16px;
  }

  .shop-wrap {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    gap: 24px;
  }

  .shop-copy {
    max-width: 720px;
  }

  .shop-copy h2,
  .shop-callout h3 {
    margin: 0;
    color: #111;
    font-weight: 600;
    line-height: 1.16;
  }

  .shop-copy h2 {
    font-size: 30px;
  }

  .shop-copy p {
    margin: 16px 0 0;
    color: #525252;
    font-size: 16px;
    line-height: 1.65;
  }

  .shop-copy ul {
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .shop-copy li {
    position: relative;
    padding-left: 18px;
    color: #222;
    font-size: 14px;
    line-height: 1.35;
  }

  .shop-copy li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #b91c1c;
  }

  .shop-callout {
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    background: #fff;
    padding: 22px;
  }

  .shop-callout h3 {
    font-size: 22px;
  }

  .shop-callout p {
    margin: 12px 0 0;
    color: #666;
    font-size: 14px;
    line-height: 1.55;
  }

  .shop-callout a {
    margin-top: 22px;
    display: inline-flex;
    width: 100%;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    background: #c1121f;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .shop-callout a:hover {
    background: #a30f19;
  }

  @media (min-width: 768px) {
    .shop-section {
      padding: 72px 24px;
    }

    .shop-wrap {
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 48px;
      align-items: center;
    }

    .shop-copy h2 {
      font-size: 38px;
    }

    .shop-copy ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .shop-section {
      padding: 88px 32px;
    }
  }
</style>
